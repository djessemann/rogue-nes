000389r 2  A9 rr            lda #<str_press_start
00038Br 2  85 rr            sta ptr_lo
00038Dr 2  A9 rr            lda #>str_press_start
00038Fr 2  85 rr            sta ptr_hi
000391r 2  A9 0A            lda #10
000393r 2  85 rr            sta temp_1
000395r 2  A9 10            lda #16
000397r 2  85 rr            sta temp_2
000399r 2  20 rr rr         jsr draw_text
00039Cr 2               
00039Cr 2                   ; Draw "A ROGUELIKE ADVENTURE"
00039Cr 2  A9 rr            lda #<str_subtitle
00039Er 2  85 rr            sta ptr_lo
0003A0r 2  A9 rr            lda #>str_subtitle
0003A2r 2  85 rr            sta ptr_hi
0003A4r 2  A9 05            lda #5
0003A6r 2  85 rr            sta temp_1
0003A8r 2  A9 0D            lda #13
0003AAr 2  85 rr            sta temp_2
0003ACr 2  20 rr rr         jsr draw_text
0003AFr 2               
0003AFr 2                   ; Enable rendering (NMI will flush VRAM buffer)
0003AFr 2  A9 80            lda #%10000000              ; NMI on, BG pattern table 0
0003B1r 2  85 rr            sta ppu_ctrl
0003B3r 2  A9 0E            lda #%00001110              ; Show BG, no clipping
0003B5r 2  85 rr            sta ppu_mask
0003B7r 2  A9 00            lda #$00
0003B9r 2  85 rr            sta ppu_scroll_x
0003BBr 2  85 rr            sta ppu_scroll_y
0003BDr 2  A5 rr            lda ppu_ctrl
0003BFr 2  8D 00 20         sta $2000                   ; Re-enable NMI last
0003C2r 2               
0003C2r 2  A9 01            lda #$01
0003C4r 2  85 rr            sta state_initialized
0003C6r 2  60               rts
0003C7r 2               
0003C7r 2               @update:
0003C7r 2                   ; Wait for Start button
0003C7r 2  A5 rr            lda buttons_new
0003C9r 2  29 10            and #BUTTON_START
0003CBr 2  F0 13            beq @done
0003CDr 2               
0003CDr 2                   ; Seed RNG from frame counter
0003CDr 2  A5 rr            lda frame_counter
0003CFr 2  85 rr            sta rng_seed_lo
0003D1r 2  49 A5            eor #$A5
0003D3r 2  85 rr            sta rng_seed_hi
0003D5r 2               
0003D5r 2                   ; Start new game
0003D5r 2  20 rr rr         jsr game_init
0003D8r 2  A9 01            lda #STATE_GAMEPLAY
0003DAr 2  85 rr            sta game_state
0003DCr 2  A9 00            lda #$00
0003DEr 2  85 rr            sta state_initialized
0003E0r 2               @done:
0003E0r 2  60               rts
0003E1r 2               .endproc
0003E1r 2               
0003E1r 2               ; ============================================================
