000496r 2  A5 rr            lda state_initialized
000498r 2  F0 03            beq @init
00049Ar 2  4C rr rr         jmp @update
00049Dr 2               @init:
00049Dr 2                   ; --- Init ---
00049Dr 2                   ; Disable NMI and rendering for safe PPU access
