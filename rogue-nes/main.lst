001504r 2  85 rr            sta temp_1
001506r 2  A9 00            lda #HUD_ROW_0
001508r 2  85 rr            sta temp_2
00150Ar 2  A5 rr            lda player_max_hp
00150Cr 2  20 rr rr         jsr draw_number_3d
00150Fr 2               
