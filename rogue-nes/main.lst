000477r 2               .proc state_inventory
000477r 2  A5 rr            lda state_initialized
000479r 2  D0 05            bne @update
00047Br 2               
00047Br 2                   ; --- Init (simple placeholder) ---
00047Br 2  A9 01            lda #$01
00047Dr 2  85 rr            sta state_initialized
00047Fr 2  60               rts
000480r 2               
000480r 2               @update:
000480r 2                   ; B or Start to close
000480r 2  A5 rr            lda buttons_new
000482r 2  29 40            and #BUTTON_B
000484r 2  D0 07            bne @close
000486r 2  A5 rr            lda buttons_new
000488r 2  29 10            and #BUTTON_START
00048Ar 2  D0 01            bne @close
00048Cr 2  60               rts
00048Dr 2               
00048Dr 2               @close:
00048Dr 2  A9 01            lda #STATE_GAMEPLAY
00048Fr 2  85 rr            sta game_state
000491r 2  A9 01            lda #$01                    ; Don't re-init gameplay (already drawn)
000493r 2  85 rr            sta state_initialized
000495r 2  60               rts
000496r 2               .endproc
000496r 2               
