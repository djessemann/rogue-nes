0003E5r 2  A9 00            lda #$00
0003E7r 2  8D 00 20         sta $2000                   ; Disable NMI first
0003EAr 2  8D 01 20         sta $2001                   ; Disable rendering
0003EDr 2  85 rr            sta ppu_ctrl                ; Update shadow
0003EFr 2  85 rr            sta ppu_mask                ; Update shadow
0003F1r 2  85 rr            sta vram_buf_len            ; Clear VRAM buffer
