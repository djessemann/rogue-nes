001553r 2  A9 1A            lda #$1A
001555r 2  85 rr            sta temp_1
001557r 2  A9 01            lda #HUD_ROW_1
001559r 2  85 rr            sta temp_2
00155Br 2  A5 rr            lda player_gold
00155Dr 2  20 rr rr         jsr draw_number_3d
001560r 2               
001560r 2  60               rts
001561r 2               .endproc
001561r 2               
001561r 1               .include "messages.asm"
001561r 2               ; ============================================================
001561r 2               ; Message Log — 2-line narrative display at bottom of screen
001561r 2               ; ============================================================
001561r 2               .segment "CODE"
001561r 2               
001561r 2               ; ------------------------------------------------------------
001561r 2               ; msg_show
001561r 2               ; Display a message on the bottom line, scrolling previous up.
001561r 2               ; Input: ptr_lo/ptr_hi = pointer to null-terminated string
001561r 2               ; Clobbers: A, X, Y, temp_1-4
001561r 2               ; ------------------------------------------------------------
001561r 2               .proc msg_show
001561r 2                   ; Save incoming message pointer
001561r 2  A5 rr            lda ptr_lo
001563r 2  85 rr            sta msg_new_lo
001565r 2  A5 rr            lda ptr_hi
001567r 2  85 rr            sta msg_new_hi
001569r 2               
001569r 2                   ; Step 1: Draw current msg_buf to row 28 (scroll up)
001569r 2  A9 00            lda #$00
00156Br 2  85 rr            sta temp_1
00156Dr 2  A9 1C            lda #MSG_ROW_0
00156Fr 2  85 rr            sta temp_2
001571r 2  20 rr rr         jsr clear_msg_row
001574r 2               
001574r 2  A9 rr            lda #<msg_buf
001576r 2  85 rr            sta ptr_lo
001578r 2  A9 rr            lda #>msg_buf
00157Ar 2  85 rr            sta ptr_hi
00157Cr 2  A9 00            lda #$00
00157Er 2  85 rr            sta temp_1
001580r 2  A9 1C            lda #MSG_ROW_0
001582r 2  85 rr            sta temp_2
001584r 2  20 rr rr         jsr draw_text
001587r 2               
001587r 2                   ; Step 2: Copy new message into msg_buf
001587r 2  A5 rr            lda msg_new_lo
001589r 2  85 rr            sta ptr_lo
00158Br 2  A5 rr            lda msg_new_hi
00158Dr 2  85 rr            sta ptr_hi
00158Fr 2               
00158Fr 2  A0 00            ldy #$00
001591r 2               @copy:
001591r 2  B1 rr            lda (ptr_lo), y
001593r 2  99 rr rr         sta msg_buf, y
001596r 2  F0 0A            beq @copy_done              ; Null terminator
001598r 2  C8               iny
001599r 2  C0 1F            cpy #31                     ; Max 31 chars + null
00159Br 2  D0 F4            bne @copy
00159Dr 2  A9 00            lda #$00
00159Fr 2  99 rr rr         sta msg_buf, y              ; Force null terminate
0015A2r 2               @copy_done:
0015A2r 2               
0015A2r 2                   ; Step 3: Clear row 29 and draw new message
0015A2r 2  A9 00            lda #$00
0015A4r 2  85 rr            sta temp_1
0015A6r 2  A9 1D            lda #MSG_ROW_1
0015A8r 2  85 rr            sta temp_2
0015AAr 2  20 rr rr         jsr clear_msg_row
0015ADr 2               
0015ADr 2  A9 rr            lda #<msg_buf
0015AFr 2  85 rr            sta ptr_lo
0015B1r 2  A9 rr            lda #>msg_buf
0015B3r 2  85 rr            sta ptr_hi
0015B5r 2  A9 00            lda #$00
0015B7r 2  85 rr            sta temp_1
0015B9r 2  A9 1D            lda #MSG_ROW_1
0015BBr 2  85 rr            sta temp_2
0015BDr 2  20 rr rr         jsr draw_text
0015C0r 2               
0015C0r 2  60               rts
0015C1r 2               .endproc
0015C1r 2               
0015C1r 2               ; ------------------------------------------------------------
0015C1r 2               ; clear_msg_row
0015C1r 2               ; Queue blank tiles for a message row.
0015C1r 2               ; Input: temp_1 = X start, temp_2 = row
0015C1r 2               ; ------------------------------------------------------------
0015C1r 2               .proc clear_msg_row
0015C1r 2                   ; Overflow guard: 35 bytes (3 header + 32 spaces)
0015C1r 2  A5 rr            lda vram_buf_len
0015C3r 2  18               clc
0015C4r 2  69 23            adc #35
0015C6r 2  B0 34            bcs @overflow               ; carry = would exceed 255
0015C8r 2               
0015C8r 2                   ; Write 32 spaces to clear the row
0015C8r 2  A5 rr            lda temp_2
0015CAr 2  4A               lsr a
0015CBr 2  4A               lsr a
0015CCr 2  4A               lsr a
0015CDr 2  18               clc
0015CEr 2  69 20            adc #$20
0015D0r 2  85 rr            sta temp_4                  ; PPU addr high
0015D2r 2               
0015D2r 2  A5 rr            lda temp_2
0015D4r 2  0A               asl a
0015D5r 2  0A               asl a
0015D6r 2  0A               asl a
0015D7r 2  0A               asl a
0015D8r 2  0A               asl a
0015D9r 2  85 rr            sta temp_3                  ; PPU addr low
0015DBr 2               
0015DBr 2  A6 rr            ldx vram_buf_len
0015DDr 2  A5 rr            lda temp_4
0015DFr 2  9D rr rr         sta vram_buf, x
0015E2r 2  E8               inx
0015E3r 2  A5 rr            lda temp_3
0015E5r 2  9D rr rr         sta vram_buf, x
0015E8r 2  E8               inx
0015E9r 2  A9 20            lda #$20                    ; 32 tiles
0015EBr 2  9D rr rr         sta vram_buf, x
0015EEr 2  E8               inx
0015EFr 2               
0015EFr 2  A0 20            ldy #$20
0015F1r 2  A9 20            lda #$20                    ; Space character
0015F3r 2               @loop:
0015F3r 2  9D rr rr         sta vram_buf, x
0015F6r 2  E8               inx
0015F7r 2  88               dey
0015F8r 2  D0 F9            bne @loop
0015FAr 2               
0015FAr 2  86 rr            stx vram_buf_len
0015FCr 2               @overflow:
0015FCr 2  60               rts
0015FDr 2               .endproc
0015FDr 2               
0015FDr 1               .include "hunger.asm"
0015FDr 2               ; ============================================================
0015FDr 2               ; Hunger System
0015FDr 2               ; ============================================================
0015FDr 2               .segment "CODE"
0015FDr 2               
0015FDr 2               ; ------------------------------------------------------------
0015FDr 2               ; hunger_update
0015FDr 2               ; Decrease hunger counter each turn. Handle starvation.
0015FDr 2               ; Called once per player turn.
0015FDr 2               ; ------------------------------------------------------------
0015FDr 2               .proc hunger_update
0015FDr 2                   ; Decrease hunger
0015FDr 2  A5 rr            lda player_hunger
0015FFr 2  F0 27            beq @starving               ; Already at 0
001601r 2               
001601r 2  38               sec
001602r 2  E9 01            sbc #$01                    ; -1 per turn (simplified)
001604r 2  85 rr            sta player_hunger
001606r 2               
001606r 2                   ; Check hunger thresholds for messages
001606r 2  C9 32            cmp #HUNGER_HUNGRY
001608r 2  D0 0C            bne @check_weak
00160Ar 2                   ; Just crossed hungry threshold
00160Ar 2  A9 rr            lda #<str_hungry
00160Cr 2  85 rr            sta ptr_lo
00160Er 2  A9 rr            lda #>str_hungry
001610r 2  85 rr            sta ptr_hi
001612r 2  20 rr rr         jsr msg_show
001615r 2  60               rts
001616r 2               
001616r 2               @check_weak:
001616r 2  A5 rr            lda player_hunger
001618r 2  C9 0A            cmp #HUNGER_WEAK
00161Ar 2  D0 23            bne @done
00161Cr 2  A9 rr            lda #<str_weak
00161Er 2  85 rr            sta ptr_lo
001620r 2  A9 rr            lda #>str_weak
001622r 2  85 rr            sta ptr_hi
001624r 2  20 rr rr         jsr msg_show
001627r 2  60               rts
001628r 2               
001628r 2               @starving:
001628r 2                   ; Lose 1 HP per turn when starving
001628r 2  A5 rr            lda player_hp
00162Ar 2  F0 13            beq @done                   ; Already dead
00162Cr 2  C6 rr            dec player_hp
00162Er 2               
00162Er 2                   ; Show starving message (only occasionally to avoid spam)
00162Er 2  A5 rr            lda frame_counter
001630r 2  29 0F            and #$0F                    ; Every 16 frames
001632r 2  D0 0B            bne @done
001634r 2  A9 rr            lda #<str_starving
001636r 2  85 rr            sta ptr_lo
001638r 2  A9 rr            lda #>str_starving
00163Ar 2  85 rr            sta ptr_hi
00163Cr 2  20 rr rr         jsr msg_show
00163Fr 2               
00163Fr 2               @done:
00163Fr 2  60               rts
001640r 2               .endproc
001640r 2               
