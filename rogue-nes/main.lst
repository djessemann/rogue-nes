000000r 1               ; ============================================================
000000r 1               ; ROGUE NES — Main Entry Point
000000r 1               ; A roguelike dungeon crawler for the NES
000000r 1               ; ============================================================
000000r 1               
000000r 1               ; Include constants first (used by all modules)
000000r 1               .include "constants.asm"
000000r 2               ; ============================================================
000000r 2               ; Constants — All tunable game parameters
000000r 2               ; ============================================================
000000r 2               
000000r 2               ; --- Map Dimensions ---
000000r 2               MAP_W           = 64            ; Full map width in tiles
000000r 2               MAP_H           = 48            ; Full map height in tiles
000000r 2               MAP_SIZE        = MAP_W * MAP_H ; 3072 bytes
000000r 2               VIEW_W          = 32            ; Viewport width (one screen)
000000r 2               VIEW_H          = 24            ; Viewport height (one screen)
000000r 2               
000000r 2               ; --- Screen Layout ---
000000r 2               MAP_TOP_ROW     = 3             ; First tile row of dungeon on screen
000000r 2               MAP_ROWS        = VIEW_H       ; Visible map rows on screen
000000r 2               MAP_COLS        = VIEW_W       ; Visible map cols on screen
000000r 2               HUD_ROW_0       = 0             ; Stats bar row 1
000000r 2               HUD_ROW_1       = 1             ; Stats bar row 2
000000r 2               HUD_DIVIDER_0   = 2             ; Top divider
000000r 2               HUD_DIVIDER_1   = 27            ; Bottom divider
000000r 2               MSG_ROW_0       = 28            ; Message line 1
000000r 2               MSG_ROW_1       = 29            ; Message line 2
000000r 2               
000000r 2               ; --- Map Tile Types ---
000000r 2               TILE_WALL       = 0
000000r 2               TILE_FLOOR      = 1
000000r 2               TILE_CORRIDOR   = 2
000000r 2               TILE_DOOR_CLOSED = 3
000000r 2               TILE_DOOR_OPEN  = 4
000000r 2               TILE_STAIRS_UP  = 5
000000r 2               TILE_STAIRS_DOWN = 6
000000r 2               
000000r 2               ; --- CHR Tile Indices (background pattern table) ---
000000r 2               CHR_BLANK       = $00
000000r 2               CHR_WALL        = $01
000000r 2               CHR_WALL_2      = $02           ; Wall variant
000000r 2               CHR_FLOOR       = $03
000000r 2               CHR_CORRIDOR    = $04
000000r 2               CHR_DOOR_CLOSED = $05
000000r 2               CHR_DOOR_OPEN   = $06
000000r 2               CHR_STAIRS_UP   = $07
000000r 2               CHR_STAIRS_DOWN = $08
000000r 2               CHR_DARKNESS    = $09
000000r 2               CHR_DIVIDER     = $0A
000000r 2               CHR_EXPLORED    = $0B           ; Explored but not visible
000000r 2               
000000r 2               ; Item symbol tiles
000000r 2               CHR_GOLD        = $0C           ; *
000000r 2               CHR_FOOD        = $0D           ; :
000000r 2               CHR_WEAPON      = $0E           ; )
000000r 2               CHR_ARMOR       = $0F           ; [
000000r 2               CHR_POTION      = $10           ; !
000000r 2               CHR_SCROLL      = $11           ; ?
000000r 2               CHR_RING        = $12           ; =
000000r 2               CHR_WAND        = $13           ; /
000000r 2               CHR_GOBLET      = $14           ; U (special)
000000r 2               CHR_PLAYER      = $15           ; @
000000r 2               
000000r 2               ; Font starts at $20 (ASCII mapping)
000000r 2               ; A-Z = $41-$5A, a-z = $61-$7A, 0-9 = $30-$39
000000r 2               ; Space = $20, punctuation mapped to ASCII positions
000000r 2               
000000r 2               ; --- Controller Buttons ---
000000r 2               BUTTON_A        = %10000000
000000r 2               BUTTON_B        = %01000000
000000r 2               BUTTON_SELECT   = %00100000
000000r 2               BUTTON_START    = %00010000
000000r 2               BUTTON_UP       = %00001000
000000r 2               BUTTON_DOWN     = %00000100
000000r 2               BUTTON_LEFT     = %00000010
000000r 2               BUTTON_RIGHT    = %00000001
000000r 2               
000000r 2               ; --- Game States ---
000000r 2               STATE_TITLE     = 0
000000r 2               STATE_GAMEPLAY  = 1
000000r 2               STATE_INVENTORY = 2
000000r 2               STATE_DEATH     = 3
000000r 2               STATE_STAIRS    = 4
000000r 2               STATE_WIN       = 5
000000r 2               
000000r 2               ; --- Player Starting Stats ---
000000r 2               START_HP        = 12
000000r 2               START_MAX_HP    = 12
000000r 2               START_STR       = 16
000000r 2               START_DEF       = 10
000000r 2               START_GOLD      = 0
000000r 2               START_LEVEL     = 1
000000r 2               START_XP        = 0
000000r 2               START_HUNGER    = $FF           ; ~255 turns (simplified for NES)
000000r 2               
000000r 2               ; --- Dungeon Generation ---
000000r 2               GRID_ROWS       = 6             ; 6x6 room grid across 64x48 map
000000r 2               GRID_COLS       = 6
000000r 2               CELL_W          = 10            ; Tile width per grid cell (64/6 ~ 10)
000000r 2               CELL_H          = 8             ; Tile height per grid cell (48/6 = 8)
000000r 2               MIN_ROOM_W      = 4
000000r 2               MAX_ROOM_W      = 9
000000r 2               MIN_ROOM_H      = 3
000000r 2               MAX_ROOM_H      = 7
000000r 2               MAX_ROOMS       = 20
000000r 2               MIN_ROOMS       = 10
000000r 2               ROOM_CHANCE     = 192           ; 75% of 256
000000r 2               
000000r 2               ; --- Fog of War ---
000000r 2               FOG_HIDDEN      = 0             ; Never seen
000000r 2               FOG_EXPLORED    = 1             ; Previously seen (dim)
000000r 2               FOG_VISIBLE     = 2             ; Currently visible
000000r 2               
000000r 2               ; --- Monsters ---
000000r 2               MAX_MONSTERS    = 10
000000r 2               MONSTER_WAKE_DIST = 5           ; Tiles away to wake up
000000r 2               
000000r 2               ; Monster types (index into tables)
000000r 2               MON_BAT         = 0
000000r 2               MON_EMU         = 1
000000r 2               MON_HOBGOBLIN   = 2
000000r 2               MON_SNAKE       = 3
000000r 2               MON_ZOMBIE      = 4
000000r 2               
000000r 2               ; Monster flags
000000r 2               MFLAG_AWAKE     = %00000001
000000r 2               MFLAG_AGGRESSIVE = %00000010    ; Starts awake
000000r 2               MFLAG_ERRATIC   = %00000100    ; Random movement 50%
000000r 2               
000000r 2               ; --- Items ---
000000r 2               MAX_FLOOR_ITEMS = 16
000000r 2               MAX_INVENTORY   = 23
000000r 2               
000000r 2               ; Item types
000000r 2               ITEM_GOLD       = 0
000000r 2               ITEM_FOOD       = 1
000000r 2               ; (more in Phase 2)
000000r 2               
000000r 2               ; --- Combat ---
000000r 2               ; d20 system parameters
000000r 2               D20_SIDES       = 20
000000r 2               
000000r 2               ; --- Hunger ---
000000r 2               HUNGER_MAX      = 255           ; Simplified for 8-bit
000000r 2               HUNGER_NORMAL   = 150
000000r 2               HUNGER_HUNGRY   = 50
000000r 2               HUNGER_WEAK     = 10
000000r 2               FOOD_RESTORE    = 100           ; Hunger restored by food
000000r 2               
000000r 2               ; --- Dungeon ---
000000r 2               MAX_DUNGEON_LEVEL = 13
000000r 2               
000000r 1               
000000r 1               ; ============================================================
000000r 1               ; Zero Page Variables ($0000-$00FF) — Fast access
000000r 1               ; ============================================================
000000r 1               .segment "ZEROPAGE"
000000r 1               
000000r 1               ; --- NMI synchronization ---
000000r 1  xx           nmi_ready:          .res 1      ; Set by NMI, cleared by main loop
000001r 1               
000001r 1               ; --- Game state ---
000001r 1  xx           game_state:         .res 1      ; Current STATE_* value
000002r 1  xx           state_initialized:  .res 1      ; 0 = needs init, 1 = running
000003r 1  xx           frame_counter:      .res 1      ; Increments every frame
000004r 1  xx           dungeon_level:      .res 1      ; Current floor (0-based)
000005r 1  xx           turn_taken:         .res 1      ; 1 if player acted this frame
000006r 1  xx           stairs_direction:   .res 1      ; 0 = down, 1 = up
000007r 1               
000007r 1               ; --- Input ---
000007r 1  xx           buttons:            .res 1      ; Current controller state
000008r 1  xx           buttons_prev:       .res 1      ; Previous frame state
000009r 1  xx           buttons_new:        .res 1      ; Newly pressed this frame
00000Ar 1               
00000Ar 1               ; --- PPU shadow registers ---
00000Ar 1  xx           ppu_ctrl:           .res 1      ; Shadow of $2000
00000Br 1  xx           ppu_mask:           .res 1      ; Shadow of $2001
00000Cr 1  xx           ppu_scroll_x:       .res 1      ; Horizontal scroll
00000Dr 1  xx           ppu_scroll_y:       .res 1      ; Vertical scroll
00000Er 1               
00000Er 1               ; --- General temps ---
00000Er 1  xx           temp_1:             .res 1
00000Fr 1  xx           temp_2:             .res 1
000010r 1  xx           temp_3:             .res 1
000011r 1  xx           temp_4:             .res 1
000012r 1  xx           ptr_lo:             .res 1      ; 16-bit pointer (low)
000013r 1  xx           ptr_hi:             .res 1      ; 16-bit pointer (high)
000014r 1  xx           addr_temp_lo:       .res 1      ; Secondary pointer
000015r 1  xx           addr_temp_hi:       .res 1
000016r 1               
000016r 1               ; --- Player ---
000016r 1  xx           player_x:           .res 1      ; Map tile X (0-31)
000017r 1  xx           player_y:           .res 1      ; Map tile Y (0-23)
000018r 1  xx           player_hp:          .res 1      ; Current HP
000019r 1  xx           player_max_hp:      .res 1      ; Maximum HP
00001Ar 1  xx           player_str:         .res 1      ; Strength
00001Br 1  xx           player_def:         .res 1      ; Defense
00001Cr 1  xx           player_gold:        .res 1      ; Gold (0-255)
00001Dr 1  xx           player_level:       .res 1      ; Character level
00001Er 1  xx           player_xp:          .res 1      ; Experience points
00001Fr 1  xx           player_hunger:      .res 1      ; Hunger counter
000020r 1  xx           player_status:      .res 1      ; Status effect flags
000021r 1               
000021r 1               ; --- Movement ---
000021r 1  xx           move_dx:            .res 1      ; Desired X delta (-1, 0, 1)
000022r 1  xx           move_dy:            .res 1      ; Desired Y delta (-1, 0, 1)
000023r 1  xx           target_x:           .res 1      ; Target tile X
000024r 1  xx           target_y:           .res 1      ; Target tile Y
000025r 1  xx           temp_move:          .res 1      ; Saved button state for movement
000026r 1               
000026r 1               ; --- RNG ---
000026r 1  xx           rng_seed_lo:        .res 1
000027r 1  xx           rng_seed_hi:        .res 1
000028r 1               
000028r 1               ; --- VRAM buffer ---
000028r 1  xx           vram_buf_len:       .res 1      ; Current length of VRAM buffer
000029r 1               
000029r 1               ; --- Dungeon generation temps ---
000029r 1  xx           temp_grid_x:        .res 1
00002Ar 1  xx           temp_grid_y:        .res 1
00002Br 1  xx           room_count:         .res 1
00002Cr 1  xx           temp_connect_a:     .res 1
00002Dr 1  xx           temp_connect_b:     .res 1
00002Er 1  xx           temp_cor_x1:        .res 1
00002Fr 1  xx           temp_cor_y1:        .res 1
000030r 1  xx           temp_cor_x2:        .res 1
000031r 1  xx           temp_cor_y2:        .res 1
000032r 1  xx           temp_dig_x:         .res 1
000033r 1  xx           temp_dig_y:         .res 1
000034r 1  xx           temp_room_idx:      .res 1
000035r 1               
000035r 1               ; --- Monster temps ---
000035r 1  xx           temp_mon_idx:       .res 1
000036r 1  xx           monster_count:      .res 1
000037r 1  xx           floor_item_count:   .res 1
000038r 1               
000038r 1               ; --- Message system ---
000038r 1  xx           msg_new_lo:         .res 1
000039r 1  xx           msg_new_hi:         .res 1
00003Ar 1               
00003Ar 1               ; --- Deferred rendering ---
00003Ar 1  xx           hud_dirty:          .res 1      ; 1 = HUD needs update next frame
00003Br 1               
00003Br 1               ; --- Viewport / Camera ---
00003Br 1  xx           camera_x:           .res 1      ; Viewport top-left tile X (0 or 32)
00003Cr 1  xx           camera_y:           .res 1      ; Viewport top-left tile Y (0 or 24)
00003Dr 1  xx           screen_flip:        .res 1      ; Nonzero = need full screen redraw
00003Er 1               
00003Er 1               ; --- Fog of war ---
00003Er 1  xx           player_current_room: .res 1     ; Room index player is in ($FF = corridor)
00003Fr 1  xx           player_prev_room:    .res 1     ; Previous room (for downgrading visibility)
000040r 1               
000040r 1               ; ============================================================
000040r 1               ; OAM Shadow Buffer ($0200-$02FF)
000040r 1               ; ============================================================
000040r 1               .segment "OAM"
000000r 1  xx xx xx xx  oam_buf:            .res 256
000004r 1  xx xx xx xx  
000008r 1  xx xx xx xx  
000100r 1               
000100r 1               ; ============================================================
000100r 1               ; WRAM — Battery-backed RAM ($6000-$7FFF)
000100r 1               ; ============================================================
000100r 1               .segment "WRAM"
000000r 1  xx xx xx xx  dungeon_map:        .res MAP_SIZE   ; 3072 bytes (64x48)
000004r 1  xx xx xx xx  
000008r 1  xx xx xx xx  
000C00r 1  xx xx xx xx  fog_map:            .res MAP_SIZE   ; 3072 bytes visibility data
000C04r 1  xx xx xx xx  
000C08r 1  xx xx xx xx  
001800r 1               
001800r 1               ; ============================================================
001800r 1               ; BSS — General RAM ($0300-$07FF)
001800r 1               ; ============================================================
001800r 1               .segment "BSS"
000000r 1               
000000r 1               ; --- Room data (9 rooms max) ---
000000r 1  xx xx xx xx  room_x:             .res MAX_ROOMS
000004r 1  xx xx xx xx  
000008r 1  xx xx xx xx  
000014r 1  xx xx xx xx  room_y:             .res MAX_ROOMS
000018r 1  xx xx xx xx  
00001Cr 1  xx xx xx xx  
000028r 1  xx xx xx xx  room_w:             .res MAX_ROOMS
00002Cr 1  xx xx xx xx  
000030r 1  xx xx xx xx  
00003Cr 1  xx xx xx xx  room_h:             .res MAX_ROOMS
000040r 1  xx xx xx xx  
000044r 1  xx xx xx xx  
000050r 1               
000050r 1               ; --- Monster data (struct-of-arrays, 10 max) ---
000050r 1  xx xx xx xx  mon_x:              .res MAX_MONSTERS
000054r 1  xx xx xx xx  
000058r 1  xx xx        
00005Ar 1  xx xx xx xx  mon_y:              .res MAX_MONSTERS
00005Er 1  xx xx xx xx  
000062r 1  xx xx        
000064r 1  xx xx xx xx  mon_type:           .res MAX_MONSTERS
000068r 1  xx xx xx xx  
00006Cr 1  xx xx        
00006Er 1  xx xx xx xx  mon_hp:             .res MAX_MONSTERS
000072r 1  xx xx xx xx  
000076r 1  xx xx        
000078r 1  xx xx xx xx  mon_flags:          .res MAX_MONSTERS
00007Cr 1  xx xx xx xx  
000080r 1  xx xx        
000082r 1  xx xx xx xx  mon_state:          .res MAX_MONSTERS
000086r 1  xx xx xx xx  
00008Ar 1  xx xx        
00008Cr 1               
00008Cr 1               ; --- Floor items (16 max) ---
00008Cr 1  xx xx xx xx  fi_x:               .res MAX_FLOOR_ITEMS
000090r 1  xx xx xx xx  
000094r 1  xx xx xx xx  
00009Cr 1  xx xx xx xx  fi_y:               .res MAX_FLOOR_ITEMS
0000A0r 1  xx xx xx xx  
0000A4r 1  xx xx xx xx  
0000ACr 1  xx xx xx xx  fi_type:            .res MAX_FLOOR_ITEMS
0000B0r 1  xx xx xx xx  
0000B4r 1  xx xx xx xx  
0000BCr 1  xx xx xx xx  fi_mod:             .res MAX_FLOOR_ITEMS
0000C0r 1  xx xx xx xx  
0000C4r 1  xx xx xx xx  
0000CCr 1               
0000CCr 1               ; --- VRAM buffer (shared with NMI) ---
0000CCr 1  xx xx xx xx  vram_buf:           .res 256
0000D0r 1  xx xx xx xx  
0000D4r 1  xx xx xx xx  
0001CCr 1               
0001CCr 1               ; --- Message buffer ---
0001CCr 1  xx xx xx xx  msg_buf:            .res 32
0001D0r 1  xx xx xx xx  
0001D4r 1  xx xx xx xx  
0001ECr 1               
0001ECr 1               ; ============================================================
0001ECr 1               ; Code Includes
0001ECr 1               ; ============================================================
0001ECr 1               .segment "CODE"
000000r 1               
000000r 1               ; Include all modules
000000r 1               .include "reset.asm"
000000r 2               ; ============================================================
000000r 2               ; Reset Handler — Standard NES boot sequence
000000r 2               ; ============================================================
000000r 2               .segment "CODE"
000000r 2               
000000r 2               .proc reset
000000r 2  78               sei                         ; Disable IRQs
000001r 2  D8               cld                         ; Clear decimal mode
000002r 2  A2 40            ldx #$40
000004r 2  8E 17 40         stx $4017                   ; Disable APU frame IRQ
000007r 2  A2 FF            ldx #$FF
000009r 2  9A               txs                         ; Initialize stack pointer to $01FF
00000Ar 2  E8               inx                         ; X = $00
00000Br 2  8E 00 20         stx $2000                   ; Disable NMI
00000Er 2  8E 01 20         stx $2001                   ; Disable rendering
000011r 2  8E 10 40         stx $4010                   ; Disable DMC IRQs
000014r 2               
000014r 2                   ; --- Wait for first vblank ---
000014r 2               @vblank1:
000014r 2  2C 02 20         bit $2002
000017r 2  10 FB            bpl @vblank1
000019r 2               
000019r 2                   ; --- Clear all RAM ($0000-$07FF) ---
000019r 2  A9 00            lda #$00
00001Br 2  A2 00            ldx #$00
00001Dr 2               @clear_ram:
00001Dr 2  95 00            sta $0000, x
00001Fr 2  9D 00 01         sta $0100, x
000022r 2  9D 00 02         sta $0200, x
000025r 2  9D 00 03         sta $0300, x
000028r 2  9D 00 04         sta $0400, x
00002Br 2  9D 00 05         sta $0500, x
00002Er 2  9D 00 06         sta $0600, x
000031r 2  9D 00 07         sta $0700, x
000034r 2  E8               inx
000035r 2  D0 E6            bne @clear_ram
000037r 2               
000037r 2                   ; --- Hide all sprites (Y position = $FF = off-screen) ---
000037r 2  A9 FF            lda #$FF
000039r 2  A2 00            ldx #$00
00003Br 2               @clear_oam:
00003Br 2  9D rr rr         sta oam_buf, x
00003Er 2  E8               inx
00003Fr 2  D0 FA            bne @clear_oam
000041r 2               
000041r 2                   ; --- Wait for second vblank (PPU is now fully warmed up) ---
000041r 2               @vblank2:
000041r 2  2C 02 20         bit $2002
000044r 2  10 FB            bpl @vblank2
000046r 2               
000046r 2                   ; --- Initialize MMC1 mapper ---
000046r 2                   ; Reset shift register
000046r 2  A9 80            lda #$80
000048r 2  8D 00 80         sta $8000
00004Br 2               
00004Br 2                   ; Write Control register ($8000): %01100
00004Br 2                   ; bit0=0 (horiz mirror), bit1-2=11 (PRG fix $C000), bit3=0 (CHR 8KB), bit4=0
00004Br 2  A9 0C            lda #%01100
00004Dr 2  8D 00 80         sta $8000                   ; bit 0
000050r 2  4A               lsr a
000051r 2  8D 00 80         sta $8000                   ; bit 1
000054r 2  4A               lsr a
000055r 2  8D 00 80         sta $8000                   ; bit 2
000058r 2  4A               lsr a
000059r 2  8D 00 80         sta $8000                   ; bit 3
00005Cr 2  4A               lsr a
00005Dr 2  8D 00 80         sta $8000                   ; bit 4 (commit)
000060r 2               
000060r 2                   ; Write PRG bank register ($E000): $00 = bank 0, WRAM enabled (bit4=0)
000060r 2  A9 00            lda #$00
000062r 2  8D 00 E0         sta $E000
000065r 2  4A               lsr a
000066r 2  8D 00 E0         sta $E000
000069r 2  4A               lsr a
00006Ar 2  8D 00 E0         sta $E000
00006Dr 2  4A               lsr a
00006Er 2  8D 00 E0         sta $E000
000071r 2  4A               lsr a
000072r 2  8D 00 E0         sta $E000
000075r 2               
000075r 2                   ; --- Clear WRAM ($6000-$7FFF) ---
000075r 2  A9 00            lda #$00
000077r 2  85 rr            sta ptr_lo
000079r 2  A9 60            lda #$60
00007Br 2  85 rr            sta ptr_hi
00007Dr 2  A9 00            lda #$00
00007Fr 2  A8               tay
000080r 2               @clear_wram:
000080r 2  91 rr            sta (ptr_lo), y
000082r 2  C8               iny
000083r 2  D0 FB            bne @clear_wram
000085r 2  E6 rr            inc ptr_hi
000087r 2  A5 rr            lda ptr_hi
000089r 2  C9 80            cmp #$80                    ; Stop at $8000
00008Br 2  D0 03            bne @clear_wram_cont
00008Dr 2  4C rr rr         jmp @wram_done
000090r 2               @clear_wram_cont:
000090r 2  A9 00            lda #$00
000092r 2  4C rr rr         jmp @clear_wram
000095r 2               @wram_done:
000095r 2               
000095r 2                   ; PPU is ready — jump to main game initialization
000095r 2  4C rr rr         jmp main
000098r 2               .endproc
000098r 2               
000098r 1               .include "nmi.asm"
000098r 2               ; ============================================================
000098r 2               ; NMI Handler — Runs every vblank
000098r 2               ; All PPU writes happen here. Game logic stays in main thread.
000098r 2               ; ============================================================
000098r 2               .segment "CODE"
000098r 2               
000098r 2               .proc nmi_handler
000098r 2                   ; Save registers
000098r 2  48               pha
000099r 2  8A               txa
00009Ar 2  48               pha
00009Br 2  98               tya
00009Cr 2  48               pha
00009Dr 2               
00009Dr 2                   ; --- OAM DMA transfer (copy $0200-$02FF to PPU OAM) ---
00009Dr 2  A9 00            lda #$00
00009Fr 2  8D 03 20         sta $2003                   ; Set OAM start address to 0
0000A2r 2  A9 rr            lda #>oam_buf               ; High byte of oam_buf ($02)
0000A4r 2  8D 14 40         sta $4014                   ; Trigger OAM DMA
0000A7r 2               
0000A7r 2                   ; --- Flush VRAM buffer if anything is queued ---
0000A7r 2  A6 rr            ldx vram_buf_len
0000A9r 2  F0 35            beq @no_vram_update
0000ABr 2               
0000ABr 2  AD 02 20         lda $2002                   ; Reset PPU address latch
0000AEr 2               
0000AEr 2  A2 00            ldx #$00
0000B0r 2               @vram_loop:
0000B0r 2  E4 rr            cpx vram_buf_len
0000B2r 2  F0 28            beq @vram_done
0000B4r 2               
0000B4r 2                   ; Read PPU address (high byte, then low byte)
0000B4r 2  BD rr rr         lda vram_buf, x
0000B7r 2  8D 06 20         sta $2006
0000BAr 2  E8               inx
0000BBr 2  BD rr rr         lda vram_buf, x
0000BEr 2  8D 06 20         sta $2006
0000C1r 2  E8               inx
0000C2r 2               
0000C2r 2                   ; Read data length
0000C2r 2  BD rr rr         lda vram_buf, x
0000C5r 2  85 rr            sta temp_1
0000C7r 2  E8               inx
0000C8r 2               
0000C8r 2                   ; Write data bytes
0000C8r 2  A0 00            ldy #$00
0000CAr 2               @data_loop:
0000CAr 2  C4 rr            cpy temp_1
0000CCr 2  F0 0B            beq @next_entry
0000CEr 2  BD rr rr         lda vram_buf, x
0000D1r 2  8D 07 20         sta $2007
0000D4r 2  E8               inx
0000D5r 2  C8               iny
0000D6r 2  4C rr rr         jmp @data_loop
0000D9r 2               
0000D9r 2               @next_entry:
0000D9r 2  4C rr rr         jmp @vram_loop
0000DCr 2               
0000DCr 2               @vram_done:
0000DCr 2                   ; Clear buffer
0000DCr 2  A9 00            lda #$00
0000DEr 2  85 rr            sta vram_buf_len
0000E0r 2               
0000E0r 2               @no_vram_update:
0000E0r 2                   ; --- Apply PPU registers ---
0000E0r 2  A5 rr            lda ppu_ctrl
0000E2r 2  8D 00 20         sta $2000
0000E5r 2  A5 rr            lda ppu_mask
0000E7r 2  8D 01 20         sta $2001
0000EAr 2  A5 rr            lda ppu_scroll_x
0000ECr 2  8D 05 20         sta $2005
0000EFr 2  A5 rr            lda ppu_scroll_y
0000F1r 2  8D 05 20         sta $2005
0000F4r 2               
0000F4r 2                   ; --- Signal main loop ---
0000F4r 2  A9 01            lda #$01
0000F6r 2  85 rr            sta nmi_ready
0000F8r 2               
0000F8r 2                   ; Restore registers
0000F8r 2  68               pla
0000F9r 2  A8               tay
0000FAr 2  68               pla
0000FBr 2  AA               tax
0000FCr 2  68               pla
0000FDr 2  40               rti
0000FEr 2               .endproc
0000FEr 2               
0000FEr 1               .include "ppu.asm"
0000FEr 2               ; ============================================================
0000FEr 2               ; PPU Utility Routines
0000FEr 2               ; ============================================================
0000FEr 2               .segment "CODE"
0000FEr 2               
0000FEr 2               ; ------------------------------------------------------------
0000FEr 2               ; load_palettes
0000FEr 2               ; Copy 32 bytes of palette data to PPU $3F00.
0000FEr 2               ; Must be called with rendering disabled.
0000FEr 2               ; Expects palette data address in ptr_lo/ptr_hi.
0000FEr 2               ; ------------------------------------------------------------
0000FEr 2               .proc load_palettes
0000FEr 2  AD 02 20         lda $2002                   ; Reset PPU address latch
000101r 2  A9 3F            lda #$3F
000103r 2  8D 06 20         sta $2006
000106r 2  A9 00            lda #$00
000108r 2  8D 06 20         sta $2006                   ; PPU address = $3F00
00010Br 2               
00010Br 2  A0 00            ldy #$00
00010Dr 2               @loop:
00010Dr 2  B1 rr            lda (ptr_lo), y
00010Fr 2  8D 07 20         sta $2007
000112r 2  C8               iny
000113r 2  C0 20            cpy #$20                    ; 32 bytes = 4 BG + 4 sprite palettes
000115r 2  D0 F6            bne @loop
000117r 2               
000117r 2                   ; Reset PPU address and scroll
000117r 2  A9 00            lda #$00
000119r 2  8D 06 20         sta $2006
00011Cr 2  8D 06 20         sta $2006
00011Fr 2  8D 05 20         sta $2005
000122r 2  8D 05 20         sta $2005
000125r 2  60               rts
000126r 2               .endproc
000126r 2               
000126r 2               ; ------------------------------------------------------------
000126r 2               ; clear_nametable
000126r 2               ; Fill nametable 0 ($2000-$23FF) with tile $00 and zero attributes.
000126r 2               ; Must be called with rendering disabled.
000126r 2               ; ------------------------------------------------------------
000126r 2               .proc clear_nametable
000126r 2  AD 02 20         lda $2002                   ; Reset PPU address latch
000129r 2  A9 20            lda #$20
00012Br 2  8D 06 20         sta $2006
00012Er 2  A9 00            lda #$00
000130r 2  8D 06 20         sta $2006                   ; PPU address = $2000
000133r 2               
000133r 2                   ; Write 1024 bytes of $00 (960 tiles + 64 attribute bytes)
000133r 2  A9 00            lda #$00
000135r 2  A2 04            ldx #$04                    ; 4 x 256 = 1024
000137r 2  A0 00            ldy #$00
000139r 2               @loop:
000139r 2  8D 07 20         sta $2007
00013Cr 2  C8               iny
00013Dr 2  D0 FA            bne @loop
00013Fr 2  CA               dex
000140r 2  D0 F7            bne @loop
000142r 2  60               rts
000143r 2               .endproc
000143r 2               
000143r 2               ; ------------------------------------------------------------
000143r 2               ; draw_text
000143r 2               ; Buffer a null-terminated ASCII string into VRAM buffer.
000143r 2               ; ASCII codes map directly to CHR tile indices.
000143r 2               ;
000143r 2               ; Input: ptr_lo/ptr_hi = string address
000143r 2               ;        temp_1 = nametable tile X (0-31)
000143r 2               ;        temp_2 = nametable tile Y (0-29)
000143r 2               ; Clobbers: A, X, Y, temp_3, temp_4
000143r 2               ; ------------------------------------------------------------
000143r 2               .proc draw_text
000143r 2                   ; Calculate nametable address: $2000 + (Y * 32) + X
000143r 2  A5 rr            lda temp_2
000145r 2  4A               lsr a
000146r 2  4A               lsr a
000147r 2  4A               lsr a
000148r 2  18               clc
000149r 2  69 20            adc #$20                    ; Base nametable at $2000
00014Br 2  85 rr            sta temp_4                  ; temp_4 = address high byte
00014Dr 2               
00014Dr 2  A5 rr            lda temp_2
00014Fr 2  0A               asl a
000150r 2  0A               asl a
000151r 2  0A               asl a
000152r 2  0A               asl a
000153r 2  0A               asl a                       ; A = (Y & 7) * 32
000154r 2  18               clc
000155r 2  65 rr            adc temp_1                  ; A = low byte + X offset
000157r 2  85 rr            sta temp_3                  ; temp_3 = address low byte
000159r 2  90 02            bcc @no_carry
00015Br 2  E6 rr            inc temp_4
00015Dr 2               @no_carry:
00015Dr 2               
00015Dr 2                   ; First pass: count string length
00015Dr 2  A0 00            ldy #$00
00015Fr 2               @count:
00015Fr 2  B1 rr            lda (ptr_lo), y
000161r 2  F0 04            beq @counted
000163r 2  C8               iny
000164r 2  4C rr rr         jmp @count
000167r 2               @counted:
000167r 2  84 rr            sty temp_1                  ; temp_1 = string length (reuse)
000169r 2               
000169r 2                   ; Overflow guard: check if buffer has room for 3 + length bytes
000169r 2  98               tya
00016Ar 2  18               clc
00016Br 2  69 03            adc #$03                    ; 3 header bytes + string length
00016Dr 2  18               clc
00016Er 2  65 rr            adc vram_buf_len
000170r 2  B0 26            bcs @overflow               ; carry = would exceed 255
000172r 2               
000172r 2                   ; Write VRAM buffer entry: [addr_hi, addr_lo, length, data...]
000172r 2  A6 rr            ldx vram_buf_len
000174r 2  A5 rr            lda temp_4
000176r 2  9D rr rr         sta vram_buf, x
000179r 2  E8               inx
00017Ar 2  A5 rr            lda temp_3
00017Cr 2  9D rr rr         sta vram_buf, x
00017Fr 2  E8               inx
000180r 2  A5 rr            lda temp_1
000182r 2  9D rr rr         sta vram_buf, x
000185r 2  E8               inx
000186r 2               
000186r 2                   ; Copy string bytes (tile indices = ASCII values)
000186r 2  A0 00            ldy #$00
000188r 2               @copy:
000188r 2  C4 rr            cpy temp_1
00018Ar 2  F0 0A            beq @done
00018Cr 2  B1 rr            lda (ptr_lo), y
00018Er 2  9D rr rr         sta vram_buf, x
000191r 2  E8               inx
000192r 2  C8               iny
000193r 2  4C rr rr         jmp @copy
000196r 2               @done:
000196r 2  86 rr            stx vram_buf_len
000198r 2               @overflow:
000198r 2  60               rts
000199r 2               .endproc
000199r 2               
000199r 2               ; ------------------------------------------------------------
000199r 2               ; draw_number
000199r 2               ; Draw a 1-2 digit decimal number to VRAM buffer.
000199r 2               ;
000199r 2               ; Input: A = number (0-99)
000199r 2               ;        temp_1 = nametable tile X
000199r 2               ;        temp_2 = nametable tile Y
000199r 2               ; Clobbers: A, X, Y, temp_3, temp_4
000199r 2               ; ------------------------------------------------------------
000199r 2               .proc draw_number
000199r 2  85 rr            sta temp_3                  ; Save number
00019Br 2               
00019Br 2                   ; Overflow guard: max 5 bytes (3 header + 2 digits)
00019Br 2  A5 rr            lda vram_buf_len
00019Dr 2  18               clc
00019Er 2  69 05            adc #$05
0001A0r 2  B0 71            bcs @overflow_early         ; carry = would exceed 255
0001A2r 2               
0001A2r 2                   ; Calculate nametable address
0001A2r 2  A5 rr            lda temp_2
0001A4r 2  4A               lsr a
0001A5r 2  4A               lsr a
0001A6r 2  4A               lsr a
0001A7r 2  18               clc
0001A8r 2  69 20            adc #$20
0001AAr 2  85 rr            sta temp_4                  ; High byte
0001ACr 2               
0001ACr 2  A5 rr            lda temp_2
0001AEr 2  0A               asl a
0001AFr 2  0A               asl a
0001B0r 2  0A               asl a
0001B1r 2  0A               asl a
0001B2r 2  0A               asl a
0001B3r 2  18               clc
0001B4r 2  65 rr            adc temp_1
0001B6r 2  48               pha                         ; Save low byte
0001B7r 2               
0001B7r 2                   ; Single or two digits?
0001B7r 2  A5 rr            lda temp_3
0001B9r 2  C9 0A            cmp #10
0001BBr 2  B0 1F            bcs @two_digits
0001BDr 2               
0001BDr 2                   ; --- Single digit ---
0001BDr 2  A6 rr            ldx vram_buf_len
0001BFr 2  A5 rr            lda temp_4
0001C1r 2  9D rr rr         sta vram_buf, x
0001C4r 2  E8               inx
0001C5r 2  68               pla
0001C6r 2  9D rr rr         sta vram_buf, x
0001C9r 2  E8               inx
0001CAr 2  A9 01            lda #$01
0001CCr 2  9D rr rr         sta vram_buf, x
0001CFr 2  E8               inx
0001D0r 2  A5 rr            lda temp_3
0001D2r 2  18               clc
0001D3r 2  69 30            adc #$30                    ; ASCII '0'
0001D5r 2  9D rr rr         sta vram_buf, x
0001D8r 2  E8               inx
0001D9r 2  86 rr            stx vram_buf_len
0001DBr 2  60               rts
0001DCr 2               
0001DCr 2               @two_digits:
0001DCr 2  A0 00            ldy #$00                    ; Tens counter
0001DEr 2  A5 rr            lda temp_3
0001E0r 2               @div10:
0001E0r 2  C9 0A            cmp #10
0001E2r 2  90 07            bcc @div_done
0001E4r 2  38               sec
0001E5r 2  E9 0A            sbc #10
0001E7r 2  C8               iny
0001E8r 2  4C rr rr         jmp @div10
0001EBr 2               @div_done:
0001EBr 2  85 rr            sta temp_3                  ; Ones digit
0001EDr 2               
0001EDr 2  A6 rr            ldx vram_buf_len
0001EFr 2  A5 rr            lda temp_4
0001F1r 2  9D rr rr         sta vram_buf, x
0001F4r 2  E8               inx
0001F5r 2  68               pla
0001F6r 2  9D rr rr         sta vram_buf, x
0001F9r 2  E8               inx
0001FAr 2  A9 02            lda #$02
0001FCr 2  9D rr rr         sta vram_buf, x
0001FFr 2  E8               inx
000200r 2  98               tya
000201r 2  18               clc
000202r 2  69 30            adc #$30                    ; Tens tile
000204r 2  9D rr rr         sta vram_buf, x
000207r 2  E8               inx
000208r 2  A5 rr            lda temp_3
00020Ar 2  18               clc
00020Br 2  69 30            adc #$30                    ; Ones tile
00020Dr 2  9D rr rr         sta vram_buf, x
000210r 2  E8               inx
000211r 2  86 rr            stx vram_buf_len
000213r 2               @overflow_early:
000213r 2  60               rts
000214r 2               .endproc
000214r 2               
000214r 2               ; ------------------------------------------------------------
000214r 2               ; draw_number_3d
000214r 2               ; Draw a 1-3 digit decimal number to VRAM buffer.
000214r 2               ; Always writes 3 characters (space-padded on left).
000214r 2               ;
000214r 2               ; Input: A = number low byte, temp_3 = number high byte (for >255)
000214r 2               ;        For now, supports 0-255 only (high byte ignored).
000214r 2               ;        temp_1 = nametable tile X
000214r 2               ;        temp_2 = nametable tile Y
000214r 2               ; Clobbers: A, X, Y, temp_3, temp_4
000214r 2               ; ------------------------------------------------------------
000214r 2               .proc draw_number_3d
000214r 2  85 rr            sta temp_3                  ; Save number
000216r 2               
000216r 2                   ; Overflow guard: 6 bytes (3 header + 3 digits)
000216r 2  A5 rr            lda vram_buf_len
000218r 2  18               clc
000219r 2  69 06            adc #$06
00021Br 2  B0 72            bcs @overflow_early         ; carry = would exceed 255
00021Dr 2               
00021Dr 2                   ; Calculate nametable address
00021Dr 2  A5 rr            lda temp_2
00021Fr 2  4A               lsr a
000220r 2  4A               lsr a
000221r 2  4A               lsr a
000222r 2  18               clc
000223r 2  69 20            adc #$20
000225r 2  85 rr            sta temp_4                  ; High byte
000227r 2               
000227r 2  A5 rr            lda temp_2
000229r 2  0A               asl a
00022Ar 2  0A               asl a
00022Br 2  0A               asl a
00022Cr 2  0A               asl a
00022Dr 2  0A               asl a
00022Er 2  18               clc
00022Fr 2  65 rr            adc temp_1
000231r 2               
000231r 2                   ; Write 3-char VRAM buffer entry
000231r 2  A6 rr            ldx vram_buf_len
000233r 2  48               pha
000234r 2  A5 rr            lda temp_4
000236r 2  9D rr rr         sta vram_buf, x
000239r 2  E8               inx
00023Ar 2  68               pla
00023Br 2  9D rr rr         sta vram_buf, x
00023Er 2  E8               inx
00023Fr 2  A9 03            lda #$03
000241r 2  9D rr rr         sta vram_buf, x
000244r 2  E8               inx
000245r 2               
000245r 2                   ; Divide by 100
000245r 2  A0 00            ldy #$00                    ; Hundreds counter
000247r 2  A5 rr            lda temp_3
000249r 2               @div100:
000249r 2  C9 64            cmp #100
00024Br 2  90 07            bcc @div100_done
00024Dr 2  38               sec
00024Er 2  E9 64            sbc #100
000250r 2  C8               iny
000251r 2  4C rr rr         jmp @div100
000254r 2               @div100_done:
000254r 2  85 rr            sta temp_3                  ; Remainder
000256r 2               
000256r 2                   ; Hundreds digit (or space if 0)
000256r 2  C0 00            cpy #$00
000258r 2  D0 09            bne @write_hundreds
00025Ar 2  A9 20            lda #$20                    ; Space
00025Cr 2  9D rr rr         sta vram_buf, x
00025Fr 2  E8               inx
000260r 2  4C rr rr         jmp @do_tens
000263r 2               @write_hundreds:
000263r 2  98               tya
000264r 2  18               clc
000265r 2  69 30            adc #$30
000267r 2  9D rr rr         sta vram_buf, x
00026Ar 2  E8               inx
00026Br 2               
00026Br 2               @do_tens:
00026Br 2                   ; Divide remainder by 10
00026Br 2  A0 00            ldy #$00
00026Dr 2  A5 rr            lda temp_3
00026Fr 2               @div10:
00026Fr 2  C9 0A            cmp #10
000271r 2  90 07            bcc @div10_done
000273r 2  38               sec
000274r 2  E9 0A            sbc #10
000276r 2  C8               iny
000277r 2  4C rr rr         jmp @div10
00027Ar 2               @div10_done:
00027Ar 2  85 rr            sta temp_3                  ; Ones digit
00027Cr 2               
00027Cr 2  98               tya
00027Dr 2  18               clc
00027Er 2  69 30            adc #$30
000280r 2  9D rr rr         sta vram_buf, x
000283r 2  E8               inx
000284r 2               
000284r 2  A5 rr            lda temp_3
000286r 2  18               clc
000287r 2  69 30            adc #$30
000289r 2  9D rr rr         sta vram_buf, x
00028Cr 2  E8               inx
00028Dr 2               
00028Dr 2  86 rr            stx vram_buf_len
00028Fr 2               @overflow_early:
00028Fr 2  60               rts
000290r 2               .endproc
000290r 2               
000290r 2               ; ------------------------------------------------------------
000290r 2               ; vram_write_tile
000290r 2               ; Queue a single tile write to the VRAM buffer.
000290r 2               ;
000290r 2               ; Input: A = tile index
000290r 2               ;        temp_1 = nametable tile X (0-31)
000290r 2               ;        temp_2 = nametable tile Y (0-29)
000290r 2               ; Clobbers: X, temp_3, temp_4
000290r 2               ; ------------------------------------------------------------
000290r 2               .proc vram_write_tile
000290r 2                   ; Overflow guard: 4 bytes (3 header + 1 tile)
000290r 2  48               pha                         ; Save tile
000291r 2  A5 rr            lda vram_buf_len
000293r 2  18               clc
000294r 2  69 04            adc #$04
000296r 2  68               pla                         ; Restore tile (A = tile again)
000297r 2  B0 36            bcs @overflow               ; carry from adc = would exceed 255
000299r 2  48               pha                         ; Re-save tile for later
00029Ar 2               
00029Ar 2                   ; Calculate nametable address: $2000 + (Y * 32) + X
00029Ar 2  A5 rr            lda temp_2
00029Cr 2  4A               lsr a
00029Dr 2  4A               lsr a
00029Er 2  4A               lsr a
00029Fr 2  18               clc
0002A0r 2  69 20            adc #$20
0002A2r 2  85 rr            sta temp_4                  ; High byte
0002A4r 2               
0002A4r 2  A5 rr            lda temp_2
0002A6r 2  0A               asl a
0002A7r 2  0A               asl a
0002A8r 2  0A               asl a
0002A9r 2  0A               asl a
0002AAr 2  0A               asl a
0002ABr 2  18               clc
0002ACr 2  65 rr            adc temp_1
0002AEr 2  85 rr            sta temp_3                  ; Low byte
0002B0r 2  90 02            bcc @no_carry
0002B2r 2  E6 rr            inc temp_4
0002B4r 2               @no_carry:
0002B4r 2               
0002B4r 2  A6 rr            ldx vram_buf_len
0002B6r 2  A5 rr            lda temp_4
0002B8r 2  9D rr rr         sta vram_buf, x
0002BBr 2  E8               inx
0002BCr 2  A5 rr            lda temp_3
0002BEr 2  9D rr rr         sta vram_buf, x
0002C1r 2  E8               inx
0002C2r 2  A9 01            lda #$01                    ; Length = 1
0002C4r 2  9D rr rr         sta vram_buf, x
0002C7r 2  E8               inx
0002C8r 2  68               pla                         ; Tile index
0002C9r 2  9D rr rr         sta vram_buf, x
0002CCr 2  E8               inx
0002CDr 2  86 rr            stx vram_buf_len
0002CFr 2               @overflow:
0002CFr 2  60               rts
0002D0r 2               .endproc
0002D0r 2               
0002D0r 2               ; ------------------------------------------------------------
0002D0r 2               ; clear_oam_sprites
0002D0r 2               ; Set all 64 sprite Y positions to $FF (offscreen/hidden).
0002D0r 2               ; ------------------------------------------------------------
0002D0r 2               .proc clear_oam_sprites
0002D0r 2  A9 FF            lda #$FF
0002D2r 2  A2 00            ldx #$00
0002D4r 2               @loop:
0002D4r 2  9D rr rr         sta oam_buf, x
0002D7r 2  E8               inx
0002D8r 2  E8               inx
0002D9r 2  E8               inx
0002DAr 2  E8               inx
0002DBr 2  D0 F7            bne @loop
0002DDr 2  60               rts
0002DEr 2               .endproc
0002DEr 2               
0002DEr 1               .include "input.asm"
0002DEr 2               ; ============================================================
0002DEr 2               ; Controller Input
0002DEr 2               ; ============================================================
0002DEr 2               .segment "CODE"
0002DEr 2               
0002DEr 2               ; ------------------------------------------------------------
0002DEr 2               ; read_controller
0002DEr 2               ; Read controller 1 state into `buttons`.
0002DEr 2               ; Computes `buttons_new` = buttons pressed this frame (edge detect).
0002DEr 2               ; Bit layout: A B Sel Start Up Down Left Right
0002DEr 2               ; ------------------------------------------------------------
0002DEr 2               .proc read_controller
0002DEr 2                   ; Save previous frame's state
0002DEr 2  A5 rr            lda buttons
0002E0r 2  85 rr            sta buttons_prev
0002E2r 2               
0002E2r 2                   ; Strobe controller
0002E2r 2  A9 01            lda #$01
0002E4r 2  8D 16 40         sta $4016
0002E7r 2  A9 00            lda #$00
0002E9r 2  8D 16 40         sta $4016
0002ECr 2               
0002ECr 2                   ; Read 8 buttons — each read returns button state in bit 0
0002ECr 2  A2 08            ldx #$08
0002EEr 2               @loop:
0002EEr 2  AD 16 40         lda $4016
0002F1r 2  4A               lsr a                       ; Bit 0 -> carry
0002F2r 2  26 rr            rol buttons                 ; Carry -> buttons (bit 0), shifts left
0002F4r 2  CA               dex
0002F5r 2  D0 F7            bne @loop
0002F7r 2               
0002F7r 2                   ; Compute newly pressed buttons (pressed now AND not pressed last frame)
0002F7r 2  A5 rr            lda buttons
0002F9r 2  45 rr            eor buttons_prev            ; Bits that changed
0002FBr 2  25 rr            and buttons                 ; Only the ones that are now pressed
0002FDr 2  85 rr            sta buttons_new
0002FFr 2               
0002FFr 2  60               rts
000300r 2               .endproc
000300r 2               
000300r 1               .include "rng.asm"
000300r 2               ; ============================================================
000300r 2               ; Random Number Generator — 16-bit Galois LFSR
000300r 2               ; ============================================================
000300r 2               .segment "CODE"
000300r 2               
000300r 2               ; ------------------------------------------------------------
000300r 2               ; rng_next
000300r 2               ; Advance the LFSR and return a pseudo-random byte in A.
000300r 2               ; Uses polynomial $00B4 for good distribution.
000300r 2               ; ------------------------------------------------------------
000300r 2               .proc rng_next
000300r 2                   ; If seed is 0, force to 1 (LFSR can't escape 0)
000300r 2  A5 rr            lda rng_seed_lo
000302r 2  05 rr            ora rng_seed_hi
000304r 2  D0 04            bne @not_zero
000306r 2  A9 01            lda #$01
000308r 2  85 rr            sta rng_seed_lo
00030Ar 2               @not_zero:
00030Ar 2               
00030Ar 2                   ; Shift right, XOR with taps if carry set
00030Ar 2  46 rr            lsr rng_seed_hi
00030Cr 2  66 rr            ror rng_seed_lo
00030Er 2  90 0C            bcc @no_tap
000310r 2                   ; XOR with polynomial $00B4
000310r 2  A5 rr            lda rng_seed_hi
000312r 2  49 00            eor #$00
000314r 2  85 rr            sta rng_seed_hi
000316r 2  A5 rr            lda rng_seed_lo
000318r 2  49 B4            eor #$B4
00031Ar 2  85 rr            sta rng_seed_lo
00031Cr 2               @no_tap:
00031Cr 2  A5 rr            lda rng_seed_lo             ; Return low byte as random value
00031Er 2  60               rts
00031Fr 2               .endproc
00031Fr 2               
00031Fr 2               ; ------------------------------------------------------------
00031Fr 2               ; rng_range
00031Fr 2               ; Return a random number in range 0..A-1.
00031Fr 2               ; Input: A = max (exclusive). Must be 1-255.
00031Fr 2               ; Output: A = random value in [0, max)
00031Fr 2               ; Clobbers: temp_1
00031Fr 2               ;
00031Fr 2               ; Uses rejection sampling for uniform distribution.
00031Fr 2               ; ------------------------------------------------------------
00031Fr 2               .proc rng_range
00031Fr 2  85 rr            sta temp_1                  ; Save max
000321r 2               @retry:
000321r 2  20 rr rr         jsr rng_next
000324r 2  C5 rr            cmp temp_1
000326r 2  B0 F9            bcs @retry                  ; If >= max, try again (simple rejection)
000328r 2  60               rts
000329r 2               .endproc
000329r 2               
000329r 1               .include "gamestate.asm"
000329r 2               ; ============================================================
000329r 2               ; Game State Machine
000329r 2               ; ============================================================
000329r 2               .segment "CODE"
000329r 2               
000329r 2               ; ------------------------------------------------------------
000329r 2               ; state_dispatch
000329r 2               ; Route to current state's handler.
000329r 2               ; Each state checks state_initialized:
000329r 2               ;   0 = run init, set to 1
000329r 2               ;   1 = run update
000329r 2               ; ------------------------------------------------------------
000329r 2               .proc state_dispatch
000329r 2  A5 rr            lda game_state
00032Br 2               
00032Br 2  C9 00            cmp #STATE_TITLE
00032Dr 2  F0 15            beq @title
00032Fr 2  C9 01            cmp #STATE_GAMEPLAY
000331r 2  F0 14            beq @gameplay
000333r 2  C9 02            cmp #STATE_INVENTORY
000335r 2  F0 13            beq @inventory
000337r 2  C9 03            cmp #STATE_DEATH
000339r 2  F0 12            beq @death
00033Br 2  C9 04            cmp #STATE_STAIRS
00033Dr 2  F0 11            beq @stairs
00033Fr 2  C9 05            cmp #STATE_WIN
000341r 2  F0 10            beq @win
000343r 2  60               rts
000344r 2               
000344r 2               @title:
000344r 2  4C rr rr         jmp state_title
000347r 2               @gameplay:
000347r 2  4C rr rr         jmp state_gameplay
00034Ar 2               @inventory:
00034Ar 2  4C rr rr         jmp state_inventory
00034Dr 2               @death:
00034Dr 2  4C rr rr         jmp state_death
000350r 2               @stairs:
000350r 2  4C rr rr         jmp state_stairs
000353r 2               @win:
000353r 2  4C rr rr         jmp state_win
000356r 2               .endproc
000356r 2               
000356r 2               ; ============================================================
000356r 2               ; TITLE STATE
