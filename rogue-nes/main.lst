000356r 2               .proc state_title
000356r 2  A5 rr            lda state_initialized
000358r 2  D0 6D            bne @update
00035Ar 2               
00035Ar 2                   ; --- Init ---
00035Ar 2                   ; Disable NMI and rendering for safe PPU access
00035Ar 2  A9 00            lda #$00
00035Cr 2  8D 00 20         sta $2000                   ; Disable NMI first
00035Fr 2  8D 01 20         sta $2001                   ; Disable rendering
000362r 2  85 rr            sta ppu_ctrl                ; Update shadow
000364r 2  85 rr            sta ppu_mask                ; Update shadow
000366r 2  85 rr            sta vram_buf_len            ; Clear VRAM buffer
000368r 2               
