00044Cr 2  60               rts
00044Dr 2               @no_inventory:
00044Dr 2               
00044Dr 2                   ; Process player input (turn-based: only act on new presses)
00044Dr 2  20 rr rr         jsr player_input
000450r 2               
000450r 2                   ; Handle screen flip if player moved to a new viewport
000450r 2  A5 rr            lda screen_flip
000452r 2  F0 07            beq @no_flip
000454r 2  20 rr rr         jsr do_screen_flip
000457r 2  A9 00            lda #$00
000459r 2  85 rr            sta screen_flip
00045Br 2               @no_flip:
00045Br 2               
00045Br 2                   ; If player acted (turn_taken != 0), run monster turns
00045Br 2  A5 rr            lda turn_taken
00045Dr 2  F0 0E            beq @no_turn
00045Fr 2  20 rr rr         jsr monsters_update
000462r 2  20 rr rr         jsr hunger_update
000465r 2               
000465r 2                   ; Check for player death
000465r 2  A5 rr            lda player_hp
000467r 2  F0 05            beq @player_died
000469r 2               
000469r 2                   ; Defer HUD update to next frame (avoids VRAM buffer overflow)
000469r 2  A9 01            lda #$01
00046Br 2  85 rr            sta hud_dirty
00046Dr 2               @no_turn:
00046Dr 2  60               rts
00046Er 2               
00046Er 2               @player_died:
00046Er 2  A9 03            lda #STATE_DEATH
000470r 2  85 rr            sta game_state
000472r 2  A9 00            lda #$00
000474r 2  85 rr            sta state_initialized
000476r 2  60               rts
000477r 2               .endproc
000477r 2               
