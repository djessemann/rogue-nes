001546r 2  A9 0F            lda #$0F
001548r 2  85 rr            sta temp_1
00154Ar 2  A9 01            lda #HUD_ROW_1
00154Cr 2  85 rr            sta temp_2
00154Er 2  A5 rr            lda player_xp
