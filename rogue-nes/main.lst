000433r 2               @update:
000433r 2                   ; Flush deferred HUD update from previous frame
000433r 2  A5 rr            lda hud_dirty
000435r 2  F0 07            beq @no_hud_refresh
000437r 2  A9 00            lda #$00
000439r 2  85 rr            sta hud_dirty
00043Br 2  20 rr rr         jsr hud_update
00043Er 2               @no_hud_refresh:
00043Er 2               
00043Er 2                   ; Check for inventory open
00043Er 2  A5 rr            lda buttons_new
000440r 2  29 10            and #BUTTON_START
000442r 2  F0 09            beq @no_inventory
000444r 2  A9 02            lda #STATE_INVENTORY
000446r 2  85 rr            sta game_state
000448r 2  A9 00            lda #$00
