0007B8r 2  00 00 00 00  
000FC0r 2                   .byte $00,$00,$00,$00,$00,$00,$00,$00
000FC0r 2                   .byte $00,$00,$00,$00,$00,$00,$00,$00
000FC0r 2               .endrepeat
