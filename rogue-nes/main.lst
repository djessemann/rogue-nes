00151Cr 2  A9 1D            lda #$1D
00151Er 2  85 rr            sta temp_1
001520r 2  A9 00            lda #HUD_ROW_0
001522r 2  85 rr            sta temp_2
001524r 2  A5 rr            lda dungeon_level
001526r 2  18               clc
001527r 2  69 01            adc #$01
001529r 2  20 rr rr         jsr draw_number
00152Cr 2               
00152Cr 2                   ; Def
00152Cr 2  A9 04            lda #$04
00152Er 2  85 rr            sta temp_1
001530r 2  A9 01            lda #HUD_ROW_1
001532r 2  85 rr            sta temp_2
001534r 2  A5 rr            lda player_def
001536r 2  20 rr rr         jsr draw_number
001539r 2               
001539r 2                   ; Exp level
001539r 2  A9 0C            lda #$0C
00153Br 2  85 rr            sta temp_1
00153Dr 2  A9 01            lda #HUD_ROW_1
00153Fr 2  85 rr            sta temp_2
001541r 2  A5 rr            lda player_level
001543r 2  20 rr rr         jsr draw_number
001546r 2               
