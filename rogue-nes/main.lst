001FC0r 1               ; ============================================================
001FC0r 1               ; Main — Game initialization and main loop
001FC0r 1               ; ============================================================
001FC0r 1               .segment "CODE"
001640r 1               
001640r 1               .proc main
001640r 1                   ; PPU init: NMI on, BG pattern table 0, sprite pattern table 1
001640r 1  A9 88            lda #%10001000
001642r 1  85 rr            sta ppu_ctrl
001644r 1  8D 00 20         sta $2000
001647r 1               
001647r 1                   ; Reset scroll
001647r 1  A9 00            lda #$00
001649r 1  85 rr            sta ppu_scroll_x
00164Br 1  85 rr            sta ppu_scroll_y
00164Dr 1               
00164Dr 1                   ; Init game state
00164Dr 1  A9 00            lda #STATE_TITLE
00164Fr 1  85 rr            sta game_state
001651r 1  A9 00            lda #$00
001653r 1  85 rr            sta state_initialized
001655r 1  85 rr            sta vram_buf_len
001657r 1               
001657r 1                   ; Init RNG with a non-zero seed
001657r 1  A9 42            lda #$42
001659r 1  85 rr            sta rng_seed_lo
00165Br 1  A9 7E            lda #$7E
00165Dr 1  85 rr            sta rng_seed_hi
00165Fr 1               
00165Fr 1               @loop:
00165Fr 1                   ; Wait for NMI (vblank sync)
00165Fr 1  A9 00            lda #$00
001661r 1  85 rr            sta nmi_ready
001663r 1               @wait_nmi:
001663r 1  A5 rr            lda nmi_ready
001665r 1  F0 FC            beq @wait_nmi
001667r 1               
001667r 1                   ; Tick frame counter
001667r 1  E6 rr            inc frame_counter
001669r 1               
001669r 1                   ; Read controller
001669r 1  20 rr rr         jsr read_controller
00166Cr 1               
00166Cr 1                   ; Game state dispatch
00166Cr 1  20 rr rr         jsr state_dispatch
00166Fr 1               
00166Fr 1  4C rr rr         jmp @loop
001672r 1               .endproc
001672r 1               
001672r 1               ; ============================================================
001672r 1               ; Interrupt Vectors
001672r 1               ; ============================================================
001672r 1               .segment "VECTORS"
000000r 1  rr rr            .word nmi_handler           ; NMI vector (vblank)
000002r 1  rr rr            .word reset                 ; Reset vector
000004r 1  00 00            .word $0000                 ; IRQ vector (unused)
000006r 1               
000006r 1               ; ============================================================
000006r 1               ; iNES Header
000006r 1               ; ============================================================
000006r 1               .include "header.asm"
000006r 2               ; ============================================================
000006r 2               ; iNES Header (16 bytes)
000006r 2               ; SxROM (MMC1): 32KB PRG-ROM + 8KB CHR-ROM + 8KB WRAM
000006r 2               ; Horizontal mirroring (controlled by mapper)
000006r 2               ; ============================================================
000006r 2               .segment "HEADER"
000000r 2  4E 45 53 1A      .byte "NES", $1A            ; iNES magic number
000004r 2  02               .byte $02                   ; 2 x 16KB PRG-ROM banks = 32KB
000005r 2  01               .byte $01                   ; 1 x 8KB CHR-ROM bank = 8KB
000006r 2  12               .byte %00010010             ; Flags 6: mapper 1 low nibble, battery WRAM
000007r 2  00               .byte %00000000             ; Flags 7: mapper 1 high nibble = 0
000008r 2  01               .byte $01                   ; Flags 8: 8KB PRG-RAM
000009r 2  00               .byte $00                   ; Flags 9: TV system (NTSC)
00000Ar 2  00               .byte $00                   ; Flags 10: unused
00000Br 2  00 00 00 00      .byte $00, $00, $00, $00, $00  ; Padding to 16 bytes
00000Fr 2  00           
000010r 2               
000010r 1               
