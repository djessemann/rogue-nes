0001D8r 1               .include "data/chr.asm"
0001D8r 2               ; ============================================================
0001D8r 2               ; CHR-ROM Data — 8KB (512 tiles, 16 bytes each)
0001D8r 2               ; Pattern Table 0 ($0000-$0FFF): Background tiles (256)
0001D8r 2               ; Pattern Table 1 ($1000-$1FFF): Sprite tiles (256)
0001D8r 2               ;
0001D8r 2               ; Each tile is 8x8 pixels, stored as two bitplanes:
0001D8r 2               ;   Plane 0 (8 bytes): bit 0 of each pixel
0001D8r 2               ;   Plane 1 (8 bytes): bit 1 of each pixel
0001D8r 2               ;   Pixel value = (plane1_bit << 1) | plane0_bit (0-3)
0001D8r 2               ;
0001D8r 2               ; Tile layout:
0001D8r 2               ;   $00       = Blank
0001D8r 2               ;   $01       = Wall (solid block)
0001D8r 2               ;   $02       = Wall variant 2
0001D8r 2               ;   $03       = Floor (dot)
0001D8r 2               ;   $04       = Corridor (dot, slightly different)
0001D8r 2               ;   $05       = Door closed (+)
0001D8r 2               ;   $06       = Door open (')
0001D8r 2               ;   $07       = Stairs up (<)
0001D8r 2               ;   $08       = Stairs down (>)
0001D8r 2               ;   $09       = Darkness (solid dark)
0001D8r 2               ;   $0A       = Divider line (horizontal line)
0001D8r 2               ;   $0B       = Explored tile
0001D8r 2               ;   $0C-$15   = Item symbols (*, :, ), [, !, ?, =, /, U, @)
0001D8r 2               ;   $20       = Space
0001D8r 2               ;   $21-$3F   = Punctuation (!-?)
0001D8r 2               ;   $30-$39   = Digits 0-9
0001D8r 2               ;   $41-$5A   = Uppercase A-Z
0001D8r 2               ;   $61-$7A   = Lowercase a-z
0001D8r 2               ; ============================================================
0001D8r 2               .segment "CHR"
000000r 2               
000000r 2               ; ===========================================
000000r 2               ; TILE $00: Blank (all transparent)
000000r 2               ; ===========================================
000000r 2  00 00 00 00      .byte %00000000, %00000000, %00000000, %00000000
000004r 2  00 00 00 00      .byte %00000000, %00000000, %00000000, %00000000
000008r 2  00 00 00 00      .byte %00000000, %00000000, %00000000, %00000000
00000Cr 2  00 00 00 00      .byte %00000000, %00000000, %00000000, %00000000
000010r 2               
000010r 2               ; ===========================================
000010r 2               ; TILE $01: Wall (solid block with border)
000010r 2               ; ===========================================
000010r 2  FF 81 81 81      .byte %11111111, %10000001, %10000001, %10000001
000014r 2  81 81 81 FF      .byte %10000001, %10000001, %10000001, %11111111
000018r 2  FF FF FF FF      .byte %11111111, %11111111, %11111111, %11111111
00001Cr 2  FF FF FF FF      .byte %11111111, %11111111, %11111111, %11111111
000020r 2               
000020r 2               ; ===========================================
000020r 2               ; TILE $02: Wall variant (brick pattern)
000020r 2               ; ===========================================
000020r 2  FF 88 FF 22      .byte %11111111, %10001000, %11111111, %00100010
000024r 2  FF 88 FF 22      .byte %11111111, %10001000, %11111111, %00100010
000028r 2  00 00 00 00      .byte %00000000, %00000000, %00000000, %00000000
00002Cr 2  00 00 00 00      .byte %00000000, %00000000, %00000000, %00000000
000030r 2               
000030r 2               ; ===========================================
000030r 2               ; TILE $03: Floor (center dot)
000030r 2               ; ===========================================
000030r 2  00 00 00 18      .byte %00000000, %00000000, %00000000, %00011000
000034r 2  18 00 00 00      .byte %00011000, %00000000, %00000000, %00000000
000038r 2  00 00 00 00      .byte %00000000, %00000000, %00000000, %00000000
00003Cr 2  00 00 00 00      .byte %00000000, %00000000, %00000000, %00000000
000040r 2               
000040r 2               ; ===========================================
000040r 2               ; TILE $04: Corridor (small dot)
000040r 2               ; ===========================================
000040r 2  00 00 00 10      .byte %00000000, %00000000, %00000000, %00010000
000044r 2  00 00 00 00      .byte %00000000, %00000000, %00000000, %00000000
000048r 2  00 00 00 00      .byte %00000000, %00000000, %00000000, %00000000
00004Cr 2  00 00 00 00      .byte %00000000, %00000000, %00000000, %00000000
000050r 2               
000050r 2               ; ===========================================
000050r 2               ; TILE $05: Door closed (+)
000050r 2               ; ===========================================
000050r 2  00 18 18 7E      .byte %00000000, %00011000, %00011000, %01111110
000054r 2  7E 18 18 00      .byte %01111110, %00011000, %00011000, %00000000
000058r 2  00 00 00 00      .byte %00000000, %00000000, %00000000, %00000000
00005Cr 2  00 00 00 00      .byte %00000000, %00000000, %00000000, %00000000
000060r 2               
000060r 2               ; ===========================================
000060r 2               ; TILE $06: Door open (.)
000060r 2               ; ===========================================
000060r 2  00 00 00 00      .byte %00000000, %00000000, %00000000, %00000000
000064r 2  00 00 18 18      .byte %00000000, %00000000, %00011000, %00011000
000068r 2  00 00 00 00      .byte %00000000, %00000000, %00000000, %00000000
00006Cr 2  00 00 00 00      .byte %00000000, %00000000, %00000000, %00000000
000070r 2               
000070r 2               ; ===========================================
000070r 2               ; TILE $07: Stairs up (<)
000070r 2               ; ===========================================
000070r 2  04 08 10 20      .byte %00000100, %00001000, %00010000, %00100000
000074r 2  20 10 08 04      .byte %00100000, %00010000, %00001000, %00000100
000078r 2  00 00 00 00      .byte %00000000, %00000000, %00000000, %00000000
00007Cr 2  00 00 00 00      .byte %00000000, %00000000, %00000000, %00000000
000080r 2               
000080r 2               ; ===========================================
000080r 2               ; TILE $08: Stairs down (>)
000080r 2               ; ===========================================
000080r 2  20 10 08 04      .byte %00100000, %00010000, %00001000, %00000100
000084r 2  04 08 10 20      .byte %00000100, %00001000, %00010000, %00100000
000088r 2  00 00 00 00      .byte %00000000, %00000000, %00000000, %00000000
00008Cr 2  00 00 00 00      .byte %00000000, %00000000, %00000000, %00000000
000090r 2               
000090r 2               ; ===========================================
