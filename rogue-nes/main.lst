00150Fr 2  A9 17            lda #$17
001511r 2  85 rr            sta temp_1
001513r 2  A9 00            lda #HUD_ROW_0
001515r 2  85 rr            sta temp_2
001517r 2  A5 rr            lda player_str
001519r 2  20 rr rr         jsr draw_number
00151Cr 2               
