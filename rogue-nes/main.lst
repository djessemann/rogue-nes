000401r 2  20 rr rr         jsr dungeon_generate_debug
000404r 2               
000404r 2                   ; === DEBUG TEST: draw test row AFTER dungeon gen to prove it completes ===
000404r 2  AD 02 20         lda $2002
000407r 2  A9 21            lda #$21
000409r 2  8D 06 20         sta $2006
00040Cr 2  A9 40            lda #$40
00040Er 2  8D 06 20         sta $2006
000411r 2  A2 20            ldx #$20
000413r 2  A9 01            lda #$01
000415r 2               @test_loop:
000415r 2  8D 07 20         sta $2007
000418r 2  CA               dex
000419r 2  D0 FA            bne @test_loop
00041Br 2                   ; === END DEBUG TEST ===
00041Br 2               
