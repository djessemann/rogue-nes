00060Cr 2               .endproc
00060Cr 2               
00060Cr 2               ; ============================================================
00060Cr 2               ; do_screen_flip — Full viewport redraw for screen transitions
00060Cr 2               ; Disables rendering, redraws viewport + HUD, re-enables.
00060Cr 2               ; ============================================================
00060Cr 2               .proc do_screen_flip
00060Cr 2                   ; Disable NMI and rendering for safe PPU access
00060Cr 2  A9 00            lda #$00
00060Er 2  8D 00 20         sta $2000                   ; Disable NMI first
000611r 2  8D 01 20         sta $2001                   ; Disable rendering
000614r 2  85 rr            sta ppu_ctrl                ; Update shadow
000616r 2  85 rr            sta ppu_mask                ; Update shadow
000618r 2  85 rr            sta vram_buf_len            ; Clear any pending VRAM writes
00061Ar 2               
00061Ar 2                   ; Redraw the entire viewport from new camera position
00061Ar 2  20 rr rr         jsr map_draw_viewport
00061Dr 2               
00061Dr 2                   ; Redraw HUD
00061Dr 2  20 rr rr         jsr hud_draw
000620r 2               
000620r 2                   ; Re-enable rendering
000620r 2  A9 80            lda #%10000000              ; NMI on, BG pattern table 0
000622r 2  85 rr            sta ppu_ctrl
000624r 2  A9 0E            lda #%00001110              ; Show BG, no clipping
000626r 2  85 rr            sta ppu_mask
000628r 2  A9 00            lda #$00
00062Ar 2  85 rr            sta ppu_scroll_x
00062Cr 2  85 rr            sta ppu_scroll_y
00062Er 2  A5 rr            lda ppu_ctrl
000630r 2  8D 00 20         sta $2000                   ; Re-enable NMI last
000633r 2               
000633r 2  60               rts
000634r 2               .endproc
000634r 2               
000634r 1               .include "dungeon.asm"
000634r 2               ; ============================================================
000634r 2               ; Dungeon Generation — 6x6 room grid with corridors
000634r 2               ; ============================================================
000634r 2               .segment "CODE"
000634r 2               
000634r 2               ; ------------------------------------------------------------
000634r 2               ; dungeon_generate
000634r 2               ; Generate a new dungeon level into the map buffer.
000634r 2               ; Places rooms, corridors, stairs, monsters, and items.
000634r 2               ; Clobbers: A, X, Y, all temps
000634r 2               ; ------------------------------------------------------------
000634r 2               .proc dungeon_generate
000634r 2                   ; Clear map to walls (3072 bytes via pointer loop)
000634r 2  A9 rr            lda #<dungeon_map
000636r 2  85 rr            sta ptr_lo
000638r 2  A9 rr            lda #>dungeon_map
00063Ar 2  85 rr            sta ptr_hi
00063Cr 2  A0 00            ldy #$00
00063Er 2  A9 00            lda #TILE_WALL
000640r 2               @clear:
000640r 2  91 rr            sta (ptr_lo), y
000642r 2  C8               iny
000643r 2  D0 FB            bne @clear
000645r 2  E6 rr            inc ptr_hi
000647r 2  A6 rr            ldx ptr_hi
000649r 2  E0 rr            cpx #>(dungeon_map + MAP_SIZE)
00064Br 2  D0 F3            bne @clear
00064Dr 2                   ; Check low byte boundary too (3072 = $C00, so low wraps to $00)
00064Dr 2                   ; dungeon_map is at $6000, end is at $6C00
00064Dr 2                   ; ptr_hi reaches $6C when done — the cpx above handles it
00064Dr 2               
00064Dr 2                   ; Clear fog map to FOG_HIDDEN
00064Dr 2  A9 rr            lda #<fog_map
00064Fr 2  85 rr            sta ptr_lo
000651r 2  A9 rr            lda #>fog_map
000653r 2  85 rr            sta ptr_hi
000655r 2  A0 00            ldy #$00
000657r 2  A9 00            lda #FOG_HIDDEN
000659r 2               @clear_fog:
000659r 2  91 rr            sta (ptr_lo), y
00065Br 2  C8               iny
00065Cr 2  D0 FB            bne @clear_fog
00065Er 2  E6 rr            inc ptr_hi
000660r 2  A6 rr            ldx ptr_hi
000662r 2  E0 rr            cpx #>(fog_map + MAP_SIZE)
000664r 2  D0 F3            bne @clear_fog
000666r 2               
000666r 2                   ; Clear room count
000666r 2  A9 00            lda #$00
000668r 2  85 rr            sta room_count
00066Ar 2               
00066Ar 2                   ; Clear monster/item counts
00066Ar 2  85 rr            sta monster_count
00066Cr 2  85 rr            sta floor_item_count
00066Er 2               
00066Er 2                   ; --- Generate rooms in 6x6 grid ---
00066Er 2  A9 00            lda #$00
000670r 2  85 rr            sta temp_grid_y             ; Grid row (0-5)
000672r 2               @grid_row:
000672r 2  A5 rr            lda temp_grid_y
000674r 2  C9 06            cmp #GRID_ROWS
000676r 2  F0 27            beq @rooms_done
000678r 2               
000678r 2  A9 00            lda #$00
00067Ar 2  85 rr            sta temp_grid_x             ; Grid column (0-2)
00067Cr 2               @grid_col:
00067Cr 2  A5 rr            lda temp_grid_x
00067Er 2  C9 06            cmp #GRID_COLS
000680r 2  F0 18            beq @next_row
000682r 2               
000682r 2                   ; Decide if this cell gets a room (75% chance)
000682r 2  20 rr rr         jsr rng_next
000685r 2  C9 C0            cmp #ROOM_CHANCE
000687r 2  B0 0C            bcs @skip_room
000689r 2               
000689r 2                   ; Room count check
000689r 2  A5 rr            lda room_count
00068Br 2  C9 14            cmp #MAX_ROOMS
00068Dr 2  F0 06            beq @skip_room
00068Fr 2               
00068Fr 2  20 rr rr         jsr generate_room
000692r 2  4C rr rr         jmp @next_col
000695r 2               
000695r 2               @skip_room:
000695r 2               @next_col:
000695r 2  E6 rr            inc temp_grid_x
000697r 2  4C rr rr         jmp @grid_col
00069Ar 2               
00069Ar 2               @next_row:
00069Ar 2  E6 rr            inc temp_grid_y
00069Cr 2  4C rr rr         jmp @grid_row
00069Fr 2               
00069Fr 2               @rooms_done:
00069Fr 2                   ; Ensure minimum room count
00069Fr 2  A5 rr            lda room_count
0006A1r 2  C9 0A            cmp #MIN_ROOMS
0006A3r 2  B0 03            bcs @enough_rooms
0006A5r 2                   ; Force-generate rooms in empty cells
0006A5r 2  20 rr rr         jsr force_more_rooms
0006A8r 2               
0006A8r 2               @enough_rooms:
0006A8r 2                   ; --- Connect rooms with corridors ---
0006A8r 2  20 rr rr         jsr connect_rooms
0006ABr 2               
0006ABr 2                   ; --- Place stairs ---
0006ABr 2  20 rr rr         jsr place_stairs
0006AEr 2               
0006AEr 2                   ; --- Place player in starting room ---
0006AEr 2  20 rr rr         jsr place_player
0006B1r 2               
0006B1r 2                   ; --- Spawn monsters ---
0006B1r 2  20 rr rr         jsr spawn_monsters
0006B4r 2               
0006B4r 2                   ; --- Spawn items (gold, food) ---
0006B4r 2  20 rr rr         jsr spawn_items
0006B7r 2               
0006B7r 2  60               rts
0006B8r 2               .endproc
0006B8r 2               
0006B8r 2               ; ------------------------------------------------------------
0006B8r 2               ; generate_room
0006B8r 2               ; Create a room in grid cell (temp_grid_x, temp_grid_y).
0006B8r 2               ; Stores room data in room_x/y/w/h arrays.
0006B8r 2               ; ------------------------------------------------------------
0006B8r 2               .proc generate_room
0006B8r 2  A6 rr            ldx room_count
0006BAr 2               
0006BAr 2                   ; Calculate cell origin in map coords and store directly in room arrays
0006BAr 2                   ; Cell X = grid_x * CELL_W + 1
0006BAr 2  A5 rr            lda temp_grid_x
0006BCr 2  0A               asl a                       ; * 2
0006BDr 2  85 rr            sta temp_1
0006BFr 2  0A               asl a                       ; * 4
0006C0r 2  0A               asl a                       ; * 8
0006C1r 2  18               clc
0006C2r 2  65 rr            adc temp_1                  ; * 10
0006C4r 2  18               clc
0006C5r 2  69 01            adc #$01                    ; 1-tile border
0006C7r 2  9D rr rr         sta room_x, x              ; Store cell X origin in room_x (safe from rng_range)
0006CAr 2               
0006CAr 2                   ; Cell Y = grid_y * CELL_H
0006CAr 2  A5 rr            lda temp_grid_y
0006CCr 2  0A               asl a                       ; * 2
0006CDr 2  0A               asl a                       ; * 4
0006CEr 2  0A               asl a                       ; * 8
0006CFr 2  9D rr rr         sta room_y, x              ; Store cell Y origin in room_y (safe from rng_range)
0006D2r 2               
0006D2r 2                   ; Random room size within cell (rng_range clobbers temp_1)
0006D2r 2  A9 09            lda #MAX_ROOM_W
0006D4r 2  38               sec
0006D5r 2  E9 04            sbc #MIN_ROOM_W
0006D7r 2  18               clc
0006D8r 2  69 01            adc #$01                    ; Range
0006DAr 2  20 rr rr         jsr rng_range
0006DDr 2  18               clc
0006DEr 2  69 04            adc #MIN_ROOM_W
0006E0r 2  9D rr rr         sta room_w, x               ; Width
0006E3r 2               
0006E3r 2  A9 07            lda #MAX_ROOM_H
0006E5r 2  38               sec
0006E6r 2  E9 03            sbc #MIN_ROOM_H
0006E8r 2  18               clc
0006E9r 2  69 01            adc #$01
0006EBr 2  20 rr rr         jsr rng_range
0006EEr 2  18               clc
0006EFr 2  69 03            adc #MIN_ROOM_H
0006F1r 2  9D rr rr         sta room_h, x               ; Height
0006F4r 2               
0006F4r 2                   ; Random offset within cell (ensure room fits)
0006F4r 2                   ; Max offset X = CELL_W - room_w
0006F4r 2  A9 0A            lda #CELL_W
0006F6r 2  38               sec
0006F7r 2  FD rr rr         sbc room_w, x
0006FAr 2  F0 03            beq @no_offset_x
0006FCr 2  20 rr rr         jsr rng_range
0006FFr 2               @no_offset_x:
0006FFr 2  18               clc
000700r 2  7D rr rr         adc room_x, x              ; Add offset to cell origin
000703r 2  9D rr rr         sta room_x, x               ; Room X in map coords
000706r 2               
000706r 2                   ; Max offset Y = CELL_H - room_h
000706r 2  A9 08            lda #CELL_H
000708r 2  38               sec
000709r 2  FD rr rr         sbc room_h, x
00070Cr 2  F0 03            beq @no_offset_y
00070Er 2  20 rr rr         jsr rng_range
000711r 2               @no_offset_y:
000711r 2  18               clc
000712r 2  7D rr rr         adc room_y, x              ; Add offset to cell origin
000715r 2  9D rr rr         sta room_y, x               ; Room Y in map coords
000718r 2               
000718r 2                   ; Clamp to full map bounds
000718r 2  BD rr rr         lda room_x, x
00071Br 2  18               clc
00071Cr 2  7D rr rr         adc room_w, x
00071Fr 2  C9 40            cmp #MAP_W
000721r 2  90 0C            bcc @x_ok
000723r 2  A9 40            lda #MAP_W
000725r 2  38               sec
000726r 2  FD rr rr         sbc room_x, x
000729r 2  38               sec
00072Ar 2  E9 01            sbc #$01
00072Cr 2  9D rr rr         sta room_w, x
00072Fr 2               @x_ok:
00072Fr 2  BD rr rr         lda room_y, x
000732r 2  18               clc
000733r 2  7D rr rr         adc room_h, x
000736r 2  C9 30            cmp #MAP_H
000738r 2  90 0C            bcc @y_ok
00073Ar 2  A9 30            lda #MAP_H
00073Cr 2  38               sec
00073Dr 2  FD rr rr         sbc room_y, x
000740r 2  38               sec
000741r 2  E9 01            sbc #$01
000743r 2  9D rr rr         sta room_h, x
000746r 2               @y_ok:
000746r 2               
000746r 2                   ; Carve room into map (floor tiles)
000746r 2  20 rr rr         jsr carve_room
000749r 2               
000749r 2  E6 rr            inc room_count
00074Br 2  60               rts
00074Cr 2               .endproc
00074Cr 2               
00074Cr 2               ; ------------------------------------------------------------
00074Cr 2               ; carve_room
00074Cr 2               ; Write floor tiles for room at index X into dungeon_map.
00074Cr 2               ; Input: X = room index
00074Cr 2               ; ------------------------------------------------------------
00074Cr 2               .proc carve_room
00074Cr 2                   ; Room bounds
00074Cr 2  BD rr rr         lda room_y, x
00074Fr 2  85 rr            sta temp_3                  ; Current row
000751r 2  18               clc
000752r 2  7D rr rr         adc room_h, x
000755r 2  85 rr            sta temp_4                  ; End row (exclusive)
000757r 2               
000757r 2               @row_loop:
000757r 2  A5 rr            lda temp_3
000759r 2  C5 rr            cmp temp_4
00075Br 2  F0 29            beq @done
00075Dr 2               
00075Dr 2                   ; Calculate map offset for start of this row: row * 32 + room_x
00075Dr 2  A5 rr            lda temp_3
00075Fr 2  20 rr rr         jsr calc_row_offset         ; Returns offset in ptr_lo/ptr_hi
000762r 2               
000762r 2  BD rr rr         lda room_x, x
000765r 2  18               clc
000766r 2  65 rr            adc ptr_lo
000768r 2  85 rr            sta ptr_lo
00076Ar 2  90 02            bcc @no_carry
00076Cr 2  E6 rr            inc ptr_hi
00076Er 2               @no_carry:
00076Er 2               
00076Er 2                   ; Write floor tiles for this row
00076Er 2  A0 00            ldy #$00
000770r 2  BD rr rr         lda room_w, x
000773r 2  85 rr            sta temp_1                  ; Width counter
000775r 2               @col_loop:
000775r 2  C4 rr            cpy temp_1
000777r 2  F0 08            beq @next_row
000779r 2  A9 01            lda #TILE_FLOOR
00077Br 2  91 rr            sta (ptr_lo), y
00077Dr 2  C8               iny
00077Er 2  4C rr rr         jmp @col_loop
000781r 2               
000781r 2               @next_row:
000781r 2  E6 rr            inc temp_3
000783r 2  4C rr rr         jmp @row_loop
000786r 2               
000786r 2               @done:
000786r 2  60               rts
000787r 2               .endproc
000787r 2               
000787r 2               ; ------------------------------------------------------------
000787r 2               ; calc_row_offset
000787r 2               ; Calculate byte offset into dungeon_map for a given row.
000787r 2               ; Input: A = row number (0-23)
000787r 2               ; Output: ptr_lo/ptr_hi = address of dungeon_map + row * 32
000787r 2               ; Preserves: X
000787r 2               ; ------------------------------------------------------------
000787r 2               .proc calc_row_offset
000787r 2                   ; row * 64 = row << 6
000787r 2  85 rr            sta ptr_hi
000789r 2  A9 00            lda #$00
00078Br 2  85 rr            sta ptr_lo
00078Dr 2               
00078Dr 2                   ; Multiply by 64: shift left 6 times
00078Dr 2  A5 rr            lda ptr_hi
00078Fr 2  0A               asl a
000790r 2  85 rr            sta ptr_lo                  ; * 2
000792r 2  A9 00            lda #$00
000794r 2  2A               rol a
000795r 2  85 rr            sta ptr_hi
000797r 2               
000797r 2  06 rr            asl ptr_lo                  ; * 4
000799r 2  26 rr            rol ptr_hi
00079Br 2               
00079Br 2  06 rr            asl ptr_lo                  ; * 8
00079Dr 2  26 rr            rol ptr_hi
00079Fr 2               
00079Fr 2  06 rr            asl ptr_lo                  ; * 16
0007A1r 2  26 rr            rol ptr_hi
0007A3r 2               
0007A3r 2  06 rr            asl ptr_lo                  ; * 32
0007A5r 2  26 rr            rol ptr_hi
0007A7r 2               
0007A7r 2  06 rr            asl ptr_lo                  ; * 64
0007A9r 2  26 rr            rol ptr_hi
0007ABr 2               
0007ABr 2                   ; Add base address of dungeon_map
0007ABr 2  A5 rr            lda ptr_lo
0007ADr 2  18               clc
0007AEr 2  69 rr            adc #<dungeon_map
0007B0r 2  85 rr            sta ptr_lo
0007B2r 2  A5 rr            lda ptr_hi
0007B4r 2  69 rr            adc #>dungeon_map
0007B6r 2  85 rr            sta ptr_hi
0007B8r 2  60               rts
0007B9r 2               .endproc
0007B9r 2               
0007B9r 2               ; ------------------------------------------------------------
0007B9r 2               ; connect_rooms
0007B9r 2               ; Connect adjacent rooms with L-shaped corridors.
0007B9r 2               ; For each pair of rooms in adjacent grid cells, dig a corridor.
0007B9r 2               ; ------------------------------------------------------------
0007B9r 2               .proc connect_rooms
0007B9r 2                   ; Simple approach: connect room i to room i+1 for all rooms
0007B9r 2  A2 00            ldx #$00
0007BBr 2               @loop:
0007BBr 2  E8               inx
0007BCr 2  E4 rr            cpx room_count
0007BEr 2  F0 0E            beq @done
0007C0r 2               
0007C0r 2                   ; Connect room X-1 to room X
0007C0r 2  CA               dex
0007C1r 2  86 rr            stx temp_connect_a
0007C3r 2  E8               inx
0007C4r 2  86 rr            stx temp_connect_b
0007C6r 2               
0007C6r 2  20 rr rr         jsr dig_corridor
0007C9r 2               
0007C9r 2  A6 rr            ldx temp_connect_b          ; Restore X (dig_corridor clobbers it)
0007CBr 2  4C rr rr         jmp @loop
0007CEr 2               @done:
0007CEr 2                   ; Also connect first and last for loop connectivity if > 3 rooms
0007CEr 2  A5 rr            lda room_count
0007D0r 2  C9 04            cmp #$04
0007D2r 2  90 0E            bcc @no_loop
0007D4r 2  A9 00            lda #$00
0007D6r 2  85 rr            sta temp_connect_a
0007D8r 2  A5 rr            lda room_count
0007DAr 2  38               sec
0007DBr 2  E9 01            sbc #$01
0007DDr 2  85 rr            sta temp_connect_b
0007DFr 2  20 rr rr         jsr dig_corridor
0007E2r 2               @no_loop:
0007E2r 2  60               rts
0007E3r 2               .endproc
0007E3r 2               
0007E3r 2               ; ------------------------------------------------------------
0007E3r 2               ; dig_corridor
0007E3r 2               ; Dig an L-shaped corridor between two rooms.
0007E3r 2               ; Input: temp_connect_a = room index A, temp_connect_b = room index B
0007E3r 2               ; ------------------------------------------------------------
0007E3r 2               .proc dig_corridor
0007E3r 2                   ; Get center of room A
0007E3r 2  A6 rr            ldx temp_connect_a
0007E5r 2  BD rr rr         lda room_x, x
0007E8r 2  18               clc
0007E9r 2  BD rr rr         lda room_w, x
0007ECr 2  4A               lsr a
0007EDr 2  18               clc
0007EEr 2  7D rr rr         adc room_x, x
0007F1r 2  85 rr            sta temp_cor_x1             ; Center X of room A
0007F3r 2               
0007F3r 2  BD rr rr         lda room_h, x
0007F6r 2  4A               lsr a
0007F7r 2  18               clc
0007F8r 2  7D rr rr         adc room_y, x
0007FBr 2  85 rr            sta temp_cor_y1             ; Center Y of room A
0007FDr 2               
0007FDr 2                   ; Get center of room B
0007FDr 2  A6 rr            ldx temp_connect_b
0007FFr 2  BD rr rr         lda room_w, x
000802r 2  4A               lsr a
000803r 2  18               clc
000804r 2  7D rr rr         adc room_x, x
000807r 2  85 rr            sta temp_cor_x2             ; Center X of room B
000809r 2               
000809r 2  BD rr rr         lda room_h, x
00080Cr 2  4A               lsr a
00080Dr 2  18               clc
00080Er 2  7D rr rr         adc room_y, x
000811r 2  85 rr            sta temp_cor_y2             ; Center Y of room B
000813r 2               
000813r 2                   ; Dig horizontal from x1 to x2 at y1
000813r 2  A5 rr            lda temp_cor_x1
000815r 2  85 rr            sta temp_dig_x
000817r 2  A5 rr            lda temp_cor_y1
000819r 2  85 rr            sta temp_dig_y
00081Br 2               @horiz:
00081Br 2  20 rr rr         jsr dig_tile
00081Er 2  A5 rr            lda temp_dig_x
000820r 2  C5 rr            cmp temp_cor_x2
000822r 2  F0 0C            beq @vert
000824r 2  90 05            bcc @move_right
000826r 2  C6 rr            dec temp_dig_x
000828r 2  4C rr rr         jmp @horiz
00082Br 2               @move_right:
00082Br 2  E6 rr            inc temp_dig_x
00082Dr 2  4C rr rr         jmp @horiz
000830r 2               
000830r 2               @vert:
000830r 2                   ; Dig vertical from y1 to y2 at x2
000830r 2  A5 rr            lda temp_cor_y1
000832r 2  85 rr            sta temp_dig_y
000834r 2               @vert_loop:
000834r 2  20 rr rr         jsr dig_tile
000837r 2  A5 rr            lda temp_dig_y
000839r 2  C5 rr            cmp temp_cor_y2
00083Br 2  F0 0C            beq @done
00083Dr 2  90 05            bcc @move_down
00083Fr 2  C6 rr            dec temp_dig_y
000841r 2  4C rr rr         jmp @vert_loop
000844r 2               @move_down:
000844r 2  E6 rr            inc temp_dig_y
000846r 2  4C rr rr         jmp @vert_loop
000849r 2               
000849r 2               @done:
000849r 2  60               rts
00084Ar 2               .endproc
00084Ar 2               
00084Ar 2               ; ------------------------------------------------------------
00084Ar 2               ; dig_tile
00084Ar 2               ; Set a map tile to corridor if it's currently a wall.
00084Ar 2               ; Input: temp_dig_x, temp_dig_y
00084Ar 2               ; ------------------------------------------------------------
00084Ar 2               .proc dig_tile
00084Ar 2                   ; Bounds check against full map dimensions
00084Ar 2  A5 rr            lda temp_dig_x
00084Cr 2  C9 40            cmp #MAP_W
00084Er 2  B0 17            bcs @skip
000850r 2  A5 rr            lda temp_dig_y
000852r 2  C9 30            cmp #MAP_H
000854r 2  B0 11            bcs @skip
000856r 2               
000856r 2                   ; Calculate offset
000856r 2  A5 rr            lda temp_dig_y
000858r 2  20 rr rr         jsr calc_row_offset
00085Br 2               
00085Br 2  A4 rr            ldy temp_dig_x
00085Dr 2  B1 rr            lda (ptr_lo), y
00085Fr 2  C9 00            cmp #TILE_WALL
000861r 2  D0 04            bne @skip                   ; Don't overwrite floor/door/stairs
000863r 2  A9 02            lda #TILE_CORRIDOR
000865r 2  91 rr            sta (ptr_lo), y
000867r 2               @skip:
000867r 2  60               rts
000868r 2               .endproc
000868r 2               
000868r 2               ; ------------------------------------------------------------
000868r 2               ; place_stairs
000868r 2               ; Place stairs up in room 0, stairs down in last room.
000868r 2               ; ------------------------------------------------------------
000868r 2               .proc place_stairs
000868r 2                   ; Stairs up in room 0 (except on level 0)
000868r 2  A5 rr            lda dungeon_level
00086Ar 2  F0 13            beq @no_stairs_up
00086Cr 2               
00086Cr 2  A2 00            ldx #$00
00086Er 2  BD rr rr         lda room_y, x
000871r 2  18               clc
000872r 2  69 01            adc #$01
000874r 2  20 rr rr         jsr calc_row_offset
000877r 2  AC rr rr         ldy room_x
00087Ar 2  C8               iny                         ; 1 tile into room
00087Br 2  A9 05            lda #TILE_STAIRS_UP
00087Dr 2  91 rr            sta (ptr_lo), y
00087Fr 2               
00087Fr 2               @no_stairs_up:
00087Fr 2                   ; Stairs down in last room (except on last level)
00087Fr 2  A5 rr            lda dungeon_level
000881r 2  C9 0D            cmp #MAX_DUNGEON_LEVEL
000883r 2  B0 17            bcs @no_stairs_down
000885r 2               
000885r 2  A6 rr            ldx room_count
000887r 2  CA               dex                         ; Last room index
000888r 2  BD rr rr         lda room_y, x
00088Br 2  18               clc
00088Cr 2  69 01            adc #$01
00088Er 2  20 rr rr         jsr calc_row_offset
000891r 2  BD rr rr         lda room_x, x
000894r 2  18               clc
000895r 2  69 01            adc #$01
000897r 2  A8               tay
000898r 2  A9 06            lda #TILE_STAIRS_DOWN
00089Ar 2  91 rr            sta (ptr_lo), y
00089Cr 2               
00089Cr 2               @no_stairs_down:
00089Cr 2  60               rts
00089Dr 2               .endproc
00089Dr 2               
00089Dr 2               ; ------------------------------------------------------------
00089Dr 2               ; place_player
00089Dr 2               ; Place player @ in room 0 center.
00089Dr 2               ; ------------------------------------------------------------
00089Dr 2               .proc place_player
00089Dr 2  A2 00            ldx #$00
00089Fr 2  BD rr rr         lda room_w, x
0008A2r 2  4A               lsr a
0008A3r 2  18               clc
0008A4r 2  7D rr rr         adc room_x, x
0008A7r 2  85 rr            sta player_x
0008A9r 2               
0008A9r 2  BD rr rr         lda room_h, x
0008ACr 2  4A               lsr a
0008ADr 2  18               clc
0008AEr 2  7D rr rr         adc room_y, x
0008B1r 2  85 rr            sta player_y
0008B3r 2  60               rts
0008B4r 2               .endproc
0008B4r 2               
0008B4r 2               ; ------------------------------------------------------------
0008B4r 2               ; force_more_rooms
0008B4r 2               ; Ensure minimum room count by filling empty grid cells.
0008B4r 2               ; ------------------------------------------------------------
0008B4r 2               .proc force_more_rooms
0008B4r 2  A9 00            lda #$00
0008B6r 2  85 rr            sta temp_grid_y
0008B8r 2               @row:
0008B8r 2  A5 rr            lda temp_grid_y
0008BAr 2  C9 06            cmp #GRID_ROWS
0008BCr 2  F0 1D            beq @done
0008BEr 2               
0008BEr 2  A9 00            lda #$00
0008C0r 2  85 rr            sta temp_grid_x
0008C2r 2               @col:
0008C2r 2  A5 rr            lda temp_grid_x
0008C4r 2  C9 06            cmp #GRID_COLS
0008C6r 2  F0 0E            beq @next_row
0008C8r 2               
0008C8r 2                   ; Check if we have enough rooms
0008C8r 2  A5 rr            lda room_count
0008CAr 2  C9 0A            cmp #MIN_ROOMS
0008CCr 2  B0 0D            bcs @done
0008CEr 2               
0008CEr 2                   ; Check if this cell already has a room (simplistic: just add more)
0008CEr 2  20 rr rr         jsr generate_room
0008D1r 2               
0008D1r 2               @next_col:
0008D1r 2  E6 rr            inc temp_grid_x
0008D3r 2  4C rr rr         jmp @col
0008D6r 2               @next_row:
0008D6r 2  E6 rr            inc temp_grid_y
0008D8r 2  4C rr rr         jmp @row
0008DBr 2               @done:
0008DBr 2  60               rts
0008DCr 2               .endproc
0008DCr 2               
0008DCr 2               ; ------------------------------------------------------------
0008DCr 2               ; spawn_monsters
0008DCr 2               ; Place initial monsters in rooms (skip room 0 = player start).
0008DCr 2               ; ------------------------------------------------------------
0008DCr 2               .proc spawn_monsters
0008DCr 2  A2 01            ldx #$01                    ; Start from room 1
0008DEr 2               @room_loop:
0008DEr 2  E4 rr            cpx room_count
0008E0r 2  F0 6F            beq @done
0008E2r 2               
0008E2r 2  86 rr            stx temp_room_idx
0008E4r 2               
0008E4r 2                   ; 60% chance of monster per room
0008E4r 2  20 rr rr         jsr rng_next
0008E7r 2  C9 99            cmp #153                    ; ~60% of 256
0008E9r 2  B0 60            bcs @skip
0008EBr 2               
0008EBr 2                   ; Don't exceed max
0008EBr 2  A5 rr            lda monster_count
0008EDr 2  C9 0A            cmp #MAX_MONSTERS
0008EFr 2  F0 60            beq @done
0008F1r 2               
0008F1r 2                   ; Pick monster type based on dungeon level
0008F1r 2  20 rr rr         jsr pick_monster_type       ; Returns type in A
0008F4r 2               
0008F4r 2                   ; Place in room center
0008F4r 2  A6 rr            ldx temp_room_idx
0008F6r 2  86 rr            stx temp_1                  ; Save room index for position calc
0008F8r 2               
0008F8r 2  A6 rr            ldx monster_count
0008FAr 2               
0008FAr 2                   ; Store monster type
0008FAr 2  9D rr rr         sta mon_type, x
0008FDr 2               
0008FDr 2                   ; Position: center of room
0008FDr 2  A4 rr            ldy temp_1                  ; Room index
0008FFr 2  B9 rr rr         lda room_w, y
000902r 2  4A               lsr a
000903r 2  18               clc
000904r 2  79 rr rr         adc room_x, y
000907r 2  9D rr rr         sta mon_x, x
00090Ar 2               
00090Ar 2  B9 rr rr         lda room_h, y
00090Dr 2  4A               lsr a
00090Er 2  18               clc
00090Fr 2  79 rr rr         adc room_y, y
000912r 2  9D rr rr         sta mon_y, x
000915r 2               
000915r 2                   ; HP from type table
000915r 2  86 rr            stx temp_2                  ; Save monster index
000917r 2  BC rr rr         ldy mon_type, x
00091Ar 2  B9 rr rr         lda mon_base_hp, y
00091Dr 2  85 rr            sta temp_3
00091Fr 2                   ; Roll HP dice: base_hp is max of 1d(base_hp)
00091Fr 2  A5 rr            lda temp_3
000921r 2  20 rr rr         jsr rng_range
000924r 2  18               clc
000925r 2  69 01            adc #$01                    ; 1 to base_hp
000927r 2  A6 rr            ldx temp_2
000929r 2  9D rr rr         sta mon_hp, x
00092Cr 2               
00092Cr 2                   ; Set flags based on type
00092Cr 2  BC rr rr         ldy mon_type, x
00092Fr 2  B9 rr rr         lda mon_base_flags, y
000932r 2  9D rr rr         sta mon_flags, x
000935r 2               
000935r 2                   ; State: sleeping unless aggressive
000935r 2  A9 00            lda #$00
000937r 2  9D rr rr         sta mon_state, x
00093Ar 2  BD rr rr         lda mon_flags, x
00093Dr 2  29 02            and #MFLAG_AGGRESSIVE
00093Fr 2  F0 08            beq @not_mean
000941r 2  A9 01            lda #MFLAG_AWAKE
000943r 2  1D rr rr         ora mon_flags, x
000946r 2  9D rr rr         sta mon_flags, x
000949r 2               @not_mean:
000949r 2               
000949r 2  E6 rr            inc monster_count
00094Br 2               
00094Br 2               @skip:
00094Br 2  A6 rr            ldx temp_room_idx
00094Dr 2  E8               inx
00094Er 2  4C rr rr         jmp @room_loop
000951r 2               
000951r 2               @done:
000951r 2  60               rts
000952r 2               .endproc
000952r 2               
000952r 2               ; ------------------------------------------------------------
000952r 2               ; pick_monster_type
000952r 2               ; Return a monster type appropriate for current dungeon level.
000952r 2               ; Output: A = monster type index
000952r 2               ; ------------------------------------------------------------
000952r 2               .proc pick_monster_type
000952r 2                   ; Simple: weight toward harder monsters on deeper levels
000952r 2                   ; Phase 1: 5 monster types (0-4)
000952r 2  A9 05            lda #$05
000954r 2  20 rr rr         jsr rng_range               ; 0-4
000957r 2  60               rts
000958r 2               .endproc
000958r 2               
000958r 2               ; ------------------------------------------------------------
000958r 2               ; spawn_items
000958r 2               ; Place gold and food in rooms.
000958r 2               ; ------------------------------------------------------------
000958r 2               .proc spawn_items
000958r 2  A2 00            ldx #$00                    ; Room index
00095Ar 2               @room_loop:
00095Ar 2  E4 rr            cpx room_count
00095Cr 2  D0 03            bne @not_done_1
00095Er 2  4C rr rr         jmp @done
000961r 2               @not_done_1:
000961r 2  86 rr            stx temp_room_idx
000963r 2               
000963r 2                   ; 50% chance of gold per room
000963r 2  20 rr rr         jsr rng_next
000966r 2  C9 80            cmp #128
000968r 2  B0 51            bcs @no_gold
00096Ar 2               
00096Ar 2  A5 rr            lda floor_item_count
00096Cr 2  C9 10            cmp #MAX_FLOOR_ITEMS
00096Er 2  D0 03            bne @not_full
000970r 2  4C rr rr         jmp @done
000973r 2               @not_full:
000973r 2               
000973r 2  A6 rr            ldx floor_item_count
000975r 2  A9 00            lda #ITEM_GOLD
000977r 2  9D rr rr         sta fi_type, x
00097Ar 2               
00097Ar 2                   ; Random position in room
00097Ar 2  A4 rr            ldy temp_room_idx
00097Cr 2  B9 rr rr         lda room_w, y
00097Fr 2  38               sec
000980r 2  E9 02            sbc #$02                    ; Avoid walls
000982r 2  20 rr rr         jsr rng_range
000985r 2  18               clc
000986r 2  69 01            adc #$01
000988r 2  18               clc
000989r 2  A4 rr            ldy temp_room_idx
00098Br 2  79 rr rr         adc room_x, y
00098Er 2  A6 rr            ldx floor_item_count
000990r 2  9D rr rr         sta fi_x, x
000993r 2               
000993r 2  A4 rr            ldy temp_room_idx
000995r 2  B9 rr rr         lda room_h, y
000998r 2  38               sec
000999r 2  E9 02            sbc #$02
00099Br 2  20 rr rr         jsr rng_range
00099Er 2  18               clc
00099Fr 2  69 01            adc #$01
0009A1r 2  18               clc
0009A2r 2  A4 rr            ldy temp_room_idx
0009A4r 2  79 rr rr         adc room_y, y
0009A7r 2  A6 rr            ldx floor_item_count
0009A9r 2  9D rr rr         sta fi_y, x
0009ACr 2               
0009ACr 2                   ; Random gold amount (5-25)
0009ACr 2  A9 15            lda #21
0009AEr 2  20 rr rr         jsr rng_range
0009B1r 2  18               clc
0009B2r 2  69 05            adc #$05
0009B4r 2  A6 rr            ldx floor_item_count
0009B6r 2  9D rr rr         sta fi_mod, x
0009B9r 2               
0009B9r 2  E6 rr            inc floor_item_count
0009BBr 2               
0009BBr 2               @no_gold:
0009BBr 2                   ; 15% chance of food per room
0009BBr 2  20 rr rr         jsr rng_next
0009BEr 2  C9 26            cmp #38                     ; ~15% of 256
0009C0r 2  B0 48            bcs @no_food
0009C2r 2               
0009C2r 2  A5 rr            lda floor_item_count
0009C4r 2  C9 10            cmp #MAX_FLOOR_ITEMS
0009C6r 2  F0 48            beq @done
0009C8r 2               
0009C8r 2  A6 rr            ldx floor_item_count
0009CAr 2  A9 01            lda #ITEM_FOOD
0009CCr 2  9D rr rr         sta fi_type, x
0009CFr 2               
0009CFr 2  A4 rr            ldy temp_room_idx
0009D1r 2  B9 rr rr         lda room_w, y
0009D4r 2  38               sec
0009D5r 2  E9 02            sbc #$02
0009D7r 2  20 rr rr         jsr rng_range
0009DAr 2  18               clc
0009DBr 2  69 01            adc #$01
0009DDr 2  18               clc
0009DEr 2  A4 rr            ldy temp_room_idx
0009E0r 2  79 rr rr         adc room_x, y
0009E3r 2  A6 rr            ldx floor_item_count
0009E5r 2  9D rr rr         sta fi_x, x
0009E8r 2               
0009E8r 2  A4 rr            ldy temp_room_idx
0009EAr 2  B9 rr rr         lda room_h, y
0009EDr 2  38               sec
0009EEr 2  E9 02            sbc #$02
0009F0r 2  20 rr rr         jsr rng_range
0009F3r 2  18               clc
0009F4r 2  69 01            adc #$01
0009F6r 2  18               clc
0009F7r 2  A4 rr            ldy temp_room_idx
0009F9r 2  79 rr rr         adc room_y, y
0009FCr 2  A6 rr            ldx floor_item_count
0009FEr 2  9D rr rr         sta fi_y, x
000A01r 2               
000A01r 2  A9 00            lda #$00                    ; Food has no modifier
000A03r 2  A6 rr            ldx floor_item_count
000A05r 2  9D rr rr         sta fi_mod, x
000A08r 2               
000A08r 2  E6 rr            inc floor_item_count
000A0Ar 2               
000A0Ar 2               @no_food:
000A0Ar 2  A6 rr            ldx temp_room_idx
000A0Cr 2  E8               inx
000A0Dr 2  4C rr rr         jmp @room_loop
000A10r 2               
000A10r 2               @done:
000A10r 2  60               rts
000A11r 2               .endproc
000A11r 2               
000A11r 2               ; ------------------------------------------------------------
000A11r 2               ; dungeon_generate_debug
000A11r 2               ; Same as dungeon_generate but stops before spawn to isolate hangs
000A11r 2               ; ------------------------------------------------------------
000A11r 2               .proc dungeon_generate_debug
000A11r 2                   ; Clear map to walls
000A11r 2  A9 rr            lda #<dungeon_map
000A13r 2  85 rr            sta ptr_lo
000A15r 2  A9 rr            lda #>dungeon_map
000A17r 2  85 rr            sta ptr_hi
000A19r 2  A0 00            ldy #$00
000A1Br 2  A9 00            lda #TILE_WALL
000A1Dr 2               @clear:
000A1Dr 2  91 rr            sta (ptr_lo), y
000A1Fr 2  C8               iny
000A20r 2  D0 FB            bne @clear
000A22r 2  E6 rr            inc ptr_hi
000A24r 2  A6 rr            ldx ptr_hi
000A26r 2  E0 rr            cpx #>(dungeon_map + MAP_SIZE)
000A28r 2  D0 F3            bne @clear
000A2Ar 2               
000A2Ar 2                   ; Clear fog map
000A2Ar 2  A9 rr            lda #<fog_map
000A2Cr 2  85 rr            sta ptr_lo
000A2Er 2  A9 rr            lda #>fog_map
000A30r 2  85 rr            sta ptr_hi
000A32r 2  A0 00            ldy #$00
000A34r 2  A9 00            lda #FOG_HIDDEN
000A36r 2               @clear_fog:
000A36r 2  91 rr            sta (ptr_lo), y
000A38r 2  C8               iny
000A39r 2  D0 FB            bne @clear_fog
000A3Br 2  E6 rr            inc ptr_hi
000A3Dr 2  A6 rr            ldx ptr_hi
000A3Fr 2  E0 rr            cpx #>(fog_map + MAP_SIZE)
000A41r 2  D0 F3            bne @clear_fog
000A43r 2               
000A43r 2  A9 00            lda #$00
000A45r 2  85 rr            sta room_count
000A47r 2  85 rr            sta monster_count
000A49r 2  85 rr            sta floor_item_count
000A4Br 2               
000A4Br 2                   ; Generate rooms
000A4Br 2  A9 00            lda #$00
000A4Dr 2  85 rr            sta temp_grid_y
000A4Fr 2               @grid_row:
000A4Fr 2  A5 rr            lda temp_grid_y
000A51r 2  C9 06            cmp #GRID_ROWS
000A53r 2  F0 27            beq @rooms_done
000A55r 2  A9 00            lda #$00
000A57r 2  85 rr            sta temp_grid_x
000A59r 2               @grid_col:
000A59r 2  A5 rr            lda temp_grid_x
000A5Br 2  C9 06            cmp #GRID_COLS
000A5Dr 2  F0 18            beq @next_row
000A5Fr 2  20 rr rr         jsr rng_next
000A62r 2  C9 C0            cmp #ROOM_CHANCE
000A64r 2  B0 0C            bcs @skip_room
000A66r 2  A5 rr            lda room_count
000A68r 2  C9 14            cmp #MAX_ROOMS
000A6Ar 2  F0 06            beq @skip_room
000A6Cr 2  20 rr rr         jsr generate_room
000A6Fr 2  4C rr rr         jmp @next_col
000A72r 2               @skip_room:
000A72r 2               @next_col:
000A72r 2  E6 rr            inc temp_grid_x
000A74r 2  4C rr rr         jmp @grid_col
000A77r 2               @next_row:
000A77r 2  E6 rr            inc temp_grid_y
000A79r 2  4C rr rr         jmp @grid_row
000A7Cr 2               @rooms_done:
000A7Cr 2  A5 rr            lda room_count
000A7Er 2  C9 0A            cmp #MIN_ROOMS
000A80r 2  B0 03            bcs @enough_rooms
000A82r 2  20 rr rr         jsr force_more_rooms
000A85r 2               @enough_rooms:
000A85r 2  20 rr rr         jsr connect_rooms
000A88r 2  20 rr rr         jsr place_stairs
000A8Br 2  20 rr rr         jsr place_player
000A8Er 2                   ; STOP HERE - skip spawn_monsters and spawn_items
000A8Er 2  60               rts
000A8Fr 2               .endproc
000A8Fr 2               
000A8Fr 1               .include "map.asm"
000A8Fr 2               ; ============================================================
000A8Fr 2               ; Map Rendering — Viewport-based dungeon map rendering
000A8Fr 2               ; Supports 64x48 map with 32x24 viewport (screen-flip scrolling)
000A8Fr 2               ; ============================================================
000A8Fr 2               .segment "CODE"
000A8Fr 2               
000A8Fr 2               ; ------------------------------------------------------------
000A8Fr 2               ; map_draw_viewport
000A8Fr 2               ; Draw the current viewport (32x24 tiles) from camera_x/camera_y.
000A8Fr 2               ; Must be called with rendering disabled.
000A8Fr 2               ; Integrates fog of war: hidden=darkness, explored=dim, visible=normal.
000A8Fr 2               ; Also draws visible entities (player, monsters, items) on top.
000A8Fr 2               ; ------------------------------------------------------------
000A8Fr 2               .proc map_draw_viewport
000A8Fr 2  AD 02 20         lda $2002                   ; Reset PPU address latch
000A92r 2               
000A92r 2                   ; Set PPU address to row 3 (MAP_TOP_ROW) of nametable 0
000A92r 2                   ; Row 3 = $2000 + 3 * 32 = $2060
000A92r 2  A9 20            lda #$20
000A94r 2  8D 06 20         sta $2006
000A97r 2  A9 60            lda #$60
000A99r 2  8D 06 20         sta $2006
000A9Cr 2               
000A9Cr 2                   ; Draw 24 rows x 32 cols from the viewport
000A9Cr 2  A9 00            lda #$00
000A9Er 2  85 rr            sta temp_3                  ; Screen row counter (0..23)
000AA0r 2               
000AA0r 2               @row_loop:
000AA0r 2  A5 rr            lda temp_3
000AA2r 2  C9 18            cmp #VIEW_H
000AA4r 2  F0 2F            beq @rows_done
000AA6r 2               
000AA6r 2                   ; Compute map row = camera_y + screen_row
000AA6r 2  A5 rr            lda camera_y
000AA8r 2  18               clc
000AA9r 2  65 rr            adc temp_3
000AABr 2  20 rr rr         jsr calc_row_offset         ; ptr_lo/ptr_hi = dungeon_map + map_row * 64
000AAEr 2               
000AAEr 2                   ; Also compute fog row address
000AAEr 2                   ; fog_map base = dungeon_map + MAP_SIZE (they're adjacent in WRAM)
000AAEr 2  A5 rr            lda ptr_lo
000AB0r 2  18               clc
000AB1r 2  69 00            adc #<(fog_map - dungeon_map)
000AB3r 2  85 rr            sta addr_temp_lo
000AB5r 2  A5 rr            lda ptr_hi
000AB7r 2  69 0C            adc #>(fog_map - dungeon_map)
000AB9r 2  85 rr            sta addr_temp_hi
000ABBr 2               
000ABBr 2                   ; Draw 32 tiles for this row
000ABBr 2  A4 rr            ldy camera_x                ; Start column in map
000ABDr 2  A2 00            ldx #$00                    ; Screen column counter
000ABFr 2               @col_loop:
000ABFr 2  E0 20            cpx #VIEW_W
000AC1r 2  F0 0D            beq @next_row
000AC3r 2               
000AC3r 2                   ; DEBUG: bypass fog, render all tiles directly
000AC3r 2  B1 rr            lda (ptr_lo), y
000AC5r 2  20 rr rr         jsr tile_to_chr
000AC8r 2  8D 07 20         sta $2007
000ACBr 2  C8               iny
000ACCr 2  E8               inx
000ACDr 2  4C rr rr         jmp @col_loop
000AD0r 2               
000AD0r 2               ;    ; Check fog state
000AD0r 2               ;    lda (addr_temp_lo), y       ; fog_map tile
000AD0r 2               ;    cmp #FOG_VISIBLE
000AD0r 2               ;    beq @draw_visible
000AD0r 2               ;    cmp #FOG_EXPLORED
000AD0r 2               ;    beq @draw_explored
000AD0r 2               ;
000AD0r 2               ;    ; FOG_HIDDEN: draw darkness
000AD0r 2               ;    lda #CHR_DARKNESS
000AD0r 2               ;    sta $2007
000AD0r 2               ;    iny
000AD0r 2               ;    inx
000AD0r 2               ;    jmp @col_loop
000AD0r 2               ;
000AD0r 2               ;@draw_explored:
000AD0r 2               ;    ; Show the tile but could use dim palette later
000AD0r 2               ;    ; For now, show the actual tile structure (walls/floor visible)
000AD0r 2               ;    lda (ptr_lo), y
000AD0r 2               ;    jsr tile_to_chr
000AD0r 2               ;    sta $2007
000AD0r 2               ;    iny
000AD0r 2               ;    inx
000AD0r 2               ;    jmp @col_loop
000AD0r 2               ;
000AD0r 2               ;@draw_visible:
000AD0r 2               ;    ; Check for entities at this position first
000AD0r 2               ;    ; map coords: x = y_reg (column), y = camera_y + temp_3 (row)
000AD0r 2               ;    lda (ptr_lo), y
000AD0r 2               ;    jsr tile_to_chr
000AD0r 2               ;    sta $2007
000AD0r 2               ;    iny
000AD0r 2               ;    inx
000AD0r 2               ;    jmp @col_loop
000AD0r 2               
000AD0r 2               @next_row:
000AD0r 2  E6 rr            inc temp_3
000AD2r 2  4C rr rr         jmp @row_loop
000AD5r 2               
000AD5r 2               @rows_done:
000AD5r 2                   ; --- Draw visible entities on top ---
000AD5r 2  20 rr rr         jsr map_draw_player_direct
000AD8r 2  20 rr rr         jsr map_draw_monsters_direct
000ADBr 2  20 rr rr         jsr map_draw_items_direct
000ADEr 2               
000ADEr 2                   ; --- Draw divider lines ---
000ADEr 2                   ; Row 2 divider
000ADEr 2  AD 02 20         lda $2002
000AE1r 2  A9 20            lda #$20
000AE3r 2  8D 06 20         sta $2006
000AE6r 2  A9 40            lda #$40                    ; Row 2 = $2000 + 2*32 = $2040
000AE8r 2  8D 06 20         sta $2006
000AEBr 2  A2 20            ldx #$20                    ; 32 tiles
000AEDr 2  A9 0A            lda #CHR_DIVIDER
000AEFr 2               @div1:
000AEFr 2  8D 07 20         sta $2007
000AF2r 2  CA               dex
000AF3r 2  D0 FA            bne @div1
000AF5r 2               
000AF5r 2                   ; Row 27 divider
000AF5r 2  AD 02 20         lda $2002
000AF8r 2  A9 23            lda #$23
000AFAr 2  8D 06 20         sta $2006
000AFDr 2  A9 60            lda #$60                    ; Row 27 = $2000 + 27*32 = $2360
000AFFr 2  8D 06 20         sta $2006
000B02r 2  A2 20            ldx #$20
000B04r 2  A9 0A            lda #CHR_DIVIDER
000B06r 2               @div2:
000B06r 2  8D 07 20         sta $2007
000B09r 2  CA               dex
000B0Ar 2  D0 FA            bne @div2
000B0Cr 2               
000B0Cr 2  60               rts
000B0Dr 2               .endproc
000B0Dr 2               
000B0Dr 2               ; ------------------------------------------------------------
000B0Dr 2               ; tile_to_chr
000B0Dr 2               ; Convert map tile type to CHR tile index for rendering.
000B0Dr 2               ; Input: A = tile type (TILE_*)
000B0Dr 2               ; Output: A = CHR tile index
000B0Dr 2               ; ------------------------------------------------------------
000B0Dr 2               .proc tile_to_chr
000B0Dr 2  C9 00            cmp #TILE_WALL
000B0Fr 2  F0 1B            beq @wall
000B11r 2  C9 01            cmp #TILE_FLOOR
000B13r 2  F0 1A            beq @floor
000B15r 2  C9 02            cmp #TILE_CORRIDOR
000B17r 2  F0 19            beq @corridor
000B19r 2  C9 03            cmp #TILE_DOOR_CLOSED
000B1Br 2  F0 18            beq @door_closed
000B1Dr 2  C9 04            cmp #TILE_DOOR_OPEN
000B1Fr 2  F0 17            beq @door_open
000B21r 2  C9 05            cmp #TILE_STAIRS_UP
000B23r 2  F0 16            beq @stairs_up
000B25r 2  C9 06            cmp #TILE_STAIRS_DOWN
000B27r 2  F0 15            beq @stairs_down
000B29r 2                   ; Default: wall
000B29r 2  A9 01            lda #CHR_WALL
000B2Br 2  60               rts
000B2Cr 2               @wall:
000B2Cr 2  A9 01            lda #CHR_WALL
000B2Er 2  60               rts
000B2Fr 2               @floor:
000B2Fr 2  A9 03            lda #CHR_FLOOR
000B31r 2  60               rts
000B32r 2               @corridor:
000B32r 2  A9 04            lda #CHR_CORRIDOR
000B34r 2  60               rts
000B35r 2               @door_closed:
000B35r 2  A9 05            lda #CHR_DOOR_CLOSED
000B37r 2  60               rts
000B38r 2               @door_open:
000B38r 2  A9 06            lda #CHR_DOOR_OPEN
000B3Ar 2  60               rts
000B3Br 2               @stairs_up:
000B3Br 2  A9 07            lda #CHR_STAIRS_UP
000B3Dr 2  60               rts
000B3Er 2               @stairs_down:
000B3Er 2  A9 08            lda #CHR_STAIRS_DOWN
000B40r 2  60               rts
000B41r 2               .endproc
000B41r 2               
000B41r 2               ; ------------------------------------------------------------
000B41r 2               ; map_draw_player_direct
000B41r 2               ; Write player @ tile directly to PPU (rendering must be off).
000B41r 2               ; Uses camera offset to compute screen position.
000B41r 2               ; Only draws if player is within current viewport.
000B41r 2               ; ------------------------------------------------------------
000B41r 2               .proc map_draw_player_direct
000B41r 2                   ; Check if player is in viewport
000B41r 2  A5 rr            lda player_x
000B43r 2  38               sec
000B44r 2  E5 rr            sbc camera_x
000B46r 2  90 40            bcc @skip                   ; Off-screen left
000B48r 2  C9 20            cmp #VIEW_W
000B4Ar 2  B0 3C            bcs @skip                   ; Off-screen right
000B4Cr 2  85 rr            sta temp_4                  ; Screen X
000B4Er 2               
000B4Er 2  A5 rr            lda player_y
000B50r 2  38               sec
000B51r 2  E5 rr            sbc camera_y
000B53r 2  90 33            bcc @skip
000B55r 2  C9 18            cmp #VIEW_H
000B57r 2  B0 2F            bcs @skip
000B59r 2               
000B59r 2                   ; Screen Y + MAP_TOP_ROW
000B59r 2  18               clc
000B5Ar 2  69 03            adc #MAP_TOP_ROW
000B5Cr 2  85 rr            sta temp_1
000B5Er 2  4A               lsr a
000B5Fr 2  4A               lsr a
000B60r 2  4A               lsr a
000B61r 2  18               clc
000B62r 2  69 20            adc #$20
000B64r 2  85 rr            sta temp_3                  ; PPU high byte
000B66r 2               
000B66r 2  A5 rr            lda temp_1
000B68r 2  0A               asl a
000B69r 2  0A               asl a
000B6Ar 2  0A               asl a
000B6Br 2  0A               asl a
000B6Cr 2  0A               asl a
000B6Dr 2  18               clc
000B6Er 2  65 rr            adc temp_4
000B70r 2  85 rr            sta temp_4                  ; PPU low byte
000B72r 2  90 02            bcc @no_carry
000B74r 2  E6 rr            inc temp_3
000B76r 2               @no_carry:
000B76r 2               
000B76r 2  AD 02 20         lda $2002
000B79r 2  A5 rr            lda temp_3
000B7Br 2  8D 06 20         sta $2006
000B7Er 2  A5 rr            lda temp_4
000B80r 2  8D 06 20         sta $2006
000B83r 2  A9 15            lda #CHR_PLAYER
000B85r 2  8D 07 20         sta $2007
000B88r 2               @skip:
000B88r 2  60               rts
000B89r 2               .endproc
000B89r 2               
000B89r 2               ; ------------------------------------------------------------
000B89r 2               ; map_draw_monsters_direct
000B89r 2               ; Write monster tiles directly to PPU.
000B89r 2               ; Only draws monsters within current viewport and on visible tiles.
000B89r 2               ; ------------------------------------------------------------
000B89r 2               .proc map_draw_monsters_direct
000B89r 2  A2 00            ldx #$00
000B8Br 2               @loop:
000B8Br 2  E4 rr            cpx monster_count
000B8Dr 2  F0 61            beq @done
000B8Fr 2               
000B8Fr 2                   ; Check if monster is in viewport
000B8Fr 2  BD rr rr         lda mon_x, x
000B92r 2  38               sec
000B93r 2  E5 rr            sbc camera_x
000B95r 2  90 50            bcc @next                   ; Off-screen
000B97r 2  C9 20            cmp #VIEW_W
000B99r 2  B0 4C            bcs @next
000B9Br 2  85 rr            sta temp_4                  ; Screen X
000B9Dr 2               
000B9Dr 2  BD rr rr         lda mon_y, x
000BA0r 2  38               sec
000BA1r 2  E5 rr            sbc camera_y
000BA3r 2  90 42            bcc @next
000BA5r 2  C9 18            cmp #VIEW_H
000BA7r 2  B0 3E            bcs @next
000BA9r 2               
000BA9r 2                   ; DEBUG: skip fog check for monsters
000BA9r 2  48               pha                         ; Save screen Y (for stack balance)
000BAAr 2  68               pla                         ; Restore screen Y
000BABr 2               
000BABr 2                   ; Get monster tile
000BABr 2  BD rr rr         lda mon_type, x
000BAEr 2  A8               tay
000BAFr 2  B9 rr rr         lda mon_chr_tile, y
000BB2r 2  48               pha                         ; Save CHR tile
000BB3r 2               
000BB3r 2                   ; Calculate PPU address
000BB3r 2  BD rr rr         lda mon_y, x
000BB6r 2  38               sec
000BB7r 2  E5 rr            sbc camera_y
000BB9r 2  18               clc
000BBAr 2  69 03            adc #MAP_TOP_ROW
000BBCr 2  85 rr            sta temp_1
000BBEr 2  4A               lsr a
000BBFr 2  4A               lsr a
000BC0r 2  4A               lsr a
000BC1r 2  18               clc
000BC2r 2  69 20            adc #$20
000BC4r 2  85 rr            sta temp_3
000BC6r 2               
000BC6r 2  A5 rr            lda temp_1
000BC8r 2  0A               asl a
000BC9r 2  0A               asl a
000BCAr 2  0A               asl a
000BCBr 2  0A               asl a
000BCCr 2  0A               asl a
000BCDr 2  18               clc
000BCEr 2  65 rr            adc temp_4
000BD0r 2  85 rr            sta temp_4
000BD2r 2  90 02            bcc @no_carry
000BD4r 2  E6 rr            inc temp_3
000BD6r 2               @no_carry:
000BD6r 2               
000BD6r 2  AD 02 20         lda $2002
000BD9r 2  A5 rr            lda temp_3
000BDBr 2  8D 06 20         sta $2006
000BDEr 2  A5 rr            lda temp_4
000BE0r 2  8D 06 20         sta $2006
000BE3r 2  68               pla
000BE4r 2  8D 07 20         sta $2007
000BE7r 2               
000BE7r 2               @next:
000BE7r 2  E8               inx
000BE8r 2  4C rr rr         jmp @loop
000BEBr 2               @next_pop:
000BEBr 2  68               pla                         ; Balance stack from saved screen Y
000BECr 2  E8               inx
000BEDr 2  4C rr rr         jmp @loop
000BF0r 2               @done:
000BF0r 2  60               rts
000BF1r 2               .endproc
000BF1r 2               
000BF1r 2               ; ------------------------------------------------------------
000BF1r 2               ; map_draw_items_direct
000BF1r 2               ; Write floor item tiles directly to PPU.
000BF1r 2               ; Only draws items within viewport and on visible tiles.
000BF1r 2               ; ------------------------------------------------------------
000BF1r 2               .proc map_draw_items_direct
000BF1r 2  A2 00            ldx #$00
000BF3r 2               @loop:
000BF3r 2  E4 rr            cpx floor_item_count
000BF5r 2  F0 61            beq @done
000BF7r 2               
000BF7r 2                   ; Check viewport bounds
000BF7r 2  BD rr rr         lda fi_x, x
000BFAr 2  38               sec
000BFBr 2  E5 rr            sbc camera_x
000BFDr 2  90 50            bcc @next
000BFFr 2  C9 20            cmp #VIEW_W
000C01r 2  B0 4C            bcs @next
000C03r 2  85 rr            sta temp_4                  ; Screen X
000C05r 2               
000C05r 2  BD rr rr         lda fi_y, x
000C08r 2  38               sec
000C09r 2  E5 rr            sbc camera_y
000C0Br 2  90 42            bcc @next
000C0Dr 2  C9 18            cmp #VIEW_H
000C0Fr 2  B0 3E            bcs @next
000C11r 2               
000C11r 2                   ; DEBUG: skip fog check for items
000C11r 2  48               pha                         ; Save screen Y (for stack balance)
000C12r 2  68               pla                         ; Restore screen Y
000C13r 2               
000C13r 2  BD rr rr         lda fi_type, x
000C16r 2  A8               tay
000C17r 2  B9 rr rr         lda item_chr_tile, y
000C1Ar 2  48               pha
000C1Br 2               
000C1Br 2                   ; PPU address
000C1Br 2  BD rr rr         lda fi_y, x
000C1Er 2  38               sec
000C1Fr 2  E5 rr            sbc camera_y
000C21r 2  18               clc
000C22r 2  69 03            adc #MAP_TOP_ROW
000C24r 2  85 rr            sta temp_1
000C26r 2  4A               lsr a
000C27r 2  4A               lsr a
000C28r 2  4A               lsr a
000C29r 2  18               clc
000C2Ar 2  69 20            adc #$20
000C2Cr 2  85 rr            sta temp_3
000C2Er 2               
000C2Er 2  A5 rr            lda temp_1
000C30r 2  0A               asl a
000C31r 2  0A               asl a
000C32r 2  0A               asl a
000C33r 2  0A               asl a
000C34r 2  0A               asl a
000C35r 2  18               clc
000C36r 2  65 rr            adc temp_4
000C38r 2  85 rr            sta temp_4
000C3Ar 2  90 02            bcc @no_carry
000C3Cr 2  E6 rr            inc temp_3
000C3Er 2               @no_carry:
000C3Er 2               
000C3Er 2  AD 02 20         lda $2002
000C41r 2  A5 rr            lda temp_3
000C43r 2  8D 06 20         sta $2006
000C46r 2  A5 rr            lda temp_4
000C48r 2  8D 06 20         sta $2006
000C4Br 2  68               pla
000C4Cr 2  8D 07 20         sta $2007
000C4Fr 2               
000C4Fr 2               @next:
000C4Fr 2  E8               inx
000C50r 2  4C rr rr         jmp @loop
000C53r 2               @next_pop:
000C53r 2  68               pla
000C54r 2  E8               inx
000C55r 2  4C rr rr         jmp @loop
000C58r 2               @done:
000C58r 2  60               rts
000C59r 2               .endproc
000C59r 2               
000C59r 2               ; ------------------------------------------------------------
000C59r 2               ; map_update_entity
000C59r 2               ; Queue a VRAM buffer update for a single tile on the map.
000C59r 2               ; Applies camera offset; skips if tile is off-screen.
000C59r 2               ; Input: A = CHR tile to draw
000C59r 2               ;        temp_1 = map X (0-63)
000C59r 2               ;        temp_2 = map Y (0-47)
000C59r 2               ; ------------------------------------------------------------
000C59r 2               .proc map_update_entity
000C59r 2  48               pha                         ; Save tile
000C5Ar 2               
000C5Ar 2                   ; Convert map coords to screen coords
000C5Ar 2  A5 rr            lda temp_1
000C5Cr 2  38               sec
000C5Dr 2  E5 rr            sbc camera_x
000C5Fr 2  90 1B            bcc @skip                   ; Off-screen
000C61r 2  C9 20            cmp #VIEW_W
000C63r 2  B0 17            bcs @skip
000C65r 2  85 rr            sta temp_1                  ; Screen X
000C67r 2               
000C67r 2  A5 rr            lda temp_2
000C69r 2  38               sec
000C6Ar 2  E5 rr            sbc camera_y
000C6Cr 2  90 0E            bcc @skip
000C6Er 2  C9 18            cmp #VIEW_H
000C70r 2  B0 0A            bcs @skip
000C72r 2  18               clc
000C73r 2  69 03            adc #MAP_TOP_ROW            ; Screen row = viewport row + 3
000C75r 2  85 rr            sta temp_2
000C77r 2               
000C77r 2  68               pla
000C78r 2  20 rr rr         jsr vram_write_tile
000C7Br 2  60               rts
000C7Cr 2               
000C7Cr 2               @skip:
000C7Cr 2  68               pla                         ; Balance stack
000C7Dr 2  60               rts
000C7Er 2               .endproc
000C7Er 2               
000C7Er 2               ; ------------------------------------------------------------
000C7Er 2               ; map_restore_tile
000C7Er 2               ; Restore the map tile at (X, Y) from the dungeon_map buffer.
000C7Er 2               ; Uses camera offset; skips if off-screen.
000C7Er 2               ; Input: temp_1 = map X, temp_2 = map Y
000C7Er 2               ; ------------------------------------------------------------
000C7Er 2               .proc map_restore_tile
000C7Er 2                   ; First check if there's a floor item at this position
000C7Er 2  20 rr rr         jsr check_floor_item_chr
000C81r 2  B0 0C            bcs @write                  ; Carry set = found item, A = item CHR tile
000C83r 2               
000C83r 2                   ; No item — read the base tile from dungeon_map and convert
000C83r 2  A5 rr            lda temp_2
000C85r 2  20 rr rr         jsr calc_row_offset
000C88r 2  A4 rr            ldy temp_1
000C8Ar 2  B1 rr            lda (ptr_lo), y
000C8Cr 2  20 rr rr         jsr tile_to_chr
000C8Fr 2               
000C8Fr 2               @write:
000C8Fr 2                   ; Convert to screen coords and write via VRAM buffer
000C8Fr 2  48               pha
000C90r 2  A5 rr            lda temp_1
000C92r 2  38               sec
000C93r 2  E5 rr            sbc camera_x
000C95r 2  90 1B            bcc @skip
000C97r 2  C9 20            cmp #VIEW_W
000C99r 2  B0 17            bcs @skip
000C9Br 2  85 rr            sta temp_1
000C9Dr 2               
000C9Dr 2  A5 rr            lda temp_2
000C9Fr 2  38               sec
000CA0r 2  E5 rr            sbc camera_y
000CA2r 2  90 0E            bcc @skip
000CA4r 2  C9 18            cmp #VIEW_H
000CA6r 2  B0 0A            bcs @skip
000CA8r 2  18               clc
000CA9r 2  69 03            adc #MAP_TOP_ROW
000CABr 2  85 rr            sta temp_2
000CADr 2               
000CADr 2  68               pla
000CAEr 2  20 rr rr         jsr vram_write_tile
000CB1r 2  60               rts
000CB2r 2               
000CB2r 2               @skip:
000CB2r 2  68               pla
000CB3r 2  60               rts
000CB4r 2               .endproc
000CB4r 2               
000CB4r 2               ; ------------------------------------------------------------
000CB4r 2               ; check_floor_item_chr
000CB4r 2               ; Check if there's a floor item at (temp_1, temp_2).
000CB4r 2               ; Output: A = item CHR tile, carry set if found
000CB4r 2               ;         carry clear if no item
000CB4r 2               ; ------------------------------------------------------------
000CB4r 2               .proc check_floor_item_chr
000CB4r 2  A2 00            ldx #$00
000CB6r 2               @loop:
000CB6r 2  E4 rr            cpx floor_item_count
000CB8r 2  F0 1B            beq @not_found
000CBAr 2               
000CBAr 2  BD rr rr         lda fi_x, x
000CBDr 2  C5 rr            cmp temp_1
000CBFr 2  D0 10            bne @next
000CC1r 2  BD rr rr         lda fi_y, x
000CC4r 2  C5 rr            cmp temp_2
000CC6r 2  D0 09            bne @next
000CC8r 2               
000CC8r 2                   ; Found item
000CC8r 2  BD rr rr         lda fi_type, x
000CCBr 2  A8               tay
000CCCr 2  B9 rr rr         lda item_chr_tile, y
000CCFr 2  38               sec                         ; Set carry = found
000CD0r 2  60               rts
000CD1r 2               
000CD1r 2               @next:
000CD1r 2  E8               inx
000CD2r 2  4C rr rr         jmp @loop
000CD5r 2               
000CD5r 2               @not_found:
000CD5r 2  18               clc                         ; Clear carry = not found
000CD6r 2  60               rts
000CD7r 2               .endproc
000CD7r 2               
000CD7r 2               ; ------------------------------------------------------------
000CD7r 2               ; fog_calc_offset
000CD7r 2               ; Calculate byte offset into fog_map for a given row.
000CD7r 2               ; Input: A = row number (0-47)
000CD7r 2               ; Output: ptr_lo/ptr_hi = address of fog_map + row * 64
000CD7r 2               ; Preserves: X
000CD7r 2               ; ------------------------------------------------------------
000CD7r 2               .proc fog_calc_offset
000CD7r 2                   ; row * 64 = row << 6  (same math as calc_row_offset)
000CD7r 2  85 rr            sta ptr_hi
000CD9r 2  A9 00            lda #$00
000CDBr 2  85 rr            sta ptr_lo
000CDDr 2               
000CDDr 2  A5 rr            lda ptr_hi
000CDFr 2  0A               asl a
000CE0r 2  85 rr            sta ptr_lo                  ; * 2
000CE2r 2  A9 00            lda #$00
000CE4r 2  2A               rol a
000CE5r 2  85 rr            sta ptr_hi
000CE7r 2               
000CE7r 2  06 rr            asl ptr_lo                  ; * 4
000CE9r 2  26 rr            rol ptr_hi
000CEBr 2  06 rr            asl ptr_lo                  ; * 8
000CEDr 2  26 rr            rol ptr_hi
000CEFr 2  06 rr            asl ptr_lo                  ; * 16
000CF1r 2  26 rr            rol ptr_hi
000CF3r 2  06 rr            asl ptr_lo                  ; * 32
000CF5r 2  26 rr            rol ptr_hi
000CF7r 2  06 rr            asl ptr_lo                  ; * 64
000CF9r 2  26 rr            rol ptr_hi
000CFBr 2               
000CFBr 2                   ; Add base address of fog_map
000CFBr 2  A5 rr            lda ptr_lo
000CFDr 2  18               clc
000CFEr 2  69 rr            adc #<fog_map
000D00r 2  85 rr            sta ptr_lo
000D02r 2  A5 rr            lda ptr_hi
000D04r 2  69 rr            adc #>fog_map
000D06r 2  85 rr            sta ptr_hi
000D08r 2  60               rts
000D09r 2               .endproc
000D09r 2               
000D09r 2               ; ------------------------------------------------------------
000D09r 2               ; fog_reveal_room
000D09r 2               ; Set all tiles in a room to FOG_VISIBLE.
000D09r 2               ; Input: X = room index
000D09r 2               ; Preserves: nothing
000D09r 2               ; ------------------------------------------------------------
000D09r 2               .proc fog_reveal_room
000D09r 2  BD rr rr         lda room_y, x
000D0Cr 2  85 rr            sta temp_3                  ; Current row
000D0Er 2  18               clc
000D0Fr 2  7D rr rr         adc room_h, x
000D12r 2  85 rr            sta temp_4                  ; End row
000D14r 2               
000D14r 2  86 rr            stx temp_room_idx           ; Save room index
000D16r 2               
000D16r 2               @row_loop:
000D16r 2  A5 rr            lda temp_3
000D18r 2  C5 rr            cmp temp_4
000D1Ar 2  F0 2B            beq @done
000D1Cr 2               
000D1Cr 2  A5 rr            lda temp_3
000D1Er 2  20 rr rr         jsr fog_calc_offset
000D21r 2               
000D21r 2                   ; Add room_x offset to ptr
000D21r 2  A6 rr            ldx temp_room_idx
000D23r 2  BD rr rr         lda room_x, x
000D26r 2  18               clc
000D27r 2  65 rr            adc ptr_lo
000D29r 2  85 rr            sta ptr_lo
000D2Br 2  90 02            bcc @no_carry
000D2Dr 2  E6 rr            inc ptr_hi
000D2Fr 2               @no_carry:
000D2Fr 2               
000D2Fr 2                   ; Write FOG_VISIBLE for room width
000D2Fr 2  A0 00            ldy #$00
000D31r 2  BD rr rr         lda room_w, x
000D34r 2  85 rr            sta temp_1
000D36r 2               @col_loop:
000D36r 2  C4 rr            cpy temp_1
000D38r 2  F0 08            beq @next_row
000D3Ar 2  A9 02            lda #FOG_VISIBLE
000D3Cr 2  91 rr            sta (ptr_lo), y
000D3Er 2  C8               iny
000D3Fr 2  4C rr rr         jmp @col_loop
000D42r 2               
000D42r 2               @next_row:
000D42r 2  E6 rr            inc temp_3
000D44r 2  4C rr rr         jmp @row_loop
000D47r 2               
000D47r 2               @done:
000D47r 2                   ; Also reveal 1 tile border around the room for walls
000D47r 2                   ; (so room edges are visible)
000D47r 2  A6 rr            ldx temp_room_idx
000D49r 2  20 rr rr         jsr fog_reveal_room_border
000D4Cr 2  60               rts
000D4Dr 2               .endproc
000D4Dr 2               
000D4Dr 2               ; ------------------------------------------------------------
000D4Dr 2               ; fog_reveal_room_border
000D4Dr 2               ; Reveal the 1-tile border around a room so walls are visible.
000D4Dr 2               ; Input: X = room index
000D4Dr 2               ; ------------------------------------------------------------
000D4Dr 2               .proc fog_reveal_room_border
000D4Dr 2                   ; Top row (room_y - 1)
000D4Dr 2  BD rr rr         lda room_y, x
000D50r 2  F0 37            beq @skip_top               ; Already at map edge
000D52r 2  38               sec
000D53r 2  E9 01            sbc #$01
000D55r 2  85 rr            sta temp_3
000D57r 2               
000D57r 2  A5 rr            lda temp_3
000D59r 2  20 rr rr         jsr fog_calc_offset
000D5Cr 2  BD rr rr         lda room_x, x
000D5Fr 2  F0 03            beq @no_left_top
000D61r 2  38               sec
000D62r 2  E9 01            sbc #$01
000D64r 2               @no_left_top:
000D64r 2  18               clc
000D65r 2  65 rr            adc ptr_lo
000D67r 2  85 rr            sta ptr_lo
000D69r 2  90 02            bcc @nc1
000D6Br 2  E6 rr            inc ptr_hi
000D6Dr 2               @nc1:
000D6Dr 2  BD rr rr         lda room_w, x
000D70r 2  18               clc
000D71r 2  69 02            adc #$02                    ; Width + 2 for border
000D73r 2  85 rr            sta temp_1
000D75r 2  A0 00            ldy #$00
000D77r 2               @top_loop:
000D77r 2  C4 rr            cpy temp_1
000D79r 2  F0 0E            beq @skip_top
000D7Br 2  B1 rr            lda (ptr_lo), y
000D7Dr 2  C9 02            cmp #FOG_VISIBLE
000D7Fr 2  F0 04            beq @top_next
000D81r 2  A9 02            lda #FOG_VISIBLE
000D83r 2  91 rr            sta (ptr_lo), y
000D85r 2               @top_next:
000D85r 2  C8               iny
000D86r 2  4C rr rr         jmp @top_loop
000D89r 2               @skip_top:
000D89r 2               
000D89r 2                   ; Bottom row (room_y + room_h)
000D89r 2  BD rr rr         lda room_y, x
000D8Cr 2  18               clc
000D8Dr 2  7D rr rr         adc room_h, x
000D90r 2  C9 30            cmp #MAP_H
000D92r 2  B0 34            bcs @skip_bottom
000D94r 2  85 rr            sta temp_3
000D96r 2               
000D96r 2  A5 rr            lda temp_3
000D98r 2  20 rr rr         jsr fog_calc_offset
000D9Br 2  BD rr rr         lda room_x, x
000D9Er 2  F0 03            beq @no_left_bot
000DA0r 2  38               sec
000DA1r 2  E9 01            sbc #$01
000DA3r 2               @no_left_bot:
000DA3r 2  18               clc
000DA4r 2  65 rr            adc ptr_lo
000DA6r 2  85 rr            sta ptr_lo
000DA8r 2  90 02            bcc @nc2
000DAAr 2  E6 rr            inc ptr_hi
000DACr 2               @nc2:
000DACr 2  BD rr rr         lda room_w, x
000DAFr 2  18               clc
000DB0r 2  69 02            adc #$02
000DB2r 2  85 rr            sta temp_1
000DB4r 2  A0 00            ldy #$00
000DB6r 2               @bot_loop:
000DB6r 2  C4 rr            cpy temp_1
000DB8r 2  F0 0E            beq @skip_bottom
000DBAr 2  B1 rr            lda (ptr_lo), y
000DBCr 2  C9 02            cmp #FOG_VISIBLE
000DBEr 2  F0 04            beq @bot_next
000DC0r 2  A9 02            lda #FOG_VISIBLE
000DC2r 2  91 rr            sta (ptr_lo), y
000DC4r 2               @bot_next:
000DC4r 2  C8               iny
000DC5r 2  4C rr rr         jmp @bot_loop
000DC8r 2               @skip_bottom:
000DC8r 2               
000DC8r 2                   ; Left and right columns
000DC8r 2  BD rr rr         lda room_y, x
000DCBr 2  F0 03            beq @no_dec_y
000DCDr 2  38               sec
000DCEr 2  E9 01            sbc #$01
000DD0r 2               @no_dec_y:
000DD0r 2  85 rr            sta temp_3                  ; Start row
000DD2r 2  BD rr rr         lda room_y, x
000DD5r 2  18               clc
000DD6r 2  7D rr rr         adc room_h, x
000DD9r 2  85 rr            sta temp_4                  ; End row (exclusive, but we want inclusive + border)
000DDBr 2               
000DDBr 2               @side_loop:
000DDBr 2  A5 rr            lda temp_3
000DDDr 2  C5 rr            cmp temp_4
000DDFr 2  F0 25            beq @sides_done
000DE1r 2               
000DE1r 2  A5 rr            lda temp_3
000DE3r 2  20 rr rr         jsr fog_calc_offset
000DE6r 2               
000DE6r 2                   ; Left column (room_x - 1)
000DE6r 2  BD rr rr         lda room_x, x
000DE9r 2  F0 06            beq @no_left_side
000DEBr 2  A8               tay
000DECr 2  88               dey
000DEDr 2  A9 02            lda #FOG_VISIBLE
000DEFr 2  91 rr            sta (ptr_lo), y
000DF1r 2               @no_left_side:
000DF1r 2               
000DF1r 2                   ; Right column (room_x + room_w)
000DF1r 2  BD rr rr         lda room_x, x
000DF4r 2  18               clc
000DF5r 2  7D rr rr         adc room_w, x
000DF8r 2  C9 40            cmp #MAP_W
000DFAr 2  B0 05            bcs @no_right_side
000DFCr 2  A8               tay
000DFDr 2  A9 02            lda #FOG_VISIBLE
000DFFr 2  91 rr            sta (ptr_lo), y
000E01r 2               @no_right_side:
000E01r 2               
000E01r 2  E6 rr            inc temp_3
000E03r 2  4C rr rr         jmp @side_loop
000E06r 2               
000E06r 2               @sides_done:
000E06r 2  60               rts
000E07r 2               .endproc
000E07r 2               
000E07r 2               ; ------------------------------------------------------------
000E07r 2               ; fog_downgrade_room
000E07r 2               ; Downgrade all FOG_VISIBLE tiles in a room to FOG_EXPLORED.
000E07r 2               ; Input: X = room index
000E07r 2               ; ------------------------------------------------------------
000E07r 2               .proc fog_downgrade_room
000E07r 2  BD rr rr         lda room_y, x
000E0Ar 2  F0 03            beq @start_at_zero
000E0Cr 2  38               sec
000E0Dr 2  E9 01            sbc #$01                    ; Include border
000E0Fr 2               @start_at_zero:
000E0Fr 2  85 rr            sta temp_3
000E11r 2  BD rr rr         lda room_y, x
000E14r 2  18               clc
000E15r 2  7D rr rr         adc room_h, x
000E18r 2  18               clc
000E19r 2  69 01            adc #$01                    ; Include border
000E1Br 2  C9 30            cmp #MAP_H
000E1Dr 2  90 02            bcc @end_ok
000E1Fr 2  A9 30            lda #MAP_H
000E21r 2               @end_ok:
000E21r 2  85 rr            sta temp_4
000E23r 2               
000E23r 2  86 rr            stx temp_room_idx
000E25r 2               
000E25r 2               @row_loop:
000E25r 2  A5 rr            lda temp_3
000E27r 2  C5 rr            cmp temp_4
000E29r 2  F0 39            beq @done
000E2Br 2               
000E2Br 2  A5 rr            lda temp_3
000E2Dr 2  20 rr rr         jsr fog_calc_offset
000E30r 2               
000E30r 2                   ; Start column
000E30r 2  A6 rr            ldx temp_room_idx
000E32r 2  BD rr rr         lda room_x, x
000E35r 2  F0 03            beq @start_col_zero
000E37r 2  38               sec
000E38r 2  E9 01            sbc #$01
000E3Ar 2               @start_col_zero:
000E3Ar 2  A8               tay                         ; Y = start column
000E3Br 2               
000E3Br 2                   ; End column
000E3Br 2  BD rr rr         lda room_x, x
000E3Er 2  18               clc
000E3Fr 2  7D rr rr         adc room_w, x
000E42r 2  18               clc
000E43r 2  69 01            adc #$01
000E45r 2  C9 40            cmp #MAP_W
000E47r 2  90 02            bcc @end_col_ok
000E49r 2  A9 40            lda #MAP_W
000E4Br 2               @end_col_ok:
000E4Br 2  85 rr            sta temp_1                  ; End column
000E4Dr 2               
000E4Dr 2               @col_loop:
000E4Dr 2  C4 rr            cpy temp_1
000E4Fr 2  F0 0E            beq @next_row
000E51r 2  B1 rr            lda (ptr_lo), y
000E53r 2  C9 02            cmp #FOG_VISIBLE
000E55r 2  D0 04            bne @col_next
000E57r 2  A9 01            lda #FOG_EXPLORED
000E59r 2  91 rr            sta (ptr_lo), y
000E5Br 2               @col_next:
000E5Br 2  C8               iny
000E5Cr 2  4C rr rr         jmp @col_loop
000E5Fr 2               
000E5Fr 2               @next_row:
000E5Fr 2  E6 rr            inc temp_3
000E61r 2  4C rr rr         jmp @row_loop
000E64r 2               
000E64r 2               @done:
000E64r 2  60               rts
000E65r 2               .endproc
000E65r 2               
000E65r 2               ; ------------------------------------------------------------
000E65r 2               ; fog_reveal_around
000E65r 2               ; Reveal tiles in a small radius around the player (for corridors).
000E65r 2               ; Sets tiles within 1 step to FOG_VISIBLE.
000E65r 2               ; Input: player_x, player_y used directly
000E65r 2               ; ------------------------------------------------------------
000E65r 2               .proc fog_reveal_around
000E65r 2                   ; Reveal a 3x3 area centered on player
000E65r 2  A5 rr            lda player_y
000E67r 2  F0 03            beq @start_y_zero
000E69r 2  38               sec
000E6Ar 2  E9 01            sbc #$01
000E6Cr 2               @start_y_zero:
000E6Cr 2  85 rr            sta temp_3                  ; Start row
000E6Er 2               
000E6Er 2  A5 rr            lda player_y
000E70r 2  18               clc
000E71r 2  69 02            adc #$02                    ; End row (exclusive, player_y+2)
000E73r 2  C9 30            cmp #MAP_H
000E75r 2  90 02            bcc @end_y_ok
000E77r 2  A9 30            lda #MAP_H
000E79r 2               @end_y_ok:
000E79r 2  85 rr            sta temp_4
000E7Br 2               
000E7Br 2               @row_loop:
000E7Br 2  A5 rr            lda temp_3
000E7Dr 2  C5 rr            cmp temp_4
000E7Fr 2  F0 2B            beq @done
000E81r 2               
000E81r 2  A5 rr            lda temp_3
000E83r 2  20 rr rr         jsr fog_calc_offset
000E86r 2               
000E86r 2                   ; Start column
000E86r 2  A5 rr            lda player_x
000E88r 2  F0 03            beq @start_x_zero
000E8Ar 2  38               sec
000E8Br 2  E9 01            sbc #$01
000E8Dr 2               @start_x_zero:
000E8Dr 2  A8               tay
000E8Er 2               
000E8Er 2                   ; End column
000E8Er 2  A5 rr            lda player_x
000E90r 2  18               clc
000E91r 2  69 02            adc #$02
000E93r 2  C9 40            cmp #MAP_W
000E95r 2  90 02            bcc @end_x_ok
000E97r 2  A9 40            lda #MAP_W
000E99r 2               @end_x_ok:
000E99r 2  85 rr            sta temp_1
000E9Br 2               
000E9Br 2               @col_loop:
000E9Br 2  C4 rr            cpy temp_1
000E9Dr 2  F0 08            beq @next_row
000E9Fr 2  A9 02            lda #FOG_VISIBLE
000EA1r 2  91 rr            sta (ptr_lo), y
000EA3r 2  C8               iny
000EA4r 2  4C rr rr         jmp @col_loop
000EA7r 2               
000EA7r 2               @next_row:
000EA7r 2  E6 rr            inc temp_3
000EA9r 2  4C rr rr         jmp @row_loop
000EACr 2               
000EACr 2               @done:
000EACr 2  60               rts
000EADr 2               .endproc
000EADr 2               
000EADr 2               ; ------------------------------------------------------------
000EADr 2               ; fog_clear_visible
000EADr 2               ; Downgrade all FOG_VISIBLE tiles around player's previous
000EADr 2               ; position to FOG_EXPLORED (for corridor movement).
000EADr 2               ; Input: temp_1 = old X, temp_2 = old Y
000EADr 2               ; ------------------------------------------------------------
000EADr 2               .proc fog_clear_visible
000EADr 2  A5 rr            lda temp_2
000EAFr 2  F0 03            beq @start_y_zero
000EB1r 2  38               sec
000EB2r 2  E9 01            sbc #$01
000EB4r 2               @start_y_zero:
000EB4r 2  85 rr            sta temp_3
000EB6r 2               
000EB6r 2  A5 rr            lda temp_2
000EB8r 2  18               clc
000EB9r 2  69 02            adc #$02
000EBBr 2  C9 30            cmp #MAP_H
000EBDr 2  90 02            bcc @end_y_ok
000EBFr 2  A9 30            lda #MAP_H
000EC1r 2               @end_y_ok:
000EC1r 2  85 rr            sta temp_4
000EC3r 2               
000EC3r 2               @row_loop:
000EC3r 2  A5 rr            lda temp_3
000EC5r 2  C5 rr            cmp temp_4
000EC7r 2  F0 37            beq @done
000EC9r 2               
000EC9r 2  A5 rr            lda temp_3
000ECBr 2  20 rr rr         jsr fog_calc_offset
000ECEr 2               
000ECEr 2  A5 rr            lda temp_1
000ED0r 2  F0 09            beq @start_x_zero
000ED2r 2  48               pha
000ED3r 2  38               sec
000ED4r 2  E9 01            sbc #$01
000ED6r 2  A8               tay
000ED7r 2  68               pla
000ED8r 2  4C rr rr         jmp @do_cols
000EDBr 2               @start_x_zero:
000EDBr 2  A8               tay
000EDCr 2               
000EDCr 2               @do_cols:
000EDCr 2  A5 rr            lda temp_1
000EDEr 2  18               clc
000EDFr 2  69 02            adc #$02
000EE1r 2  C9 40            cmp #MAP_W
000EE3r 2  90 02            bcc @end_x_ok
000EE5r 2  A9 40            lda #MAP_W
000EE7r 2               @end_x_ok:
000EE7r 2  85 rr            sta temp_room_idx           ; Reuse as end column
000EE9r 2               
000EE9r 2               @col_loop:
000EE9r 2  C4 rr            cpy temp_room_idx
000EEBr 2  F0 0E            beq @next_row
000EEDr 2  B1 rr            lda (ptr_lo), y
000EEFr 2  C9 02            cmp #FOG_VISIBLE
000EF1r 2  D0 04            bne @col_next
000EF3r 2  A9 01            lda #FOG_EXPLORED
000EF5r 2  91 rr            sta (ptr_lo), y
000EF7r 2               @col_next:
000EF7r 2  C8               iny
000EF8r 2  4C rr rr         jmp @col_loop
000EFBr 2               
000EFBr 2               @next_row:
000EFBr 2  E6 rr            inc temp_3
000EFDr 2  4C rr rr         jmp @row_loop
000F00r 2               
000F00r 2               @done:
000F00r 2  60               rts
000F01r 2               .endproc
000F01r 2               
000F01r 2               ; ------------------------------------------------------------
000F01r 2               ; find_player_room
000F01r 2               ; Find which room the player is currently in.
000F01r 2               ; Output: X = room index, carry set if found
000F01r 2               ;         carry clear if not in any room (corridor)
000F01r 2               ; Sets player_current_room.
000F01r 2               ; ------------------------------------------------------------
000F01r 2               .proc find_player_room
000F01r 2  A2 00            ldx #$00
000F03r 2               @loop:
000F03r 2  E4 rr            cpx room_count
000F05r 2  F0 28            beq @not_in_room
000F07r 2               
000F07r 2                   ; Check X bounds
000F07r 2  A5 rr            lda player_x
000F09r 2  DD rr rr         cmp room_x, x
000F0Cr 2  90 1D            bcc @next
000F0Er 2  38               sec
000F0Fr 2  FD rr rr         sbc room_x, x
000F12r 2  DD rr rr         cmp room_w, x
000F15r 2  B0 14            bcs @next
000F17r 2               
000F17r 2                   ; Check Y bounds
000F17r 2  A5 rr            lda player_y
000F19r 2  DD rr rr         cmp room_y, x
000F1Cr 2  90 0D            bcc @next
000F1Er 2  38               sec
000F1Fr 2  FD rr rr         sbc room_y, x
000F22r 2  DD rr rr         cmp room_h, x
000F25r 2  B0 04            bcs @next
000F27r 2               
000F27r 2                   ; Found room X
000F27r 2  86 rr            stx player_current_room
000F29r 2  38               sec
000F2Ar 2  60               rts
000F2Br 2               
000F2Br 2               @next:
000F2Br 2  E8               inx
000F2Cr 2  4C rr rr         jmp @loop
000F2Fr 2               
000F2Fr 2               @not_in_room:
000F2Fr 2  A9 FF            lda #$FF
000F31r 2  85 rr            sta player_current_room
000F33r 2  18               clc
000F34r 2  60               rts
000F35r 2               .endproc
000F35r 2               
000F35r 1               .include "player.asm"
000F35r 2               ; ============================================================
000F35r 2               ; Player System — Movement, input handling
000F35r 2               ; ============================================================
000F35r 2               .segment "CODE"
000F35r 2               
000F35r 2               ; ------------------------------------------------------------
000F35r 2               ; player_input
000F35r 2               ; Process player input for one turn.
000F35r 2               ; Sets turn_taken = 1 if the player performed an action.
000F35r 2               ; ------------------------------------------------------------
000F35r 2               .proc player_input
000F35r 2  A9 00            lda #$00
000F37r 2  85 rr            sta turn_taken
000F39r 2               
000F39r 2                   ; Check directional input (new presses only for turn-based)
000F39r 2  A5 rr            lda buttons_new
000F3Br 2  85 rr            sta temp_move               ; Save for diagonal check
000F3Dr 2               
000F3Dr 2                   ; Calculate desired dx, dy
000F3Dr 2  A9 00            lda #$00
000F3Fr 2  85 rr            sta move_dx
000F41r 2  85 rr            sta move_dy
000F43r 2               
000F43r 2                   ; Check UP
000F43r 2  A5 rr            lda temp_move
000F45r 2  29 08            and #BUTTON_UP
000F47r 2  F0 02            beq @no_up
000F49r 2  C6 rr            dec move_dy                 ; dy = -1
000F4Br 2               @no_up:
000F4Br 2               
000F4Br 2                   ; Check DOWN
000F4Br 2  A5 rr            lda temp_move
000F4Dr 2  29 04            and #BUTTON_DOWN
000F4Fr 2  F0 02            beq @no_down
000F51r 2  E6 rr            inc move_dy                 ; dy = +1
000F53r 2               @no_down:
000F53r 2               
000F53r 2                   ; Check LEFT
000F53r 2  A5 rr            lda temp_move
000F55r 2  29 02            and #BUTTON_LEFT
000F57r 2  F0 02            beq @no_left
000F59r 2  C6 rr            dec move_dx                 ; dx = -1
000F5Br 2               @no_left:
000F5Br 2               
000F5Br 2                   ; Check RIGHT
000F5Br 2  A5 rr            lda temp_move
000F5Dr 2  29 01            and #BUTTON_RIGHT
000F5Fr 2  F0 02            beq @no_right
000F61r 2  E6 rr            inc move_dx                 ; dx = +1
000F63r 2               @no_right:
000F63r 2               
000F63r 2                   ; If no direction, check other buttons
000F63r 2  A5 rr            lda move_dx
000F65r 2  05 rr            ora move_dy
000F67r 2  D0 03            bne @has_direction
000F69r 2  4C rr rr         jmp @check_buttons
000F6Cr 2               @has_direction:
000F6Cr 2               
000F6Cr 2                   ; --- Attempt movement ---
000F6Cr 2                   ; Calculate target position
000F6Cr 2  A5 rr            lda player_x
000F6Er 2  18               clc
000F6Fr 2  65 rr            adc move_dx
000F71r 2  85 rr            sta target_x
000F73r 2               
000F73r 2  A5 rr            lda player_y
000F75r 2  18               clc
000F76r 2  65 rr            adc move_dy
000F78r 2  85 rr            sta target_y
000F7Ar 2               
000F7Ar 2                   ; Bounds check against full map (64x48)
000F7Ar 2  A5 rr            lda target_x
000F7Cr 2  C9 40            cmp #MAP_W
000F7Er 2  B0 79            bcs @blocked                ; >= 64 (or wrapped negative)
000F80r 2  A5 rr            lda target_y
000F82r 2  C9 30            cmp #MAP_H
000F84r 2  B0 73            bcs @blocked                ; >= 48 (or wrapped negative)
000F86r 2               
000F86r 2                   ; Check if target has a monster (bump attack)
000F86r 2  20 rr rr         jsr check_monster_at_target
000F89r 2  90 0A            bcc @no_monster
000F8Br 2                   ; Monster found — attack it (X = monster index)
000F8Br 2  86 rr            stx temp_mon_idx
000F8Dr 2  20 rr rr         jsr player_attack_monster
000F90r 2  A9 01            lda #$01
000F92r 2  85 rr            sta turn_taken
000F94r 2  60               rts
000F95r 2               
000F95r 2               @no_monster:
000F95r 2                   ; Check if target tile is passable
000F95r 2  A5 rr            lda target_y
000F97r 2  20 rr rr         jsr calc_row_offset
000F9Ar 2  A4 rr            ldy target_x
000F9Cr 2  B1 rr            lda (ptr_lo), y
000F9Er 2  C9 00            cmp #TILE_WALL
000FA0r 2  F0 57            beq @blocked
000FA2r 2  C9 03            cmp #TILE_DOOR_CLOSED
000FA4r 2  F0 36            beq @open_door
000FA6r 2               
000FA6r 2                   ; --- Move player ---
000FA6r 2                   ; Save old position for fog update (reuse move_dx/move_dy — done with them)
000FA6r 2  A5 rr            lda player_x
000FA8r 2  85 rr            sta move_dx                 ; Old X
000FAAr 2  A5 rr            lda player_y
000FACr 2  85 rr            sta move_dy                 ; Old Y
000FAEr 2               
000FAEr 2                   ; Erase old position
000FAEr 2  A5 rr            lda player_x
000FB0r 2  85 rr            sta temp_1
000FB2r 2  A5 rr            lda player_y
000FB4r 2  85 rr            sta temp_2
000FB6r 2  20 rr rr         jsr map_restore_tile
000FB9r 2               
000FB9r 2                   ; Update position
000FB9r 2  A5 rr            lda target_x
000FBBr 2  85 rr            sta player_x
000FBDr 2  A5 rr            lda target_y
000FBFr 2  85 rr            sta player_y
000FC1r 2               
000FC1r 2                   ; Check for screen flip (updates camera if player left viewport)
000FC1r 2  20 rr rr         jsr check_screen_flip
000FC4r 2               
000FC4r 2                   ; Draw new position (skips if off-screen during flip — redraw handles it)
000FC4r 2  A5 rr            lda player_x
000FC6r 2  85 rr            sta temp_1
000FC8r 2  A5 rr            lda player_y
000FCAr 2  85 rr            sta temp_2
000FCCr 2  A9 15            lda #CHR_PLAYER
000FCEr 2  20 rr rr         jsr map_update_entity
000FD1r 2               
000FD1r 2                   ; Update fog of war
000FD1r 2  20 rr rr         jsr update_fog
000FD4r 2               
000FD4r 2                   ; Check for items at new position
000FD4r 2  20 rr rr         jsr check_pickup
000FD7r 2               
000FD7r 2  A9 01            lda #$01
000FD9r 2  85 rr            sta turn_taken
000FDBr 2  60               rts
000FDCr 2               
000FDCr 2               @open_door:
000FDCr 2                   ; Change door to open
000FDCr 2  A5 rr            lda target_y
000FDEr 2  20 rr rr         jsr calc_row_offset
000FE1r 2  A4 rr            ldy target_x
000FE3r 2  A9 04            lda #TILE_DOOR_OPEN
000FE5r 2  91 rr            sta (ptr_lo), y
000FE7r 2               
000FE7r 2                   ; Update tile on screen
000FE7r 2  A5 rr            lda target_x
000FE9r 2  85 rr            sta temp_1
000FEBr 2  A5 rr            lda target_y
000FEDr 2  85 rr            sta temp_2
000FEFr 2  A9 06            lda #CHR_DOOR_OPEN
000FF1r 2  20 rr rr         jsr map_update_entity
000FF4r 2               
000FF4r 2  A9 01            lda #$01
000FF6r 2  85 rr            sta turn_taken
000FF8r 2  60               rts
000FF9r 2               
000FF9r 2               @blocked:
000FF9r 2  60               rts
000FFAr 2               
000FFAr 2               @check_buttons:
000FFAr 2                   ; B button = wait one turn
000FFAr 2  A5 rr            lda buttons_new
000FFCr 2  29 40            and #BUTTON_B
000FFEr 2  F0 05            beq @no_wait
001000r 2  A9 01            lda #$01
001002r 2  85 rr            sta turn_taken
001004r 2  60               rts
001005r 2               @no_wait:
001005r 2               
001005r 2                   ; A button = pick up / use stairs
001005r 2  A5 rr            lda buttons_new
001007r 2  29 80            and #BUTTON_A
001009r 2  F0 2F            beq @no_action
00100Br 2               
00100Br 2                   ; Check if on stairs
00100Br 2  A5 rr            lda player_y
00100Dr 2  20 rr rr         jsr calc_row_offset
001010r 2  A4 rr            ldy player_x
001012r 2  B1 rr            lda (ptr_lo), y
001014r 2  C9 06            cmp #TILE_STAIRS_DOWN
001016r 2  F0 08            beq @go_down
001018r 2  C9 05            cmp #TILE_STAIRS_UP
00101Ar 2  F0 11            beq @go_up
00101Cr 2               
00101Cr 2                   ; Check for item pickup
00101Cr 2  20 rr rr         jsr check_pickup
00101Fr 2  60               rts
001020r 2               
001020r 2               @go_down:
001020r 2  A9 00            lda #$00                    ; Direction = down
001022r 2  85 rr            sta stairs_direction
001024r 2  A9 04            lda #STATE_STAIRS
001026r 2  85 rr            sta game_state
001028r 2  A9 00            lda #$00
00102Ar 2  85 rr            sta state_initialized
00102Cr 2  60               rts
00102Dr 2               
00102Dr 2               @go_up:
00102Dr 2  A9 01            lda #$01                    ; Direction = up
00102Fr 2  85 rr            sta stairs_direction
001031r 2  A9 04            lda #STATE_STAIRS
001033r 2  85 rr            sta game_state
001035r 2  A9 00            lda #$00
001037r 2  85 rr            sta state_initialized
001039r 2  60               rts
00103Ar 2               
00103Ar 2               @no_action:
00103Ar 2  60               rts
00103Br 2               .endproc
00103Br 2               
00103Br 2               ; ------------------------------------------------------------
00103Br 2               ; check_screen_flip
00103Br 2               ; Check if player has moved outside the current viewport.
00103Br 2               ; If so, update camera_x/camera_y and set screen_flip = 1.
00103Br 2               ; The gamestate handler will then do a full screen redraw.
00103Br 2               ; ------------------------------------------------------------
00103Br 2               .proc check_screen_flip
00103Br 2                   ; --- Check horizontal ---
00103Br 2  A5 rr            lda player_x
00103Dr 2  C5 rr            cmp camera_x
00103Fr 2  B0 12            bcs @check_right            ; player_x >= camera_x, not off left
001041r 2               
001041r 2                   ; Player moved left of viewport
001041r 2  A5 rr            lda camera_x
001043r 2  38               sec
001044r 2  E9 20            sbc #VIEW_W
001046r 2  B0 02            bcs @set_cam_x              ; Result >= 0
001048r 2  A9 00            lda #$00                    ; Clamp to 0
00104Ar 2               @set_cam_x:
00104Ar 2  85 rr            sta camera_x
00104Cr 2  A9 01            lda #$01
00104Er 2  85 rr            sta screen_flip
001050r 2  4C rr rr         jmp @check_y
001053r 2               
001053r 2               @check_right:
001053r 2                   ; Check if player_x >= camera_x + VIEW_W
001053r 2  A5 rr            lda camera_x
001055r 2  18               clc
001056r 2  69 20            adc #VIEW_W
001058r 2  85 rr            sta temp_1                  ; camera_x + VIEW_W
00105Ar 2  A5 rr            lda player_x
00105Cr 2  C5 rr            cmp temp_1
00105Er 2  90 0C            bcc @check_y                ; Still within viewport
001060r 2               
001060r 2                   ; Player moved right of viewport
001060r 2  A5 rr            lda temp_1
001062r 2  C9 40            cmp #MAP_W
001064r 2  B0 06            bcs @check_y                ; Can't scroll past map edge
001066r 2  85 rr            sta camera_x
001068r 2  A9 01            lda #$01
00106Ar 2  85 rr            sta screen_flip
00106Cr 2               
00106Cr 2               @check_y:
00106Cr 2                   ; --- Check vertical ---
00106Cr 2  A5 rr            lda player_y
00106Er 2  C5 rr            cmp camera_y
001070r 2  B0 10            bcs @check_down             ; player_y >= camera_y, not off top
001072r 2               
001072r 2                   ; Player moved above viewport
001072r 2  A5 rr            lda camera_y
001074r 2  38               sec
001075r 2  E9 18            sbc #VIEW_H
001077r 2  B0 02            bcs @set_cam_y
001079r 2  A9 00            lda #$00
00107Br 2               @set_cam_y:
00107Br 2  85 rr            sta camera_y
00107Dr 2  A9 01            lda #$01
00107Fr 2  85 rr            sta screen_flip
001081r 2  60               rts
001082r 2               
001082r 2               @check_down:
001082r 2                   ; Check if player_y >= camera_y + VIEW_H
001082r 2  A5 rr            lda camera_y
001084r 2  18               clc
001085r 2  69 18            adc #VIEW_H
001087r 2  85 rr            sta temp_1
001089r 2  A5 rr            lda player_y
00108Br 2  C5 rr            cmp temp_1
00108Dr 2  90 0C            bcc @done                   ; Still within viewport
00108Fr 2               
00108Fr 2                   ; Player moved below viewport
00108Fr 2  A5 rr            lda temp_1
001091r 2  C9 30            cmp #MAP_H
001093r 2  B0 06            bcs @done                   ; Can't scroll past map edge
001095r 2  85 rr            sta camera_y
001097r 2  A9 01            lda #$01
001099r 2  85 rr            sta screen_flip
00109Br 2               
00109Br 2               @done:
00109Br 2  60               rts
00109Cr 2               .endproc
00109Cr 2               
00109Cr 2               ; ------------------------------------------------------------
00109Cr 2               ; update_fog
00109Cr 2               ; Update fog of war after player moves.
00109Cr 2               ; Uses move_dx/move_dy as saved old position.
00109Cr 2               ; Handles room transitions and corridor visibility.
00109Cr 2               ; ------------------------------------------------------------
00109Cr 2               .proc update_fog
00109Cr 2                   ; Find which room player is now in
00109Cr 2  20 rr rr         jsr find_player_room
00109Fr 2  90 19            bcc @in_corridor
0010A1r 2               
0010A1r 2                   ; --- Player is in a room ---
0010A1r 2  A5 rr            lda player_current_room
0010A3r 2  C5 rr            cmp player_prev_room
0010A5r 2  F0 12            beq @same_room              ; Same room, nothing to change
0010A7r 2               
0010A7r 2                   ; Different room — downgrade old room if valid
0010A7r 2  A6 rr            ldx player_prev_room
0010A9r 2  E0 FF            cpx #$FF
0010ABr 2  F0 03            beq @no_downgrade
0010ADr 2  20 rr rr         jsr fog_downgrade_room
0010B0r 2               @no_downgrade:
0010B0r 2               
0010B0r 2                   ; Reveal new room
0010B0r 2  A6 rr            ldx player_current_room
0010B2r 2  20 rr rr         jsr fog_reveal_room
0010B5r 2               
0010B5r 2                   ; Update prev room tracker
0010B5r 2  A5 rr            lda player_current_room
0010B7r 2  85 rr            sta player_prev_room
0010B9r 2               
0010B9r 2               @same_room:
0010B9r 2  60               rts
0010BAr 2               
0010BAr 2               @in_corridor:
0010BAr 2                   ; Downgrade old visible area (old position saved in move_dx/move_dy)
0010BAr 2  A5 rr            lda move_dx
0010BCr 2  85 rr            sta temp_1                  ; Old X
0010BEr 2  A5 rr            lda move_dy
0010C0r 2  85 rr            sta temp_2                  ; Old Y
0010C2r 2  20 rr rr         jsr fog_clear_visible
0010C5r 2               
0010C5r 2                   ; Reveal around current position
0010C5r 2  20 rr rr         jsr fog_reveal_around
0010C8r 2               
0010C8r 2                   ; If was in a room, downgrade it
0010C8r 2  A6 rr            ldx player_prev_room
0010CAr 2  E0 FF            cpx #$FF
0010CCr 2  F0 07            beq @no_room_downgrade
0010CEr 2  20 rr rr         jsr fog_downgrade_room
0010D1r 2  A9 FF            lda #$FF
0010D3r 2  85 rr            sta player_prev_room
0010D5r 2               @no_room_downgrade:
0010D5r 2  60               rts
0010D6r 2               .endproc
0010D6r 2               
0010D6r 2               ; ------------------------------------------------------------
0010D6r 2               ; check_monster_at_target
0010D6r 2               ; Check if there's a monster at (target_x, target_y).
0010D6r 2               ; Output: carry set if found, X = monster index
0010D6r 2               ;         carry clear if not found
0010D6r 2               ; ------------------------------------------------------------
0010D6r 2               .proc check_monster_at_target
0010D6r 2  A2 00            ldx #$00
0010D8r 2               @loop:
0010D8r 2  E4 rr            cpx monster_count
0010DAr 2  F0 14            beq @not_found
0010DCr 2               
0010DCr 2  BD rr rr         lda mon_x, x
0010DFr 2  C5 rr            cmp target_x
0010E1r 2  D0 09            bne @next
0010E3r 2  BD rr rr         lda mon_y, x
0010E6r 2  C5 rr            cmp target_y
0010E8r 2  D0 02            bne @next
0010EAr 2               
0010EAr 2                   ; Found monster at target
0010EAr 2  38               sec
0010EBr 2  60               rts
0010ECr 2               
0010ECr 2               @next:
0010ECr 2  E8               inx
0010EDr 2  4C rr rr         jmp @loop
0010F0r 2               
0010F0r 2               @not_found:
0010F0r 2  18               clc
0010F1r 2  60               rts
0010F2r 2               .endproc
0010F2r 2               
0010F2r 2               ; ------------------------------------------------------------
0010F2r 2               ; check_pickup
0010F2r 2               ; Check if player is standing on a floor item and pick it up.
0010F2r 2               ; ------------------------------------------------------------
0010F2r 2               .proc check_pickup
0010F2r 2  A2 00            ldx #$00
0010F4r 2               @loop:
0010F4r 2  E4 rr            cpx floor_item_count
0010F6r 2  F0 66            beq @done
0010F8r 2               
0010F8r 2  BD rr rr         lda fi_x, x
0010FBr 2  C5 rr            cmp player_x
0010FDr 2  D0 5B            bne @next
0010FFr 2  BD rr rr         lda fi_y, x
001102r 2  C5 rr            cmp player_y
001104r 2  D0 54            bne @next
001106r 2               
001106r 2                   ; Found item — handle by type
001106r 2  BD rr rr         lda fi_type, x
001109r 2  C9 00            cmp #ITEM_GOLD
00110Br 2  F0 07            beq @pickup_gold
00110Dr 2  C9 01            cmp #ITEM_FOOD
00110Fr 2  F0 1D            beq @pickup_food
001111r 2  4C rr rr         jmp @next                   ; Unknown type, skip
001114r 2               
001114r 2               @pickup_gold:
001114r 2                   ; Add gold to player total
001114r 2  BD rr rr         lda fi_mod, x               ; Gold amount
001117r 2  18               clc
001118r 2  65 rr            adc player_gold
00111Ar 2  90 02            bcc @gold_ok
00111Cr 2  A9 FF            lda #$FF                    ; Cap at 255
00111Er 2               @gold_ok:
00111Er 2  85 rr            sta player_gold
001120r 2               
001120r 2                   ; Show message
001120r 2  A9 rr            lda #<str_found_gold
001122r 2  85 rr            sta ptr_lo
001124r 2  A9 rr            lda #>str_found_gold
001126r 2  85 rr            sta ptr_hi
001128r 2  20 rr rr         jsr msg_show
00112Br 2               
00112Br 2  4C rr rr         jmp @remove_item
00112Er 2               
00112Er 2               @pickup_food:
00112Er 2                   ; Restore hunger
00112Er 2  A5 rr            lda player_hunger
001130r 2  18               clc
001131r 2  69 64            adc #FOOD_RESTORE
001133r 2  90 02            bcc @hunger_ok
001135r 2  A9 FF            lda #$FF
001137r 2               @hunger_ok:
001137r 2  85 rr            sta player_hunger
001139r 2               
001139r 2                   ; Heal 25% of max HP
001139r 2  A5 rr            lda player_max_hp
00113Br 2  4A               lsr a
00113Cr 2  4A               lsr a                       ; / 4 = 25%
00113Dr 2  18               clc
00113Er 2  65 rr            adc player_hp
001140r 2  C5 rr            cmp player_max_hp
001142r 2  90 02            bcc @hp_ok
001144r 2  A5 rr            lda player_max_hp
001146r 2               @hp_ok:
001146r 2  85 rr            sta player_hp
001148r 2               
001148r 2  A9 rr            lda #<str_ate_food
00114Ar 2  85 rr            sta ptr_lo
00114Cr 2  A9 rr            lda #>str_ate_food
00114Er 2  85 rr            sta ptr_hi
001150r 2  20 rr rr         jsr msg_show
001153r 2               
001153r 2  4C rr rr         jmp @remove_item
001156r 2               
001156r 2               @remove_item:
001156r 2                   ; Remove item by shifting array
001156r 2  20 rr rr         jsr remove_floor_item       ; X = index to remove
001159r 2  60               rts
00115Ar 2               
00115Ar 2               @next:
00115Ar 2  E8               inx
00115Br 2  4C rr rr         jmp @loop
00115Er 2               @done:
00115Er 2  60               rts
00115Fr 2               .endproc
00115Fr 2               
00115Fr 2               ; ------------------------------------------------------------
00115Fr 2               ; remove_floor_item
00115Fr 2               ; Remove floor item at index X by shifting remaining items down.
00115Fr 2               ; Input: X = index to remove
00115Fr 2               ; ------------------------------------------------------------
00115Fr 2               .proc remove_floor_item
00115Fr 2                   ; Shift items from X+1..count-1 down by 1
00115Fr 2               @shift:
00115Fr 2  E8               inx
001160r 2  E4 rr            cpx floor_item_count
001162r 2  F0 1B            beq @done
001164r 2               
001164r 2  BD rr rr         lda fi_x, x
001167r 2  9D rr rr         sta fi_x - 1, x
00116Ar 2  BD rr rr         lda fi_y, x
00116Dr 2  9D rr rr         sta fi_y - 1, x
001170r 2  BD rr rr         lda fi_type, x
001173r 2  9D rr rr         sta fi_type - 1, x
001176r 2  BD rr rr         lda fi_mod, x
001179r 2  9D rr rr         sta fi_mod - 1, x
00117Cr 2               
00117Cr 2  4C rr rr         jmp @shift
00117Fr 2               
00117Fr 2               @done:
00117Fr 2  C6 rr            dec floor_item_count
001181r 2  60               rts
001182r 2               .endproc
001182r 2               
001182r 1               .include "monsters.asm"
001182r 2               ; ============================================================
001182r 2               ; Monster System — AI, movement, spawning
001182r 2               ; ============================================================
001182r 2               .segment "CODE"
001182r 2               
001182r 2               ; ------------------------------------------------------------
001182r 2               ; monsters_update
001182r 2               ; Process all monster turns (called after player moves).
001182r 2               ; Each awake monster moves toward player or attacks.
001182r 2               ; ------------------------------------------------------------
001182r 2               .proc monsters_update
001182r 2  A2 00            ldx #$00
001184r 2               @loop:
001184r 2  E4 rr            cpx monster_count
001186r 2  F0 2B            beq @done
001188r 2  86 rr            stx temp_mon_idx
00118Ar 2               
00118Ar 2                   ; Skip dead monsters (hp = 0)
00118Ar 2  BD rr rr         lda mon_hp, x
00118Dr 2  F0 1E            beq @next
00118Fr 2               
00118Fr 2                   ; Check if sleeping
00118Fr 2  BD rr rr         lda mon_flags, x
001192r 2  29 01            and #MFLAG_AWAKE
001194r 2  F0 06            beq @check_wake
001196r 2               
001196r 2                   ; Monster is awake — decide action
001196r 2  20 rr rr         jsr monster_act
001199r 2  4C rr rr         jmp @next
00119Cr 2               
00119Cr 2               @check_wake:
00119Cr 2                   ; Check distance to player
00119Cr 2  20 rr rr         jsr calc_monster_dist       ; Returns distance in A
00119Fr 2  C9 05            cmp #MONSTER_WAKE_DIST
0011A1r 2  B0 0A            bcs @next                   ; Too far, stay asleep
0011A3r 2               
0011A3r 2                   ; Wake up!
0011A3r 2  A6 rr            ldx temp_mon_idx
0011A5r 2  BD rr rr         lda mon_flags, x
0011A8r 2  09 01            ora #MFLAG_AWAKE
0011AAr 2  9D rr rr         sta mon_flags, x
0011ADr 2               
0011ADr 2               @next:
0011ADr 2  A6 rr            ldx temp_mon_idx
0011AFr 2  E8               inx
0011B0r 2  4C rr rr         jmp @loop
0011B3r 2               
0011B3r 2               @done:
0011B3r 2  60               rts
0011B4r 2               .endproc
0011B4r 2               
0011B4r 2               ; ------------------------------------------------------------
0011B4r 2               ; monster_act
0011B4r 2               ; Process one monster's turn.
0011B4r 2               ; Input: temp_mon_idx = monster index
0011B4r 2               ; ------------------------------------------------------------
0011B4r 2               .proc monster_act
0011B4r 2  A6 rr            ldx temp_mon_idx
0011B6r 2               
0011B6r 2                   ; Check if adjacent to player (can attack)
0011B6r 2  BD rr rr         lda mon_x, x
0011B9r 2  38               sec
0011BAr 2  E5 rr            sbc player_x
0011BCr 2  10 05            bpl @abs_dx
0011BEr 2  49 FF            eor #$FF
0011C0r 2  18               clc
0011C1r 2  69 01            adc #$01
0011C3r 2               @abs_dx:
0011C3r 2  85 rr            sta temp_1                  ; |dx|
0011C5r 2               
0011C5r 2  BD rr rr         lda mon_y, x
0011C8r 2  38               sec
0011C9r 2  E5 rr            sbc player_y
0011CBr 2  10 05            bpl @abs_dy
0011CDr 2  49 FF            eor #$FF
0011CFr 2  18               clc
0011D0r 2  69 01            adc #$01
0011D2r 2               @abs_dy:
0011D2r 2  85 rr            sta temp_2                  ; |dy|
0011D4r 2               
0011D4r 2                   ; Adjacent if max(|dx|, |dy|) <= 1
0011D4r 2  A5 rr            lda temp_1
0011D6r 2  C9 02            cmp #$02
0011D8r 2  B0 10            bcs @move
0011DAr 2  A5 rr            lda temp_2
0011DCr 2  C9 02            cmp #$02
0011DEr 2  B0 0A            bcs @move
0011E0r 2               
0011E0r 2                   ; Both dx and dy <= 1 — attack!
0011E0r 2  A5 rr            lda temp_1
0011E2r 2  05 rr            ora temp_2
0011E4r 2  F0 04            beq @move                   ; Same tile? shouldn't happen, just move
0011E6r 2  20 rr rr         jsr monster_attack_player
0011E9r 2  60               rts
0011EAr 2               
0011EAr 2               @move:
0011EAr 2                   ; Check for erratic movement
0011EAr 2  A6 rr            ldx temp_mon_idx
0011ECr 2  BD rr rr         lda mon_flags, x
0011EFr 2  29 04            and #MFLAG_ERRATIC
0011F1r 2  F0 1A            beq @chase
0011F3r 2               
0011F3r 2                   ; 50% chance of random movement
0011F3r 2  20 rr rr         jsr rng_next
0011F6r 2  29 01            and #$01
0011F8r 2  F0 13            beq @chase
0011FAr 2               
0011FAr 2                   ; Random direction
0011FAr 2  A9 08            lda #$08                    ; 8 directions
0011FCr 2  20 rr rr         jsr rng_range
0011FFr 2  AA               tax
001200r 2  BD rr rr         lda dir_dx, x
001203r 2  85 rr            sta move_dx
001205r 2  BD rr rr         lda dir_dy, x
001208r 2  85 rr            sta move_dy
00120Ar 2  4C rr rr         jmp @try_move
00120Dr 2               
00120Dr 2               @chase:
00120Dr 2                   ; Move toward player (prefer axis with greater distance)
00120Dr 2  A6 rr            ldx temp_mon_idx
00120Fr 2  A9 00            lda #$00
001211r 2  85 rr            sta move_dx
001213r 2  85 rr            sta move_dy
001215r 2               
001215r 2  A5 rr            lda player_x
001217r 2  DD rr rr         cmp mon_x, x
00121Ar 2  F0 09            beq @check_y
00121Cr 2  90 05            bcc @move_left
00121Er 2  E6 rr            inc move_dx                 ; Move right
001220r 2  4C rr rr         jmp @check_y
001223r 2               @move_left:
001223r 2  C6 rr            dec move_dx                 ; Move left
001225r 2               
001225r 2               @check_y:
001225r 2  A5 rr            lda player_y
001227r 2  DD rr rr         cmp mon_y, x
00122Ar 2  F0 09            beq @try_move
00122Cr 2  90 05            bcc @move_up
00122Er 2  E6 rr            inc move_dy                 ; Move down
001230r 2  4C rr rr         jmp @try_move
001233r 2               @move_up:
001233r 2  C6 rr            dec move_dy                 ; Move up
001235r 2               
001235r 2               @try_move:
001235r 2  A6 rr            ldx temp_mon_idx
001237r 2               
001237r 2                   ; Calculate target
001237r 2  BD rr rr         lda mon_x, x
00123Ar 2  18               clc
00123Br 2  65 rr            adc move_dx
00123Dr 2  85 rr            sta target_x
00123Fr 2               
00123Fr 2  BD rr rr         lda mon_y, x
001242r 2  18               clc
001243r 2  65 rr            adc move_dy
001245r 2  85 rr            sta target_y
001247r 2               
001247r 2                   ; Bounds check
001247r 2  A5 rr            lda target_x
001249r 2  C9 20            cmp #MAP_COLS
00124Br 2  B0 57            bcs @cant_move
00124Dr 2  A5 rr            lda target_y
00124Fr 2  C9 18            cmp #MAP_ROWS
001251r 2  B0 51            bcs @cant_move
001253r 2               
001253r 2                   ; Check passability
001253r 2  A5 rr            lda target_y
001255r 2  20 rr rr         jsr calc_row_offset
001258r 2  A4 rr            ldy target_x
00125Ar 2  B1 rr            lda (ptr_lo), y
00125Cr 2  C9 00            cmp #TILE_WALL
00125Er 2  F0 44            beq @cant_move
001260r 2  C9 03            cmp #TILE_DOOR_CLOSED
001262r 2  F0 40            beq @cant_move
001264r 2               
001264r 2                   ; Check for other monsters at target
001264r 2  20 rr rr         jsr check_monster_collision
001267r 2  B0 3B            bcs @cant_move
001269r 2               
001269r 2                   ; Check if target is player position (shouldn't move onto player)
001269r 2  A5 rr            lda target_x
00126Br 2  C5 rr            cmp player_x
00126Dr 2  D0 06            bne @not_player
00126Fr 2  A5 rr            lda target_y
001271r 2  C5 rr            cmp player_y
001273r 2  F0 2F            beq @cant_move              ; Can't walk onto player
001275r 2               @not_player:
001275r 2               
001275r 2                   ; Erase old position
001275r 2  A6 rr            ldx temp_mon_idx
001277r 2  BD rr rr         lda mon_x, x
00127Ar 2  85 rr            sta temp_1
00127Cr 2  BD rr rr         lda mon_y, x
00127Fr 2  85 rr            sta temp_2
001281r 2  20 rr rr         jsr map_restore_tile
001284r 2               
001284r 2                   ; Update position
001284r 2  A6 rr            ldx temp_mon_idx
001286r 2  A5 rr            lda target_x
001288r 2  9D rr rr         sta mon_x, x
00128Br 2  A5 rr            lda target_y
00128Dr 2  9D rr rr         sta mon_y, x
001290r 2               
001290r 2                   ; Draw new position
001290r 2  BD rr rr         lda mon_x, x
001293r 2  85 rr            sta temp_1
001295r 2  BD rr rr         lda mon_y, x
001298r 2  85 rr            sta temp_2
00129Ar 2  BD rr rr         lda mon_type, x
00129Dr 2  A8               tay
00129Er 2  B9 rr rr         lda mon_chr_tile, y
0012A1r 2  20 rr rr         jsr map_update_entity
0012A4r 2               
0012A4r 2               @cant_move:
0012A4r 2  60               rts
0012A5r 2               .endproc
0012A5r 2               
0012A5r 2               ; ------------------------------------------------------------
0012A5r 2               ; calc_monster_dist
0012A5r 2               ; Calculate Chebyshev distance from monster to player.
0012A5r 2               ; Input: temp_mon_idx
0012A5r 2               ; Output: A = max(|dx|, |dy|)
0012A5r 2               ; ------------------------------------------------------------
0012A5r 2               .proc calc_monster_dist
0012A5r 2  A6 rr            ldx temp_mon_idx
0012A7r 2               
0012A7r 2  BD rr rr         lda mon_x, x
0012AAr 2  38               sec
0012ABr 2  E5 rr            sbc player_x
0012ADr 2  10 05            bpl @abs_dx
0012AFr 2  49 FF            eor #$FF
0012B1r 2  18               clc
0012B2r 2  69 01            adc #$01
0012B4r 2               @abs_dx:
0012B4r 2  85 rr            sta temp_1
0012B6r 2               
0012B6r 2  BD rr rr         lda mon_y, x
0012B9r 2  38               sec
0012BAr 2  E5 rr            sbc player_y
0012BCr 2  10 05            bpl @abs_dy
0012BEr 2  49 FF            eor #$FF
0012C0r 2  18               clc
0012C1r 2  69 01            adc #$01
0012C3r 2               @abs_dy:
0012C3r 2               
0012C3r 2                   ; Return max(|dx|, |dy|)
0012C3r 2  C5 rr            cmp temp_1
0012C5r 2  B0 02            bcs @dy_bigger
0012C7r 2  A5 rr            lda temp_1                  ; dx is bigger
0012C9r 2               @dy_bigger:
0012C9r 2  60               rts
0012CAr 2               .endproc
0012CAr 2               
0012CAr 2               ; ------------------------------------------------------------
0012CAr 2               ; check_monster_collision
0012CAr 2               ; Check if another monster is at (target_x, target_y).
0012CAr 2               ; Output: carry set if blocked, carry clear if free
0012CAr 2               ; ------------------------------------------------------------
0012CAr 2               .proc check_monster_collision
0012CAr 2  A2 00            ldx #$00
0012CCr 2               @loop:
0012CCr 2  E4 rr            cpx monster_count
0012CEr 2  F0 1D            beq @free
0012D0r 2               
0012D0r 2                   ; Skip self
0012D0r 2  E4 rr            cpx temp_mon_idx
0012D2r 2  F0 15            beq @next
0012D4r 2               
0012D4r 2                   ; Skip dead
0012D4r 2  BD rr rr         lda mon_hp, x
0012D7r 2  F0 10            beq @next
0012D9r 2               
0012D9r 2  BD rr rr         lda mon_x, x
0012DCr 2  C5 rr            cmp target_x
0012DEr 2  D0 09            bne @next
0012E0r 2  BD rr rr         lda mon_y, x
0012E3r 2  C5 rr            cmp target_y
0012E5r 2  D0 02            bne @next
0012E7r 2               
0012E7r 2  38               sec                         ; Blocked
0012E8r 2  60               rts
0012E9r 2               
0012E9r 2               @next:
0012E9r 2  E8               inx
0012EAr 2  4C rr rr         jmp @loop
0012EDr 2               
0012EDr 2               @free:
0012EDr 2  18               clc
0012EEr 2  60               rts
0012EFr 2               .endproc
0012EFr 2               
0012EFr 2               ; ============================================================
0012EFr 2               ; Direction tables for 8-directional movement
0012EFr 2               ; ============================================================
0012EFr 2               .segment "RODATA"
000000r 2               
000000r 2               dir_dx:
000000r 2  00 01 01 01      .byte $00, $01, $01, $01, $00, $FF, $FF, $FF  ; N, NE, E, SE, S, SW, W, NW
000004r 2  00 FF FF FF  
000008r 2               dir_dy:
000008r 2  FF FF 00 01      .byte $FF, $FF, $00, $01, $01, $01, $00, $FF
00000Cr 2  01 01 00 FF  
000010r 2               
000010r 1               .include "combat.asm"
000010r 2               ; ============================================================
000010r 2               ; Combat System — Attack resolution, damage, XP
000010r 2               ; ============================================================
000010r 2               .segment "CODE"
0012EFr 2               
0012EFr 2               ; ------------------------------------------------------------
0012EFr 2               ; player_attack_monster
0012EFr 2               ; Player attacks monster at index X.
0012EFr 2               ; Uses d20 system from game mechanics.
0012EFr 2               ; Input: X = monster index (also in temp_mon_idx)
0012EFr 2               ; ------------------------------------------------------------
0012EFr 2               .proc player_attack_monster
0012EFr 2  A6 rr            ldx temp_mon_idx
0012F1r 2               
0012F1r 2                   ; Roll d20
0012F1r 2  A9 14            lda #D20_SIDES
0012F3r 2  20 rr rr         jsr rng_range               ; 0-19
0012F6r 2  18               clc
0012F7r 2  69 01            adc #$01                    ; 1-20
0012F9r 2               
0012F9r 2                   ; Add player level
0012F9r 2  18               clc
0012FAr 2  65 rr            adc player_level
0012FCr 2               
0012FCr 2                   ; Add weapon bonus (start with +1 mace)
0012FCr 2  18               clc
0012FDr 2  69 01            adc #$01                    ; TODO: read from equipped weapon
0012FFr 2               
0012FFr 2                   ; Compare against monster armor
0012FFr 2  A6 rr            ldx temp_mon_idx
001301r 2  BC rr rr         ldy mon_type, x
001304r 2  D9 rr rr         cmp mon_armor, y
001307r 2  90 5E            bcc @miss                   ; Roll < armor = miss
001309r 2               
001309r 2                   ; --- HIT ---
001309r 2                   ; Calculate damage: 1d4 + str_bonus + weapon_bonus
001309r 2  A9 04            lda #$04
00130Br 2  20 rr rr         jsr rng_range               ; 0-3
00130Er 2  18               clc
00130Fr 2  69 01            adc #$01                    ; 1-4
001311r 2               
001311r 2                   ; Add strength bonus
001311r 2  18               clc
001312r 2  69 01            adc #$01                    ; Simplified: +1 for str 16
001314r 2               
001314r 2                   ; Add weapon bonus
001314r 2  18               clc
001315r 2  69 01            adc #$01                    ; +1 mace
001317r 2               
001317r 2                   ; Apply damage
001317r 2  A6 rr            ldx temp_mon_idx
001319r 2  85 rr            sta temp_1                  ; Damage amount
00131Br 2  BD rr rr         lda mon_hp, x
00131Er 2  38               sec
00131Fr 2  E5 rr            sbc temp_1
001321r 2  B0 02            bcs @not_dead
001323r 2  A9 00            lda #$00                    ; Clamp to 0
001325r 2               @not_dead:
001325r 2  9D rr rr         sta mon_hp, x
001328r 2               
001328r 2                   ; Show hit message
001328r 2  A9 rr            lda #<str_you_hit
00132Ar 2  85 rr            sta ptr_lo
00132Cr 2  A9 rr            lda #>str_you_hit
00132Er 2  85 rr            sta ptr_hi
001330r 2  20 rr rr         jsr msg_show
001333r 2               
001333r 2                   ; Check if monster died
001333r 2  A6 rr            ldx temp_mon_idx            ; Reload (msg_show clobbers X)
001335r 2  BD rr rr         lda mon_hp, x
001338r 2  D0 2C            bne @done
00133Ar 2               
00133Ar 2                   ; --- Monster killed ---
00133Ar 2                   ; Award XP
00133Ar 2  BC rr rr         ldy mon_type, x
00133Dr 2  B9 rr rr         lda mon_xp, y
001340r 2  18               clc
001341r 2  65 rr            adc player_xp
001343r 2  90 02            bcc @xp_ok
001345r 2  A9 FF            lda #$FF
001347r 2               @xp_ok:
001347r 2  85 rr            sta player_xp
001349r 2               
001349r 2                   ; Check for level up
001349r 2  20 rr rr         jsr check_level_up
00134Cr 2               
00134Cr 2                   ; Erase monster from map
00134Cr 2  A6 rr            ldx temp_mon_idx            ; Reload (check_level_up clobbers X)
00134Er 2  BD rr rr         lda mon_x, x
001351r 2  85 rr            sta temp_1
001353r 2  BD rr rr         lda mon_y, x
001356r 2  85 rr            sta temp_2
001358r 2  20 rr rr         jsr map_restore_tile
00135Br 2               
00135Br 2                   ; Show kill message
00135Br 2  A9 rr            lda #<str_killed
00135Dr 2  85 rr            sta ptr_lo
00135Fr 2  A9 rr            lda #>str_killed
001361r 2  85 rr            sta ptr_hi
001363r 2  20 rr rr         jsr msg_show
001366r 2               
001366r 2               @done:
001366r 2  60               rts
001367r 2               
001367r 2               @miss:
001367r 2  A9 rr            lda #<str_you_miss
001369r 2  85 rr            sta ptr_lo
00136Br 2  A9 rr            lda #>str_you_miss
00136Dr 2  85 rr            sta ptr_hi
00136Fr 2  20 rr rr         jsr msg_show
001372r 2  60               rts
001373r 2               .endproc
001373r 2               
001373r 2               ; ------------------------------------------------------------
001373r 2               ; monster_attack_player
001373r 2               ; Monster at temp_mon_idx attacks the player.
001373r 2               ; ------------------------------------------------------------
001373r 2               .proc monster_attack_player
001373r 2  A6 rr            ldx temp_mon_idx
001375r 2               
001375r 2                   ; Roll d20
001375r 2  A9 14            lda #D20_SIDES
001377r 2  20 rr rr         jsr rng_range
00137Ar 2  18               clc
00137Br 2  69 01            adc #$01                    ; 1-20
00137Dr 2               
00137Dr 2                   ; Add monster level
00137Dr 2  BC rr rr         ldy mon_type, x
001380r 2  18               clc
001381r 2  79 rr rr         adc mon_level, y
001384r 2               
001384r 2                   ; Compare against player defense
001384r 2  C5 rr            cmp player_def
001386r 2  90 25            bcc @miss
001388r 2               
001388r 2                   ; --- HIT ---
001388r 2                   ; Look up monster damage
001388r 2  BC rr rr         ldy mon_type, x
00138Br 2  B9 rr rr         lda mon_damage, y           ; Max damage for this type
00138Er 2  20 rr rr         jsr rng_range               ; 0 to max-1
001391r 2  18               clc
001392r 2  69 01            adc #$01                    ; 1 to max
001394r 2               
001394r 2                   ; Apply damage to player
001394r 2  85 rr            sta temp_1
001396r 2  A5 rr            lda player_hp
001398r 2  38               sec
001399r 2  E5 rr            sbc temp_1
00139Br 2  B0 02            bcs @not_dead
00139Dr 2  A9 00            lda #$00
00139Fr 2               @not_dead:
00139Fr 2  85 rr            sta player_hp
0013A1r 2               
0013A1r 2                   ; Show message
0013A1r 2  A9 rr            lda #<str_mon_hits
0013A3r 2  85 rr            sta ptr_lo
0013A5r 2  A9 rr            lda #>str_mon_hits
0013A7r 2  85 rr            sta ptr_hi
0013A9r 2  20 rr rr         jsr msg_show
0013ACr 2               
0013ACr 2  60               rts
0013ADr 2               
0013ADr 2               @miss:
0013ADr 2  A9 rr            lda #<str_mon_miss
0013AFr 2  85 rr            sta ptr_lo
0013B1r 2  A9 rr            lda #>str_mon_miss
0013B3r 2  85 rr            sta ptr_hi
0013B5r 2  20 rr rr         jsr msg_show
0013B8r 2  60               rts
0013B9r 2               .endproc
0013B9r 2               
0013B9r 2               ; ------------------------------------------------------------
0013B9r 2               ; check_level_up
0013B9r 2               ; Check if player has enough XP to level up.
0013B9r 2               ; XP thresholds: 10, 20, 40, 80, 160...
0013B9r 2               ; ------------------------------------------------------------
0013B9r 2               .proc check_level_up
0013B9r 2  A5 rr            lda player_level
0013BBr 2  C9 0C            cmp #12                     ; Max level
0013BDr 2  B0 30            bcs @done
0013BFr 2               
0013BFr 2                   ; Calculate threshold: 10 * 2^(level-1)
0013BFr 2                   ; Simplified: use lookup table
0013BFr 2  A6 rr            ldx player_level
0013C1r 2  CA               dex                         ; 0-based index
0013C2r 2  E0 08            cpx #$08
0013C4r 2  B0 29            bcs @done                   ; Safety check
0013C6r 2  BD rr rr         lda xp_thresholds, x
0013C9r 2  C5 rr            cmp player_xp
0013CBr 2  B0 22            bcs @done                   ; Not enough XP
0013CDr 2               
0013CDr 2                   ; Level up!
0013CDr 2  E6 rr            inc player_level
0013CFr 2               
0013CFr 2                   ; Increase max HP by 2-9
0013CFr 2  A9 08            lda #$08
0013D1r 2  20 rr rr         jsr rng_range               ; 0-7
0013D4r 2  18               clc
0013D5r 2  69 02            adc #$02                    ; 2-9
0013D7r 2  18               clc
0013D8r 2  65 rr            adc player_max_hp
0013DAr 2  90 02            bcc @hp_ok
0013DCr 2  A9 FF            lda #$FF
0013DEr 2               @hp_ok:
0013DEr 2  85 rr            sta player_max_hp
0013E0r 2               
0013E0r 2                   ; Fully heal
0013E0r 2  A5 rr            lda player_max_hp
0013E2r 2  85 rr            sta player_hp
0013E4r 2               
0013E4r 2                   ; Show message
0013E4r 2  A9 rr            lda #<str_level_up
0013E6r 2  85 rr            sta ptr_lo
0013E8r 2  A9 rr            lda #>str_level_up
0013EAr 2  85 rr            sta ptr_hi
0013ECr 2  20 rr rr         jsr msg_show
0013EFr 2               
0013EFr 2               @done:
0013EFr 2  60               rts
0013F0r 2               .endproc
0013F0r 2               
0013F0r 2               ; ============================================================
0013F0r 2               ; XP threshold table
0013F0r 2               ; ============================================================
0013F0r 2               .segment "RODATA"
000010r 2               
000010r 2               xp_thresholds:
000010r 2  0A 14 28 50      .byte 10, 20, 40, 80, 160, 255, 255, 255    ; Levels 2-9+
000014r 2  A0 FF FF FF  
000018r 2               
000018r 1               .include "hud.asm"
000018r 2               ; ============================================================
000018r 2               ; HUD — Status bar and stat display
000018r 2               ; ============================================================
000018r 2               .segment "CODE"
0013F0r 2               
0013F0r 2               ; ------------------------------------------------------------
0013F0r 2               ; hud_draw
0013F0r 2               ; Draw the full HUD (called once on screen init).
0013F0r 2               ; Row 0: @  HP:12/12  Str:16  Fl:1
0013F0r 2               ; Row 1: Def:10  Exp:1/0  Gold:0
0013F0r 2               ; Uses VRAM buffer (flushed by NMI).
0013F0r 2               ; ------------------------------------------------------------
0013F0r 2               .proc hud_draw
0013F0r 2                   ; --- Row 0 ---
0013F0r 2                   ; Player symbol @
0013F0r 2  A9 00            lda #$00
0013F2r 2  85 rr            sta temp_1
0013F4r 2  A9 00            lda #HUD_ROW_0
0013F6r 2  85 rr            sta temp_2
0013F8r 2  A9 15            lda #CHR_PLAYER
0013FAr 2  20 rr rr         jsr vram_write_tile
0013FDr 2               
0013FDr 2                   ; "HP:"
0013FDr 2  A9 rr            lda #<str_hp
0013FFr 2  85 rr            sta ptr_lo
001401r 2  A9 rr            lda #>str_hp
001403r 2  85 rr            sta ptr_hi
001405r 2  A9 02            lda #$02
001407r 2  85 rr            sta temp_1
001409r 2  A9 00            lda #HUD_ROW_0
00140Br 2  85 rr            sta temp_2
00140Dr 2  20 rr rr         jsr draw_text
001410r 2               
001410r 2                   ; HP current
001410r 2  A9 05            lda #$05
001412r 2  85 rr            sta temp_1
001414r 2  A9 00            lda #HUD_ROW_0
001416r 2  85 rr            sta temp_2
001418r 2  A5 rr            lda player_hp
00141Ar 2  20 rr rr         jsr draw_number_3d
00141Dr 2               
00141Dr 2                   ; "/"
00141Dr 2  A9 08            lda #$08
00141Fr 2  85 rr            sta temp_1
001421r 2  A9 00            lda #HUD_ROW_0
001423r 2  85 rr            sta temp_2
001425r 2  A9 2F            lda #'/'
001427r 2  20 rr rr         jsr vram_write_tile
00142Ar 2               
00142Ar 2                   ; HP max
00142Ar 2  A9 09            lda #$09
00142Cr 2  85 rr            sta temp_1
00142Er 2  A9 00            lda #HUD_ROW_0
001430r 2  85 rr            sta temp_2
001432r 2  A5 rr            lda player_max_hp
001434r 2  20 rr rr         jsr draw_number_3d
001437r 2               
001437r 2                   ; "Str:"
001437r 2  A9 rr            lda #<str_str
001439r 2  85 rr            sta ptr_lo
00143Br 2  A9 rr            lda #>str_str
00143Dr 2  85 rr            sta ptr_hi
00143Fr 2  A9 13            lda #$13
001441r 2  85 rr            sta temp_1
001443r 2  A9 00            lda #HUD_ROW_0
001445r 2  85 rr            sta temp_2
001447r 2  20 rr rr         jsr draw_text
00144Ar 2               
00144Ar 2                   ; Str value
00144Ar 2  A9 17            lda #$17
00144Cr 2  85 rr            sta temp_1
00144Er 2  A9 00            lda #HUD_ROW_0
001450r 2  85 rr            sta temp_2
001452r 2  A5 rr            lda player_str
001454r 2  20 rr rr         jsr draw_number
001457r 2               
001457r 2                   ; "Fl:"
001457r 2  A9 rr            lda #<str_fl
001459r 2  85 rr            sta ptr_lo
00145Br 2  A9 rr            lda #>str_fl
00145Dr 2  85 rr            sta ptr_hi
00145Fr 2  A9 1A            lda #$1A
001461r 2  85 rr            sta temp_1
001463r 2  A9 00            lda #HUD_ROW_0
001465r 2  85 rr            sta temp_2
001467r 2  20 rr rr         jsr draw_text
00146Ar 2               
00146Ar 2                   ; Floor number
00146Ar 2  A9 1D            lda #$1D
00146Cr 2  85 rr            sta temp_1
00146Er 2  A9 00            lda #HUD_ROW_0
001470r 2  85 rr            sta temp_2
001472r 2  A5 rr            lda dungeon_level
001474r 2  18               clc
001475r 2  69 01            adc #$01
001477r 2  20 rr rr         jsr draw_number
00147Ar 2               
00147Ar 2                   ; --- Row 1 ---
00147Ar 2                   ; "Def:"
00147Ar 2  A9 rr            lda #<str_def
00147Cr 2  85 rr            sta ptr_lo
00147Er 2  A9 rr            lda #>str_def
001480r 2  85 rr            sta ptr_hi
001482r 2  A9 00            lda #$00
001484r 2  85 rr            sta temp_1
001486r 2  A9 01            lda #HUD_ROW_1
001488r 2  85 rr            sta temp_2
00148Ar 2  20 rr rr         jsr draw_text
00148Dr 2               
00148Dr 2                   ; Def value
00148Dr 2  A9 04            lda #$04
00148Fr 2  85 rr            sta temp_1
001491r 2  A9 01            lda #HUD_ROW_1
001493r 2  85 rr            sta temp_2
001495r 2  A5 rr            lda player_def
001497r 2  20 rr rr         jsr draw_number
00149Ar 2               
00149Ar 2                   ; "Exp:"
00149Ar 2  A9 rr            lda #<str_exp
00149Cr 2  85 rr            sta ptr_lo
00149Er 2  A9 rr            lda #>str_exp
0014A0r 2  85 rr            sta ptr_hi
0014A2r 2  A9 08            lda #$08
0014A4r 2  85 rr            sta temp_1
0014A6r 2  A9 01            lda #HUD_ROW_1
0014A8r 2  85 rr            sta temp_2
0014AAr 2  20 rr rr         jsr draw_text
0014ADr 2               
0014ADr 2                   ; Exp level
0014ADr 2  A9 0C            lda #$0C
0014AFr 2  85 rr            sta temp_1
0014B1r 2  A9 01            lda #HUD_ROW_1
0014B3r 2  85 rr            sta temp_2
0014B5r 2  A5 rr            lda player_level
0014B7r 2  20 rr rr         jsr draw_number
0014BAr 2               
0014BAr 2                   ; "/"
0014BAr 2  A9 0E            lda #$0E
0014BCr 2  85 rr            sta temp_1
0014BEr 2  A9 01            lda #HUD_ROW_1
0014C0r 2  85 rr            sta temp_2
0014C2r 2  A9 2F            lda #'/'
0014C4r 2  20 rr rr         jsr vram_write_tile
0014C7r 2               
0014C7r 2                   ; XP value
0014C7r 2  A9 0F            lda #$0F
0014C9r 2  85 rr            sta temp_1
0014CBr 2  A9 01            lda #HUD_ROW_1
0014CDr 2  85 rr            sta temp_2
0014CFr 2  A5 rr            lda player_xp
0014D1r 2  20 rr rr         jsr draw_number_3d
0014D4r 2               
0014D4r 2                   ; "Gold:"
0014D4r 2  A9 rr            lda #<str_gold
0014D6r 2  85 rr            sta ptr_lo
0014D8r 2  A9 rr            lda #>str_gold
0014DAr 2  85 rr            sta ptr_hi
0014DCr 2  A9 15            lda #$15
0014DEr 2  85 rr            sta temp_1
0014E0r 2  A9 01            lda #HUD_ROW_1
0014E2r 2  85 rr            sta temp_2
0014E4r 2  20 rr rr         jsr draw_text
0014E7r 2               
0014E7r 2                   ; Gold value
0014E7r 2  A9 1A            lda #$1A
0014E9r 2  85 rr            sta temp_1
0014EBr 2  A9 01            lda #HUD_ROW_1
0014EDr 2  85 rr            sta temp_2
0014EFr 2  A5 rr            lda player_gold
0014F1r 2  20 rr rr         jsr draw_number_3d
0014F4r 2               
0014F4r 2  60               rts
0014F5r 2               .endproc
0014F5r 2               
0014F5r 2               ; ------------------------------------------------------------
0014F5r 2               ; hud_update
0014F5r 2               ; Update only changed HUD values (called after each turn).
0014F5r 2               ; More efficient than redrawing everything.
0014F5r 2               ; ------------------------------------------------------------
0014F5r 2               .proc hud_update
0014F5r 2                   ; HP current
0014F5r 2  A9 05            lda #$05
0014F7r 2  85 rr            sta temp_1
0014F9r 2  A9 00            lda #HUD_ROW_0
0014FBr 2  85 rr            sta temp_2
0014FDr 2  A5 rr            lda player_hp
0014FFr 2  20 rr rr         jsr draw_number_3d
001502r 2               
