000549r 2               ; ============================================================
000549r 2               ; STAIRS STATE — transition between floors
000549r 2               ; ============================================================
000549r 2               .proc state_stairs
000549r 2  A5 rr            lda state_initialized
00054Br 2  D0 2A            bne @update
00054Dr 2               
00054Dr 2                   ; --- Init ---
00054Dr 2                   ; Increment or decrement dungeon level based on stairs direction
00054Dr 2  A5 rr            lda stairs_direction
00054Fr 2  F0 13            beq @going_down
000551r 2                   ; Going up
000551r 2  C6 rr            dec dungeon_level
000553r 2                   ; Check for win (ascending past level 0 with goblet)
000553r 2  A5 rr            lda dungeon_level
000555r 2  10 17            bpl @level_ok
000557r 2                   ; Would go above level 0 — win condition (Phase 3)
000557r 2  A9 00            lda #$00
000559r 2  85 rr            sta dungeon_level
00055Br 2  A9 05            lda #STATE_WIN
00055Dr 2  85 rr            sta game_state
00055Fr 2  A9 00            lda #$00
000561r 2  85 rr            sta state_initialized
000563r 2  60               rts
000564r 2               
000564r 2               @going_down:
000564r 2  E6 rr            inc dungeon_level
000566r 2  A5 rr            lda dungeon_level
000568r 2  C9 0D            cmp #MAX_DUNGEON_LEVEL
00056Ar 2  90 02            bcc @level_ok
00056Cr 2  C6 rr            dec dungeon_level           ; Can't go deeper than max
00056Er 2               
00056Er 2               @level_ok:
00056Er 2                   ; Transition to gameplay with new level
00056Er 2  A9 01            lda #STATE_GAMEPLAY
000570r 2  85 rr            sta game_state
000572r 2  A9 00            lda #$00
000574r 2  85 rr            sta state_initialized
000576r 2  60               rts
000577r 2               
000577r 2               @update:
000577r 2  60               rts
000578r 2               .endproc
