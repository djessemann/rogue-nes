0005E5r 2  A9 0C            lda #START_HP
0005E7r 2  85 rr            sta player_hp
0005E9r 2  85 rr            sta player_max_hp
0005EBr 2  A9 10            lda #START_STR
0005EDr 2  85 rr            sta player_str
0005EFr 2  A9 0A            lda #START_DEF
0005F1r 2  85 rr            sta player_def
